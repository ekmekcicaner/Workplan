@page "/login"
@layout EmptyLayout
@inject AuthApiService AuthApi
@inject Workplan.Client.Auth.LocalStorageService LocalStorage
@inject Workplan.Client.Auth.JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>Giriş Yap | Workplan</PageTitle>
<div class="flex min-h-screen items-center bg-neutral-50 px-4 py-6 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100 sm:px-6">
    <div class="mx-auto flex w-full max-w-sm flex-col gap-6">
        <div class="flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-500 text-lg font-bold text-neutral-950">W</span>
                <span class="text-lg font-semibold text-neutral-950 dark:text-white">Workplan</span>
            </div>
            <ThemeModeSelector />
        </div>

        <div class="card p-5 sm:p-6">
            <h1 class="mb-5 text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Giriş yap</h1>

            <EditForm Model="_model" OnValidSubmit="LoginAsync" class="flex flex-col gap-4">
                <DataAnnotationsValidator />
                <div>
                    <label class="field-label">E-posta</label>
                    <input class="input" @bind="_model.Email" @bind:event="oninput" autocomplete="email" />
                </div>
                <div>
                    <label class="field-label">Şifre</label>
                    <input class="input" type="password" @bind="_model.Password" @bind:event="oninput" autocomplete="current-password" />
                </div>

                @if (_error is not null)
                {
                    <p class="text-sm text-red-600 dark:text-red-400">@_error</p>
                }

                <button class="btn-primary mt-1 w-full" type="submit" disabled="@(!CanLogin)">
                    @(_busy ? "Giriş yapılıyor..." : "Giriş yap")
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private string? _error;
    private bool _busy;

    private static readonly EmailAddressAttribute EmailValidator = new();

    private bool CanLogin =>
        !_busy &&
        EmailValidator.IsValid(_model.Email) &&
        !string.IsNullOrWhiteSpace(_model.Password);

    private async Task LoginAsync()
    {
        _busy = true;
        _error = null;

        var result = await AuthApi.LoginAsync(new LoginRequest(_model.Email, _model.Password));
        if (result.Success && result.Data is not null)
        {
            await LocalStorage.SetAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.AccessTokenKey, result.Data.AccessToken);
            await LocalStorage.SetAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.RefreshTokenKey, result.Data.RefreshToken);
            AuthStateProvider.NotifyUserAuthentication(result.Data.AccessToken);
            Navigation.NavigateTo("/");
        }
        else
        {
            _error = result.ErrorMessage ?? "Giriş yapılamadı.";
            Toast.Error(_error);
        }

        _busy = false;
    }

    private class LoginFormModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string Password { get; set; } = "";
    }
}
