@page "/login"
@layout EmptyLayout
@inject AuthApiService AuthApi
@inject Workplan.Client.Auth.LocalStorageService LocalStorage
@inject Workplan.Client.Auth.JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>Giriş Yap | Workplan</PageTitle>
<div class="relative flex min-h-screen items-center overflow-hidden bg-canvas px-4 py-8 text-foreground sm:px-6">
    <div class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-brand-500/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 -left-32 h-96 w-96 rounded-full bg-neutral-900/5 blur-3xl dark:bg-surface-raised/5"></div>
    <div class="relative mx-auto grid w-full max-w-4xl overflow-hidden rounded-dialog border border-border bg-surface shadow-float md:grid-cols-[1.05fr_0.95fr]">
        <section class="hidden flex-col justify-between bg-foreground p-8 text-surface md:flex lg:p-10">
            <div class="flex items-center gap-3">
                <span class="brand-mark">W</span>
                <span class="text-lg font-extrabold">Workplan</span>
            </div>
            <div>
                <p class="text-xs font-bold uppercase tracking-[0.16em] text-brand-300">Saha Operasyonları</p>
                <h1 class="mt-3 text-3xl font-bold leading-tight tracking-tight">Planı, sahayı ve onay akışını tek yerde yönetin.</h1>
                <p class="mt-4 max-w-sm text-sm leading-6 text-surface/70">Günlük iş planlarından gerçekleşme takibine kadar ekiplerin ortak operasyon alanı.</p>
            </div>
            <p class="text-xs text-surface/50">Kurumsal operasyon yönetimi</p>
        </section>
        <section class="p-5 sm:p-8 lg:p-10">
        <div class="flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <span class="brand-mark">W</span>
                <span class="text-lg font-extrabold text-foreground">Workplan</span>
            </div>
            <ThemeModeSelector />
        </div>

        <div class="mt-8">
            <p class="page-kicker">Güvenli erişim</p>
            <h1 class="mb-2 text-2xl font-bold tracking-tight text-foreground">Hesabınıza giriş yapın</h1>
            <p class="mb-6 text-sm text-foreground-muted">Workplan çalışma alanınıza devam edin.</p>

            <EditForm Model="_model" OnValidSubmit="LoginAsync" class="flex flex-col gap-4">
                <DataAnnotationsValidator />
                <WpField Label="E-posta" For="login-email">
                    <ChildContent><InputText id="login-email" class="input" @bind-Value="_model.Email" autocomplete="email" /></ChildContent>
                    <Validation><ValidationMessage For="() => _model.Email" /></Validation>
                </WpField>
                <WpField Label="Şifre" For="login-password">
                    <ChildContent><InputText id="login-password" class="input" type="password" @bind-Value="_model.Password" autocomplete="current-password" /></ChildContent>
                    <Validation><ValidationMessage For="() => _model.Password" /></Validation>
                </WpField>

                @if (_error is not null)
                {
                    <WpNotice Tone="WpTone.Danger" Text="@_error" />
                }

                <WpButton Type="submit" CssClass="mt-1 w-full" Disabled="@(!CanLogin)" Loading="_busy">Giriş yap</WpButton>
            </EditForm>
        </div>
        </section>
    </div>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private string? _error;
    private bool _busy;

    private static readonly EmailAddressAttribute EmailValidator = new();

    private bool CanLogin =>
        !_busy &&
        EmailValidator.IsValid(_model.Email) &&
        !string.IsNullOrWhiteSpace(_model.Password);

    private async Task LoginAsync()
    {
        _busy = true;
        _error = null;

        var result = await AuthApi.LoginAsync(new LoginRequest(_model.Email, _model.Password));
        if (result.Success && result.Data is not null)
        {
            await LocalStorage.SetAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.AccessTokenKey, result.Data.AccessToken);
            await LocalStorage.SetAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.RefreshTokenKey, result.Data.RefreshToken);
            AuthStateProvider.NotifyUserAuthentication(result.Data.AccessToken);
            Navigation.NavigateTo("/");
        }
        else
        {
            _error = result.ErrorMessage ?? "Giriş yapılamadı.";
            Toast.Error(_error);
        }

        _busy = false;
    }

    private class LoginFormModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string Password { get; set; } = "";
    }
}
