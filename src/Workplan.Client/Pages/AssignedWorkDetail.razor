@page "/daily-plans/{Id:guid}"
@attribute [Authorize]
@inject DailyPlansApiService DailyPlansApi
@inject NotificationsApiService NotificationsApi
@inject AuthenticationStateProvider AuthStateProvider
@inject ConfirmService Confirm
@inject ToastService Toast
@inject ConnectivityService Connectivity

<PageTitle>İş Detayı | Workplan</PageTitle>

<PageHeader Title="İş Detayı"
            Subtitle="Saha işi, sorumlular, gerçekleşen değerler ve onay akışı."
            BackHref=""
            BackText="Ana Sayfa" />

<LoadingBlock Loading="_loading" ErrorText="@_loadError" />

@if (!_loading && _plan is not null)
{
    <div class="flex flex-col gap-4">
        <WorkDetailHero Plan="_plan" />
        <WorkResponsibilityStrip Plan="_plan" />

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-12 lg:items-start">
            <main class="order-2 flex flex-col gap-4 lg:order-1 lg:col-span-8">
                <PlanActualComparison Plan="_plan" />
                <FieldCommentPanel Comments="@_plan.Comments" />
                <WorkStatusTimeline History="_plan.History" />
            </main>

            <aside class="order-1 flex flex-col gap-4 lg:sticky lg:top-4 lg:order-2 lg:col-span-4">
                <AuthorizeView Roles="HeadOfMaster" Context="homContext">
                    <Authorized>
                        @if (_plan.Status == WorkStatus.Assigned || _plan.CrewTypeId is not null)
                        {
                            <CrewAssignmentPanel Plan="_plan"
                                                 @bind-SelectedCrewTypeId="_selectedCrewTypeId"
                                                 Busy="_busy"
                                                 IsOnline="Connectivity.IsOnline"
                                                 OnStart="ConfirmStartAsync" />
                        }

                        @if (_plan.Status == WorkStatus.InProgress)
                        {
                            <ProgressSubmissionForm Model="_submitProgress"
                                                    Plan="_plan"
                                                    Busy="_busy"
                                                    IsOnline="Connectivity.IsOnline"
                                                    OnSubmit="ConfirmSubmitProgressAsync" />
                        }
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="SiteChief,ProjectManager" Context="approvalContext">
                    <Authorized>
                        @if (CanApproveCurrentStage(approvalContext.User))
                        {
                            <ApprovalActionPanel Busy="_busy"
                                                 IsOnline="Connectivity.IsOnline"
                                                 HelpText="@ApprovalHelpText(approvalContext.User)"
                                                 OnApprove="ConfirmApproveAsync"
                                                 OnReject="ConfirmRejectAsync" />
                        }
                        else if (_plan.Status is WorkStatus.Submitted or WorkStatus.ApprovedByHoM or WorkStatus.ApprovedBySiteChief)
                        {
                            <div class="card">
                                <h2 class="mb-1 text-base font-semibold">Onay</h2>
                                <p class="text-sm text-neutral-500 dark:text-neutral-400">Bu kayıt şu anda sizin onay aşamanızda değil.</p>
                            </div>
                        }
                    </Authorized>
                </AuthorizeView>

                <ApprovalStepTracker Plan="_plan" />
            </aside>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private DailyPlanDetailDto? _plan;
    private bool _loading = true;
    private string? _loadError;
    private bool _busy;
    private Guid? _selectedCrewTypeId;
    private IReadOnlyList<string> _currentRoles = [];
    private readonly ProgressSubmissionForm.ProgressModel _submitProgress = new();

    protected override async Task OnInitializedAsync()
    {
        await Connectivity.InitializeAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        _selectedCrewTypeId = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentRoles = authState.User.FindAll(ClaimTypes.Role).Select(claim => claim.Value).ToList();

        var result = await DailyPlansApi.GetDetailAsync(Id);
        if (!result.Success || result.Data is null)
        {
            _loadError = result.ErrorMessage ?? "Plan bulunamadı veya görüntüleme yetkiniz yok.";
            _loading = false;
            return;
        }

        _plan = result.Data;
        await NotificationsApi.MarkDailyPlanReadAsync(Id);

        _loading = false;
    }

    private bool CanApproveCurrentStage(ClaimsPrincipal user)
    {
        if (_plan is null) return false;
        return (user.IsInRole("SiteChief") && _plan.Status is WorkStatus.Submitted or WorkStatus.ApprovedByHoM)
               || (user.IsInRole("ProjectManager") && _plan.Status == WorkStatus.ApprovedBySiteChief);
    }

    private string ApprovalHelpText(ClaimsPrincipal user)
    {
        if (user.IsInRole("SiteChief"))
            return "Şantiye Şefi onayı sonrası kayıt Proje Yöneticisi aşamasına geçer.";
        if (user.IsInRole("ProjectManager"))
            return "Project Manager son onayı sonrası kayıt Daily Report'a dahil edilir.";
        return "Bu kayıt yalnızca sizin onay aşamanızdaysa işlenir.";
    }

    private async Task ConfirmStartAsync()
    {
        if (_plan is null) return;
        if (!Connectivity.IsOnline)
        {
            Toast.Error("Bağlantı yokken iş başlatılamaz.");
            return;
        }

        if (_selectedCrewTypeId is null)
        {
            Toast.Error("Lütfen bir ekip tipi seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("İşi başlat", "Bu işi seçilen ekip tipi ile başlatmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _busy = true;
        var result = await DailyPlansApi.StartAsync(Id, _selectedCrewTypeId.Value);
        await HandleResultAsync(result, "İş başlatıldı.");
        _busy = false;
    }

    private async Task ConfirmSubmitProgressAsync()
    {
        if (!Connectivity.IsOnline)
        {
            Toast.Error("Bağlantı yokken gün sonu beyanı gönderilemez.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("Gün sonu beyanını gönder", "Bu beyan HoM onayı kabul edilip Şantiye Şefi onayına gönderilecek. Emin misiniz?");
        if (!confirmed) return;

        _busy = true;
        var request = new SubmitProgressRequest(
            _submitProgress.FactQuantity,
            _submitProgress.FactManDay,
            _submitProgress.Overtime,
            _submitProgress.Comment);
        var result = await DailyPlansApi.SubmitProgressAsync(Id, request);
        await HandleResultAsync(result, "Beyan kaydedildi ve Şantiye Şefi onayına gönderildi.");
        _busy = false;
    }

    private async Task ConfirmApproveAsync()
    {
        if (!Connectivity.IsOnline)
        {
            Toast.Error("Bağlantı yokken onay verilemez.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("Onayla", "Bu işi onaylamak istediğinize emin misiniz?");
        if (!confirmed) return;

        _busy = true;
        var result = await DailyPlansApi.ApproveAsync(Id);
        await HandleResultAsync(result, "İş onaylandı.");
        _busy = false;
    }

    private async Task<bool> ConfirmRejectAsync(string reason)
    {
        if (!Connectivity.IsOnline)
        {
            Toast.Error("Bağlantı yokken red gönderilemez.");
            return false;
        }

        if (string.IsNullOrWhiteSpace(reason))
        {
            Toast.Error("Lütfen red gerekçesi girin.");
            return false;
        }

        var targetLabel = RejectTargetLabel();
        var confirmed = await Confirm.ConfirmAsync("Reddet", $"Bu işi gerekçeyle {targetLabel} geri göndermek istediğinize emin misiniz?", danger: true);
        if (!confirmed) return false;

        _busy = true;
        var result = await DailyPlansApi.RejectAsync(Id, new RejectRequest(reason));
        await HandleResultAsync(result, $"İş {targetLabel} geri gönderildi.");
        _busy = false;
        return result.Success;
    }

    private string RejectTargetLabel() =>
        _plan?.Status == WorkStatus.ApprovedBySiteChief ? "Şantiye Şefi'ne" : "Ustabaşı'na";

    private async Task HandleResultAsync(ApiResult<bool> result, string successMessage)
    {
        if (result.Success)
        {
            Toast.Success(successMessage);
            _submitProgress.FactQuantity = null;
            _submitProgress.FactManDay = null;
            _submitProgress.Overtime = null;
            _submitProgress.Comment = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu. Kayıt başka bir kullanıcı tarafından değişmiş olabilir.");
            await LoadAsync();
        }
    }
}
