@page "/daily-plans/{Id:guid}"
@attribute [Authorize]
@inject DailyPlansApiService DailyPlansApi
@inject ProjectsApiService ProjectsApi
@inject CrewRegionsApiService CrewRegionsApi
@inject LocationsApiService LocationsApi
@inject WorkItemTypesApiService WorkItemTypesApi
@inject CrewsApiService CrewsApi
@inject NotificationsApiService NotificationsApi
@inject AuthenticationStateProvider AuthStateProvider
@inject ConfirmService Confirm
@inject ToastService Toast

<p class="mb-2"><a class="text-sm text-neutral-500 hover:underline dark:text-neutral-400" href="">&larr; Ana Sayfa</a></p>
<h1 class="mb-4 text-2xl font-semibold">İş Detayı</h1>

<LoadingBlock Loading="_loading" ErrorText="@_loadError" />

@if (!_loading && _plan is not null)
{
    <div class="card mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
            <p class="field-label">Proje</p>
            <p>@(_project?.Name ?? "-")</p>
        </div>
        <div>
            <p class="field-label">Saha Bölgesi</p>
            <p>@(_region?.Name ?? "-")</p>
        </div>
        <div>
            <p class="field-label">Lokasyon</p>
            <p>@(_location?.Name ?? "-")</p>
        </div>
        <div>
            <p class="field-label">İş Kalemi Tipi</p>
            <p>@(_workItemTypeName ?? "-")</p>
        </div>
        <div>
            <p class="field-label">Tarih</p>
            <p>@_plan.WorkDate.ToString("dd.MM.yyyy")</p>
        </div>
        <div>
            <p class="field-label">Durum</p>
            <StatusBadge Status="_plan.Status" />
        </div>
        <div>
            <p class="field-label">Planlanan</p>
            <p>@NumberDisplay.Format(_plan.PlannedQuantity) @UnitLabel(_plan.Unit) &middot; @NumberDisplay.Format(_plan.PlannedManDay) adam-gün</p>
        </div>
        <div>
            <p class="field-label">Gerçekleşen</p>
            <p>
                @NumberDisplay.Format(_plan.FactQuantity) @UnitLabel(_plan.Unit) &middot;
                @NumberDisplay.Format(_plan.FactManDay) adam-gün
                @(_plan.Overtime is { } ot ? $" · {NumberDisplay.Format(ot)} fazla mesai" : "")
            </p>
        </div>
        @if (!string.IsNullOrWhiteSpace(_plan.Comment))
        {
            <div class="sm:col-span-2">
                <p class="field-label">Yorum</p>
                <p>@_plan.Comment</p>
            </div>
        }
    </div>

    @if (_crew is not null)
    {
        <div class="card mb-6">
            <div class="mb-2 flex items-center justify-between">
                <h2 class="font-semibold">@_crew.Name</h2>
                <span class="badge">@_crew.Members.Count üye</span>
            </div>
            @if (_crew.Members.Count > 0)
            {
                <table class="table-base mb-3">
                    <thead>
                        <tr>
                            <th>Rol</th>
                            <th>Personel Ref.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in _crew.Members)
                        {
                            <tr>
                                <td>@member.WorkerType</td>
                                <td>@member.PersonnelRef</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="mb-3 text-sm text-neutral-500 dark:text-neutral-400">Ekipte kayıtlı üye yok.</p>
            }
            <a class="btn-secondary" href="@($"locations/{_plan.LocationId}/crews")">Ekip detayına git</a>
        </div>
    }

    <AuthorizeView Roles="HeadOfMaster" Context="assignContext">
        <Authorized>
            @if (_plan.Status == WorkStatus.Assigned)
            {
                <div class="card mb-6">
                    <h2 class="mb-1 font-semibold">İşi başlat</h2>
                    <AccessNote Roles="HeadOfMaster" />
                    <div class="flex flex-wrap items-end gap-2">
                        <div class="w-full sm:w-64">
                            <label class="field-label">Ekip</label>
                            <select class="input" @bind="_selectedCrewId" disabled="@(_crews.Count == 0)">
                                <option value="">Seçiniz</option>
                                @foreach (var crew in _crews)
                                {
                                    <option value="@crew.Id">@crew.Name</option>
                                }
                            </select>
                        </div>
                        <button class="btn-primary" disabled="@(!Guid.TryParse(_selectedCrewId, out _))" @onclick="ConfirmStartAsync">Başlat</button>
                        <a class="btn-secondary" href="@($"locations/{_plan.LocationId}/crews")">Yeni ekip oluştur</a>
                    </div>
                </div>
            }
            @if (_plan.Status == WorkStatus.InProgress)
            {
                <ProgressForm Model="_submitProgress" OnSubmit="ConfirmSubmitProgressAsync" />
            }
        </Authorized>
    </AuthorizeView>

    @if (_plan.Status is WorkStatus.Submitted or WorkStatus.ApprovedByHoM or WorkStatus.ApprovedBySiteChief)
    {
        <AuthorizeView Roles="SiteChief,ProjectManager" Context="approveContext">
            <Authorized>
                <ApprovalPanel OnApprove="ConfirmApproveAsync" OnReject="ConfirmRejectAsync" />
            </Authorized>
        </AuthorizeView>
    }

    <div class="card">
        <h2 class="mb-3 font-semibold">Durum Geçmişi</h2>
        @if (_plan.History is null || _plan.History.Count == 0)
        {
            <p class="text-sm text-neutral-500 dark:text-neutral-400">Geçmiş kaydı yok.</p>
        }
        else
        {
            <ul class="flex flex-col gap-2 text-sm">
                @foreach (var entry in _plan.History)
                {
                    <li class="border-b border-neutral-100 pb-2 last:border-0 dark:border-neutral-700/60">
                        <div class="flex items-center gap-2">
                            <StatusBadge Status="entry.FromStatus" />
                            <span>&rarr;</span>
                            <StatusBadge Status="entry.ToStatus" />
                            <span class="text-neutral-400">@entry.TransitionedAt.ToLocalTime().ToString("g")</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(entry.Note))
                        {
                            <p class="mt-1 text-neutral-600 dark:text-neutral-300">@entry.Note</p>
                        }
                    </li>
                }
            </ul>
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private DailyPlanDto? _plan;
    private ProjectDto? _project;
    private CrewRegionDto? _region;
    private LocationDto? _location;
    private string? _workItemTypeName;
    private bool _loading = true;
    private string? _loadError;

    private Guid? _currentUserId;
    private List<CrewDto> _crews = [];
    private CrewDto? _crew;
    private string _selectedCrewId = "";

    private readonly ProgressForm.ProgressModel _submitProgress = new();

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        var result = await DailyPlansApi.GetByIdAsync(Id);
        if (!result.Success || result.Data is null)
        {
            _loadError = result.ErrorMessage ?? "Plan bulunamadı.";
            _loading = false;
            return;
        }

        _plan = result.Data;
        await NotificationsApi.MarkDailyPlanReadAsync(Id);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = Guid.TryParse(authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var uid) ? uid : null;

        var projectTask = ProjectsApi.GetByIdAsync(_plan.ProjectId);
        var regionTask = CrewRegionsApi.GetByIdAsync(_plan.CrewRegionId);
        var locationTask = LocationsApi.GetByIdAsync(_plan.LocationId);
        var typesTask = WorkItemTypesApi.GetTreeAsync(includeInactive: true);

        await Task.WhenAll(projectTask, regionTask, locationTask, typesTask);

        _project = (await projectTask).Data;
        _region = (await regionTask).Data;
        _location = (await locationTask).Data;

        var types = (await typesTask).Data ?? [];
        _workItemTypeName = Flatten(types).FirstOrDefault(t => t.Id == _plan.WorkItemTypeId)?.Name;

        if (_plan.Status == WorkStatus.Assigned)
        {
            var crewsResult = await CrewsApi.GetByLocationAsync(_plan.LocationId);
            _crews = (crewsResult.Data ?? []).Where(c => c.CreatedByHoMId == _currentUserId).ToList();
        }
        else if (_plan.CrewId is { } crewId)
        {
            var crewsResult = await CrewsApi.GetByLocationAsync(_plan.LocationId);
            _crew = (crewsResult.Data ?? []).FirstOrDefault(c => c.Id == crewId);
        }

        _loading = false;
    }

    private static string UnitLabel(Unit unit) => unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => ""
    };

    private static IEnumerable<WorkItemTypeDto> Flatten(IEnumerable<WorkItemTypeDto> nodes)
    {
        foreach (var node in nodes)
        {
            yield return node;
            foreach (var child in Flatten(node.Children))
            {
                yield return child;
            }
        }
    }

    private async Task ConfirmStartAsync()
    {
        if (!Guid.TryParse(_selectedCrewId, out var crewId))
        {
            Toast.Error("Lütfen bir ekip seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("İşi başlat", "Bu işi başlatmak istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await DailyPlansApi.StartAsync(Id, crewId);
        await HandleResultAsync(result, "İş başlatıldı.");
    }

    private async Task ConfirmSubmitProgressAsync()
    {
        var confirmed = await Confirm.ConfirmAsync("İlerlemeyi onaya sun", "Girilen değerlerle onaya sunmak istediğinize emin misiniz?");
        if (!confirmed) return;

        var request = new SubmitProgressRequest(
            _submitProgress.FactQuantity, _submitProgress.FactManDay, _submitProgress.Overtime, _submitProgress.Comment);
        var result = await DailyPlansApi.SubmitProgressAsync(Id, request);
        await HandleResultAsync(result, "İlerleme kaydedildi ve onaya sunuldu.");
    }

    private async Task ConfirmApproveAsync()
    {
        var confirmed = await Confirm.ConfirmAsync("Onayla", "Bu işi onaylamak istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await DailyPlansApi.ApproveAsync(Id);
        await HandleResultAsync(result, "İş onaylandı.");
    }

    private async Task<bool> ConfirmRejectAsync(string reason)
    {
        if (string.IsNullOrWhiteSpace(reason))
        {
            Toast.Error("Lütfen red nedeni girin.");
            return false;
        }

        var confirmed = await Confirm.ConfirmAsync("Reddet", "Bu işi reddetmek istediğinize emin misiniz?", danger: true);
        if (!confirmed) return false;

        var result = await DailyPlansApi.RejectAsync(Id, new RejectRequest(reason));
        await HandleResultAsync(result, "İş reddedildi.");
        return result.Success;
    }

    private async Task HandleResultAsync(ApiResult<bool> result, string successMessage)
    {
        if (result.Success)
        {
            Toast.Success(successMessage);
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }
}
