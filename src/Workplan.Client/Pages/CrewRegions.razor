@page "/projects/{ProjectId:guid}/regions"
@attribute [Authorize]
@inject CrewRegionsApiService CrewRegionsApi
@inject ProjectsApiService ProjectsApi
@inject UsersApiService UsersApi
@inject ConfirmService Confirm
@inject ToastService Toast

<PageTitle>Saha Bölgeleri | Workplan</PageTitle>

<section class="space-y-4">
    <PageHeader Title="@($"Saha Bölgeleri{(_project is not null ? $" · {_project.Name}" : "")}")"
                Subtitle="Proje altındaki saha bölgelerini, sorumlu rolleri ve lokasyon geçişlerini yönet."
                BackHref="projects"
                BackText="Projeler">
        <Actions>
            <button class="btn-secondary" @onclick="LoadAsync">
                <Icon Name="refresh" CssClass="h-4 w-4" />Yenile
            </button>
        </Actions>
    </PageHeader>

    <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="formAuth">
        <Authorized>
            <div class="surface-panel p-3">
                <EditForm Model="_newRegion" OnValidSubmit="CreateAsync" class="grid grid-cols-1 gap-3 xl:grid-cols-[8rem_1fr_16rem_16rem_auto] xl:items-end">
                    <DataAnnotationsValidator />
                    <div>
                        <label class="field-label">Kod</label>
                        <InputText class="input" @bind-Value="_newRegion.Code" />
                        <ValidationMessage For="() => _newRegion.Code" />
                    </div>
                    <div>
                        <label class="field-label">İsim</label>
                        <InputText class="input" @bind-Value="_newRegion.Name" />
                        <ValidationMessage For="() => _newRegion.Name" />
                    </div>
                    <div>
                        <label class="field-label">Şantiye Şefi</label>
                        <UserPicker Role="SiteChief" @bind-Value="_newRegion.SiteChiefUserId" Placeholder="Şantiye şefi ara..." />
                    </div>
                    <div>
                        <label class="field-label">Tech Office</label>
                        <UserPicker Role="TechnicalOfficeEngineer" @bind-Value="_newRegion.TechOfficeUserId" Placeholder="Tech office ara..." />
                    </div>
                    <WpButton Type="submit" Icon="plus" Disabled="@(!CanCreateRegion)" Loading="_creating">Oluştur</WpButton>
                </EditForm>
            </div>
        </Authorized>
    </AuthorizeView>

    <WpEntityToolbar Label="Pasif bölgeleri de göster" Count="_regions.Count" @bind-IncludeInactive="_includeInactive" OnChanged="LoadAsync" />

    <WpResponsiveDataView TItem="CrewRegionDto"
                          Items="_regions"
                          Loading="_loading"
                          ErrorText="@_loadError"
                          ItemKey="@(region => region.Id)"
                          EmptyTitle="Henüz saha bölgesi yok"
                          EmptyText="Bu proje için saha bölgesi oluşturarak lokasyon planlamasına başlayın.">
        <Columns>
            <PropertyColumn TGridItem="CrewRegionDto" TProp="string" Property="@(region => region.Code)" Title="Kod" Sortable="true" />
            <PropertyColumn TGridItem="CrewRegionDto" TProp="string" Property="@(region => region.Name)" Title="İsim" Sortable="true" />
            <TemplateColumn TGridItem="CrewRegionDto" Title="Şantiye Şefi" Context="region">@SiteChiefName(region.SiteChiefUserId)</TemplateColumn>
            <TemplateColumn TGridItem="CrewRegionDto" Title="Teknik Ofis" Context="region">@TechOfficeName(region.TechOfficeUserId)</TemplateColumn>
            <TemplateColumn TGridItem="CrewRegionDto" Title="Durum" Context="region">@StatusPill(region.IsActive)</TemplateColumn>
            <TemplateColumn TGridItem="CrewRegionDto" Title="İşlem" Align="Align.End" Context="region"><button class="entity-row-action" @onclick="() => OpenDetail(region)">Yönet</button></TemplateColumn>
        </Columns>
        <MobileTemplate Context="region">
            <article class="entity-card">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-xs font-semibold uppercase text-foreground-muted">@region.Code</p>
                        <h2 class="truncate font-semibold">@region.Name</h2>
                        <p class="mt-1 truncate text-sm text-foreground-muted">@SiteChiefName(region.SiteChiefUserId)</p>
                    </div>
                    @StatusPill(region.IsActive)
                </div>
                <button class="btn-secondary mt-3 w-full" @onclick="() => OpenDetail(region)">Yönet</button>
            </article>
        </MobileTemplate>
    </WpResponsiveDataView>
</section>

<DetailPanel Show="_selectedRegion is not null"
             Title="@(_selectedRegion?.Name ?? "")"
             Subtitle="@(_selectedRegion?.Code ?? "Saha bölgesi")"
             OnClose="CloseDetail">
    @if (_selectedRegion is not null)
    {
        <div class="space-y-4">
            <a class="btn-secondary w-full" href="@($"projects/{ProjectId}/regions/{_selectedRegion.Id}/locations")">
                <Icon Name="map-pin" CssClass="h-4 w-4" />Lokasyonlar
            </a>

            <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="editAuth">
                <Authorized>
                    <div class="space-y-3 rounded-lg border border-border bg-surface-muted p-3">
                        <h3 class="text-sm font-semibold">Bölge bilgileri</h3>
                        <div>
                            <label class="field-label">Kod</label>
                            <input class="input" @bind="_editModel.Code" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="field-label">İsim</label>
                            <input class="input" @bind="_editModel.Name" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="field-label">Şantiye Şefi</label>
                            <UserPicker Role="SiteChief" @bind-Value="_editModel.SiteChiefUserId" Placeholder="Şantiye şefi ara..." />
                        </div>
                        <div>
                            <label class="field-label">Tech Office</label>
                            <UserPicker Role="TechnicalOfficeEngineer" @bind-Value="_editModel.TechOfficeUserId" Placeholder="Tech office ara..." />
                        </div>
                        <button class="btn-primary w-full" disabled="@(!CanUpdateRegion)" @onclick="ConfirmUpdateAsync">
                            <Icon Name="check" CssClass="h-4 w-4" />Kaydet
                        </button>
                    </div>

                    <div class="rounded-lg border border-border bg-surface-muted p-3">
                        <p class="field-label">Durum</p>
                        <div class="flex items-center justify-between gap-3">
                            @StatusPill(_selectedRegion.IsActive)
                            <button class="@(_selectedRegion.IsActive ? "btn-danger" : "btn-secondary")"
                                    @onclick="() => ConfirmSetActiveAsync(_selectedRegion, !_selectedRegion.IsActive)">
                                @(_selectedRegion.IsActive ? "Pasif Yap" : "Aktif Yap")
                            </button>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    }
</DetailPanel>

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private ProjectDto? _project;
    private List<CrewRegionDto> _regions = [];
    private List<UserDto> _siteChiefs = [];
    private List<UserDto> _techOffices = [];
    private bool _loading = true;
    private string? _loadError;
    private bool _creating;
    private bool _includeInactive;
    private readonly NewRegionModel _newRegion = new();
    private CrewRegionDto? _selectedRegion;
    private readonly EditRegionModel _editModel = new();

    private bool CanCreateRegion =>
        !_creating &&
        !string.IsNullOrWhiteSpace(_newRegion.Code) &&
        !string.IsNullOrWhiteSpace(_newRegion.Name);

    private bool CanUpdateRegion =>
        _selectedRegion is not null &&
        !string.IsNullOrWhiteSpace(_editModel.Code) &&
        !string.IsNullOrWhiteSpace(_editModel.Name);

    protected override async Task OnInitializedAsync()
    {
        var siteChiefResult = await UsersApi.GetUsersAsync("SiteChief");
        _siteChiefs = siteChiefResult.Data ?? [];
        var techOfficeResult = await UsersApi.GetUsersAsync("TechnicalOfficeEngineer");
        _techOffices = techOfficeResult.Data ?? [];
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        var projectResult = await ProjectsApi.GetByIdAsync(ProjectId);
        if (projectResult.Success)
        {
            _project = projectResult.Data;
        }

        var result = await CrewRegionsApi.GetByProjectAsync(ProjectId, _includeInactive);
        if (result.Success)
        {
            _regions = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }

        _loading = false;
    }

    private string SiteChiefName(Guid? userId) => userId is null ? "-" : _siteChiefs.FirstOrDefault(u => u.Id == userId)?.FullName ?? "-";
    private string TechOfficeName(Guid? userId) => userId is null ? "-" : _techOffices.FirstOrDefault(u => u.Id == userId)?.FullName ?? "-";

    private async Task CreateAsync()
    {
        var confirmed = await Confirm.ConfirmAsync(
            "Saha bölgesi oluştur", $"\"{_newRegion.Name}\" saha bölgesini oluşturmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        var result = await CrewRegionsApi.CreateAsync(new CreateCrewRegionRequest(
            ProjectId,
            _newRegion.Code,
            _newRegion.Name,
            _newRegion.SiteChiefUserId,
            _newRegion.TechOfficeUserId));
        if (result.Success)
        {
            Toast.Success("Saha bölgesi oluşturuldu.");
            _newRegion.Code = "";
            _newRegion.Name = "";
            _newRegion.SiteChiefUserId = null;
            _newRegion.TechOfficeUserId = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Saha bölgesi oluşturulamadı.");
        }

        _creating = false;
    }

    private void OpenDetail(CrewRegionDto region)
    {
        _selectedRegion = region;
        _editModel.Code = region.Code;
        _editModel.Name = region.Name;
        _editModel.SiteChiefUserId = region.SiteChiefUserId;
        _editModel.TechOfficeUserId = region.TechOfficeUserId;
    }

    private void CloseDetail() => _selectedRegion = null;

    private async Task ConfirmUpdateAsync()
    {
        if (_selectedRegion is null) return;

        var confirmed = await Confirm.ConfirmAsync("Saha bölgesini güncelle", "Değişiklikleri kaydetmek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await CrewRegionsApi.UpdateAsync(_selectedRegion.Id, new UpdateCrewRegionRequest(_editModel.Code, _editModel.Name));
        if (result.Success && _editModel.SiteChiefUserId is { } siteChiefUserId)
        {
            result = await CrewRegionsApi.AssignSiteChiefAsync(_selectedRegion.Id, siteChiefUserId);
        }
        if (result.Success && _editModel.TechOfficeUserId is { } techOfficeUserId)
        {
            result = await CrewRegionsApi.AssignTechOfficeAsync(_selectedRegion.Id, techOfficeUserId);
        }

        if (result.Success)
        {
            Toast.Success("Saha bölgesi güncellendi.");
            CloseDetail();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Saha bölgesi güncellenemedi.");
        }
    }

    private async Task ConfirmSetActiveAsync(CrewRegionDto region, bool isActive)
    {
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            $"Saha bölgesini {action} yap", $"\"{region.Name}\" bölgesini {action} yapmak istediğinize emin misiniz?", danger: !isActive);
        if (!confirmed) return;

        var result = await CrewRegionsApi.SetActiveAsync(region.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"Saha bölgesi {action} yapıldı.");
            CloseDetail();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }

    private static RenderFragment StatusPill(bool isActive) =>
        @<WpBadge Tone="@(isActive ? WpTone.Success : WpTone.Danger)">@(isActive ? "Aktif" : "Pasif")</WpBadge>;

    private class NewRegionModel
    {
        [Required, MaxLength(50)] public string Code { get; set; } = "";
        [Required, MaxLength(200)] public string Name { get; set; } = "";
        public Guid? SiteChiefUserId { get; set; }
        public Guid? TechOfficeUserId { get; set; }
    }

    private class EditRegionModel
    {
        [Required, MaxLength(50)] public string Code { get; set; } = "";
        [Required, MaxLength(200)] public string Name { get; set; } = "";
        public Guid? SiteChiefUserId { get; set; }
        public Guid? TechOfficeUserId { get; set; }
    }
}
