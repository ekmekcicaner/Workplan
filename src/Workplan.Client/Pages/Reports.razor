@page "/reports"
@attribute [Authorize(Roles = Roles.Reporting)]
@inject ReportsApiService ReportsApi
@inject ProjectsApiService ProjectsApi
@inject CrewRegionsApiService CrewRegionsApi

<PageTitle>Raporlamalar | Workplan</PageTitle>
<section class="space-y-4">
<PageHeader Title="Günlük Rapor"
            Subtitle="PM onayı tamamlanan işlerde plan, gerçekleşen ve fazla mesai özetini takip et.">
    <Actions>
        <button class="btn-secondary" @onclick="LoadReportAsync">
            <Icon Name="refresh" CssClass="h-4 w-4" />Yenile
        </button>
    </Actions>
</PageHeader>

<WpFilterPanel Title="Rapor filtreleri" Description="Tarih, proje ve saha bölgesi kapsamını belirleyin.">
    <div class="grid grid-cols-1 gap-3 lg:grid-cols-[12rem_1fr_1fr_auto] lg:items-end">
        <div>
            <label class="field-label">İş tarihi</label>
            <input class="input" type="date" value="@(_workDate?.ToString("yyyy-MM-dd") ?? "")" @onchange="OnDateChangedAsync" />
        </div>
        <div>
            <label class="field-label">Proje</label>
            <select class="input" value="@_projectId" @onchange="OnProjectChangedAsync">
                <option value="">Tümü</option>
                @foreach (var project in _projects)
                {
                    <option value="@project.Id">@project.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="field-label">Saha bölgesi</label>
            <select class="input" value="@_crewRegionId" @onchange="OnRegionChangedAsync" disabled="@(_regions.Count == 0)">
                <option value="">Tümü</option>
                @foreach (var region in _regions)
                {
                    <option value="@region.Id">@region.Name</option>
                }
            </select>
        </div>
        <div class="flex items-end">
            <button class="btn-primary w-full" @onclick="LoadReportAsync">
                <Icon Name="search" CssClass="h-4 w-4" />Filtrele
            </button>
        </div>
    </div>
</WpFilterPanel>

<LoadingBlock Loading="_loading" ErrorText="@_loadError" />

@if (!_loading && _report is not null)
{
    <ReportKpiSummary Report="_report" />

    <section class="space-y-3">
        <div class="mb-3 flex items-center justify-between gap-3">
            <h2 class="text-base font-semibold">Onaylanmış İşler</h2>
            <span class="badge">@_report.Items.Count</span>
        </div>
        <WpResponsiveDataView TItem="DailyReportItemDto"
                              Items="_report.Items"
                              ItemKey="@(item => item.Id)"
                              PageSize="25"
                              EmptyTitle="Onaylanmış kayıt yok"
                              EmptyText="Bu filtrelerle rapora dahil edilmiş kayıt bulunamadı.">
            <Columns>
                <PropertyColumn TGridItem="DailyReportItemDto" TProp="DateOnly" Property="@(item => item.WorkDate)" Title="Tarih" Sortable="true" Format="dd.MM.yyyy" />
                <PropertyColumn TGridItem="DailyReportItemDto" TProp="string" Property="@(item => item.ProjectName)" Title="Proje" Sortable="true" />
                <PropertyColumn TGridItem="DailyReportItemDto" TProp="string" Property="@(item => item.LocationName)" Title="Lokasyon" Sortable="true" />
                <PropertyColumn TGridItem="DailyReportItemDto" TProp="string" Property="@(item => item.WorkItemTypeName)" Title="İş Kalemi" Sortable="true" />
                <TemplateColumn TGridItem="DailyReportItemDto" Title="Plan" Context="item">@NumberDisplay.Format(item.PlannedQuantity) @UnitLabel(item.Unit)</TemplateColumn>
                <TemplateColumn TGridItem="DailyReportItemDto" Title="Gerçek" Context="item">@NumberDisplay.Format(item.FactQuantity) @UnitLabel(item.Unit)</TemplateColumn>
                <TemplateColumn TGridItem="DailyReportItemDto" Title="AG" Context="item">@NumberDisplay.Format(item.FactManDay) / @NumberDisplay.Format(item.PlannedManDay)</TemplateColumn>
                <PropertyColumn TGridItem="DailyReportItemDto" TProp="decimal" Property="@(item => item.Overtime)" Title="FM" Sortable="true" />
                <TemplateColumn TGridItem="DailyReportItemDto" Title="İşlem" Align="Align.End" Context="item"><a class="entity-row-action" href="@($"daily-plans/{item.Id}")">Detay</a></TemplateColumn>
            </Columns>
            <MobileTemplate Context="item">
                <article class="entity-card">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <h3 class="truncate font-semibold">@item.WorkItemTypeName</h3>
                            <p class="truncate text-sm text-foreground-muted">@item.ProjectName · @item.LocationName</p>
                        </div>
                        <span class="badge">@item.WorkDate.ToString("dd.MM")</span>
                    </div>
                    <dl class="mt-3 grid grid-cols-2 gap-3 text-sm">
                        <div>
                            <dt class="field-label">Plan</dt>
                            <dd>@NumberDisplay.Format(item.PlannedQuantity) @UnitLabel(item.Unit)</dd>
                        </div>
                        <div>
                            <dt class="field-label">Gerçek</dt>
                            <dd>@NumberDisplay.Format(item.FactQuantity) @UnitLabel(item.Unit)</dd>
                        </div>
                        <div>
                            <dt class="field-label">Adam-gün</dt>
                            <dd>@NumberDisplay.Format(item.FactManDay)</dd>
                        </div>
                        <div>
                            <dt class="field-label">FM</dt>
                            <dd>@NumberDisplay.Format(item.Overtime)</dd>
                        </div>
                    </dl>
                    <a class="btn-secondary mt-3 w-full" href="@($"daily-plans/{item.Id}")">Detay</a>
                </article>
            </MobileTemplate>
        </WpResponsiveDataView>
    </section>
}
</section>

@code {
    private DailyReportDto? _report;
    private List<ProjectDto> _projects = [];
    private List<CrewRegionDto> _regions = [];
    private bool _loading = true;
    private string? _loadError;
    private DateOnly? _workDate;
    private string _projectId = "";
    private string _crewRegionId = "";

    protected override async Task OnInitializedAsync()
    {
        var projectsResult = await ProjectsApi.GetAllAsync();
        _projects = projectsResult.Data ?? [];
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        _loading = true;
        _loadError = null;
        var result = await ReportsApi.GetDailyAsync(
            _workDate,
            Guid.TryParse(_projectId, out var projectId) ? projectId : null,
            Guid.TryParse(_crewRegionId, out var regionId) ? regionId : null);

        if (result.Success)
        {
            _report = result.Data ?? new DailyReportDto(
                new DailyReportSummaryDto(0, 0, 0, 0, null), [], [], []);
        }
        else
        {
            _loadError = result.ErrorMessage;
        }
        _loading = false;
    }

    private async Task OnDateChangedAsync(ChangeEventArgs args)
    {
        _workDate = DateOnly.TryParse(args.Value?.ToString(), out var date) ? date : null;
        await LoadReportAsync();
    }

    private async Task OnProjectChangedAsync(ChangeEventArgs args)
    {
        _projectId = args.Value?.ToString() ?? "";
        _crewRegionId = "";
        _regions = [];
        if (Guid.TryParse(_projectId, out var projectId))
        {
            var result = await CrewRegionsApi.GetByProjectAsync(projectId);
            _regions = result.Data ?? [];
        }
        await LoadReportAsync();
    }

    private async Task OnRegionChangedAsync(ChangeEventArgs args)
    {
        _crewRegionId = args.Value?.ToString() ?? "";
        await LoadReportAsync();
    }

    private static string UnitLabel(Unit unit) => unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => ""
    };
}
