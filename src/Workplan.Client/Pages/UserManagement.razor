@page "/user-management"
@attribute [Authorize(Roles = "SystemAdmin")]
@inject UsersApiService UsersApi
@inject ConfirmService Confirm
@inject ToastService Toast

<PageTitle>Kullanıcı Yönetimi | Workplan</PageTitle>

<section class="space-y-4">
    <PageHeader Title="Kullanıcı Yönetimi"
                Subtitle="Kullanıcı oluştur, rolleri güncelle, şifre sıfırla ve erişimi aktif/pasif yönet.">
        <Actions>
            <button class="btn-secondary" @onclick="LoadAsync">
                <Icon Name="refresh" CssClass="h-4 w-4" />Yenile
            </button>
        </Actions>
    </PageHeader>

    <div class="surface-panel p-3">
        <EditForm Model="_newUser" OnValidSubmit="CreateAsync" class="grid grid-cols-1 gap-3 lg:grid-cols-2">
            <DataAnnotationsValidator />
            <div>
                <label class="field-label">E-posta</label>
                <InputText class="input" @bind-Value="_newUser.Email" />
                <ValidationMessage For="() => _newUser.Email" />
            </div>
            <div>
                <label class="field-label">Ad Soyad</label>
                <InputText class="input" @bind-Value="_newUser.FullName" />
                <ValidationMessage For="() => _newUser.FullName" />
            </div>
            <div>
                <label class="field-label">Şifre</label>
                <InputText class="input" type="password" @bind-Value="_newUser.Password" />
                <ValidationMessage For="() => _newUser.Password" />
            </div>
            <div>
                <label class="field-label">Roller</label>
                <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                    @foreach (var role in AllRoles)
                    {
                        <label class="inline-flex min-h-10 items-center gap-2 rounded-lg border border-border px-3 text-sm">
                            <input type="checkbox" class="size-4" checked="@_newUser.Roles.Contains(role)" @onchange="e => ToggleRole(_newUser.Roles, role, e.Value)" />
                            @RoleLabel(role)
                        </label>
                    }
                </div>
            </div>
            <div class="lg:col-span-2">
                <WpButton Type="submit" Icon="plus" CssClass="w-full sm:w-auto" Disabled="@(!CanCreateUser)" Loading="_creating">Kullanıcı Oluştur</WpButton>
            </div>
        </EditForm>
    </div>

    <WpResponsiveDataView TItem="UserDto"
                          Items="_users"
                          Loading="_loading"
                          ErrorText="@_loadError"
                          ItemKey="@(user => user.Id)"
                          EmptyTitle="Henüz kullanıcı yok"
                          EmptyText="Sistem rolleri için kullanıcı oluşturun.">
        <Columns>
            <PropertyColumn TGridItem="UserDto" TProp="string" Property="@(user => user.Email)" Title="E-posta" Sortable="true" />
            <PropertyColumn TGridItem="UserDto" TProp="string" Property="@(user => user.FullName)" Title="Ad Soyad" Sortable="true" />
            <TemplateColumn TGridItem="UserDto" Title="Roller" Context="user">@string.Join(", ", user.Roles.Select(RoleLabel))</TemplateColumn>
            <TemplateColumn TGridItem="UserDto" Title="Durum" Context="user">@StatusPill(user.IsActive)</TemplateColumn>
            <TemplateColumn TGridItem="UserDto" Title="İşlem" Align="Align.End" Context="user"><button class="entity-row-action" @onclick="() => OpenDetail(user)">Yönet</button></TemplateColumn>
        </Columns>
        <MobileTemplate Context="user">
            <article class="entity-card">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <h2 class="truncate font-semibold">@user.FullName</h2>
                        <p class="truncate text-sm text-foreground-muted">@user.Email</p>
                        <p class="mt-1 line-clamp-2 text-sm text-foreground-muted">@string.Join(", ", user.Roles.Select(RoleLabel))</p>
                    </div>
                    @StatusPill(user.IsActive)
                </div>
                <button class="btn-secondary mt-3 w-full" @onclick="() => OpenDetail(user)">Yönet</button>
            </article>
        </MobileTemplate>
    </WpResponsiveDataView>
</section>

<DetailPanel Show="_selectedUser is not null"
             Title="@(_selectedUser?.FullName ?? "")"
             Subtitle="@(_selectedUser?.Email ?? "Kullanıcı")"
             OnClose="CloseDetail">
    @if (_selectedUser is not null)
    {
        <div class="space-y-4">
            <div class="space-y-3 rounded-lg border border-border bg-surface-muted p-3">
                <h3 class="text-sm font-semibold">Roller</h3>
                <div class="grid grid-cols-1 gap-2">
                    @foreach (var role in AllRoles)
                    {
                        <label class="inline-flex min-h-10 items-center gap-2 rounded-lg border border-border bg-surface-raised px-3 text-sm">
                            <input type="checkbox" class="size-4" checked="@_editRoles.Contains(role)" @onchange="e => ToggleRole(_editRoles, role, e.Value)" />
                            @RoleLabel(role)
                        </label>
                    }
                </div>
                <button class="btn-primary w-full" disabled="@(_editRoles.Count == 0)" @onclick="ConfirmUpdateRolesAsync">
                    <Icon Name="check" CssClass="h-4 w-4" />Rolleri Kaydet
                </button>
            </div>

            <div class="space-y-3 rounded-lg border border-border bg-surface-muted p-3">
                <h3 class="text-sm font-semibold">Şifre sıfırla</h3>
                <input class="input" type="password" placeholder="Yeni şifre" @bind="_newPassword" @bind:event="oninput" />
                <button class="btn-secondary w-full" disabled="@(!CanResetPassword)" @onclick="ConfirmResetPasswordAsync">
                    Şifreyi Sıfırla
                </button>
            </div>

            <div class="rounded-lg border border-border bg-surface-muted p-3">
                <p class="field-label">Durum</p>
                <div class="flex items-center justify-between gap-3">
                    @StatusPill(_selectedUser.IsActive)
                    <button class="@(_selectedUser.IsActive ? "btn-danger" : "btn-secondary")"
                            @onclick="() => ConfirmSetActiveAsync(_selectedUser, !_selectedUser.IsActive)">
                        @(_selectedUser.IsActive ? "Pasif Yap" : "Aktif Yap")
                    </button>
                </div>
            </div>
        </div>
    }
</DetailPanel>

@code {
    private static readonly string[] AllRoles =
    [
        "SystemAdmin", "TechnicalOfficeEngineer", "HeadOfMaster", "SiteChief", "ProjectManager"
    ];

    private List<UserDto> _users = [];
    private bool _loading = true;
    private string? _loadError;
    private bool _creating;
    private readonly NewUserModel _newUser = new();
    private UserDto? _selectedUser;
    private readonly List<string> _editRoles = [];
    private string _newPassword = "";
    private static readonly EmailAddressAttribute EmailValidator = new();

    private bool CanCreateUser =>
        !_creating &&
        EmailValidator.IsValid(_newUser.Email) &&
        !string.IsNullOrWhiteSpace(_newUser.FullName) &&
        _newUser.Password.Length >= 6 &&
        _newUser.Roles.Count > 0;

    private bool CanResetPassword => _newPassword.Length >= 6;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        var result = await UsersApi.GetUsersAsync();
        if (result.Success)
        {
            _users = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }

        _loading = false;
    }

    private static void ToggleRole(List<string> roles, string role, object? isChecked)
    {
        var check = isChecked is bool b && b;
        if (check && !roles.Contains(role)) roles.Add(role);
        else if (!check) roles.Remove(role);
    }

    private async Task CreateAsync()
    {
        if (_newUser.Roles.Count == 0)
        {
            Toast.Error("Lütfen en az bir rol seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync(
            "Kullanıcı oluştur", $"\"{_newUser.Email}\" kullanıcısını oluşturmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        var result = await UsersApi.CreateAsync(new CreateUserRequest(_newUser.Email, _newUser.Password, _newUser.FullName, _newUser.Roles));
        if (result.Success)
        {
            Toast.Success("Kullanıcı oluşturuldu.");
            _newUser.Email = "";
            _newUser.FullName = "";
            _newUser.Password = "";
            _newUser.Roles.Clear();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Kullanıcı oluşturulamadı.");
        }

        _creating = false;
    }

    private void OpenDetail(UserDto user)
    {
        _selectedUser = user;
        _editRoles.Clear();
        _editRoles.AddRange(user.Roles);
        _newPassword = "";
    }

    private void CloseDetail()
    {
        _selectedUser = null;
        _editRoles.Clear();
        _newPassword = "";
    }

    private async Task ConfirmUpdateRolesAsync()
    {
        if (_selectedUser is null) return;
        if (_editRoles.Count == 0)
        {
            Toast.Error("Lütfen en az bir rol seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("Rolleri güncelle", "Bu kullanıcının rollerini güncellemek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await UsersApi.UpdateRolesAsync(_selectedUser.Id, new UpdateUserRolesRequest(_editRoles.ToList()));
        if (result.Success)
        {
            Toast.Success("Roller güncellendi.");
            CloseDetail();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Roller güncellenemedi.");
        }
    }

    private async Task ConfirmSetActiveAsync(UserDto user, bool isActive)
    {
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            $"Kullanıcıyı {action} yap", $"\"{user.FullName}\" kullanıcısını {action} yapmak istediğinize emin misiniz?", danger: !isActive);
        if (!confirmed) return;

        var result = await UsersApi.SetActiveAsync(user.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"Kullanıcı {action} yapıldı.");
            CloseDetail();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }

    private async Task ConfirmResetPasswordAsync()
    {
        if (_selectedUser is null) return;
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 6)
        {
            Toast.Error("Şifre en az 6 karakter olmalı.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync(
            "Şifreyi sıfırla", "Bu kullanıcının şifresini sıfırlamak istediğinize emin misiniz?", danger: true);
        if (!confirmed) return;

        var result = await UsersApi.ResetPasswordAsync(_selectedUser.Id, new ResetPasswordRequest(_newPassword));
        if (result.Success)
        {
            Toast.Success("Şifre sıfırlandı.");
            _newPassword = "";
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Şifre sıfırlanamadı.");
        }
    }

    private static RenderFragment StatusPill(bool isActive) =>
        @<WpBadge Tone="@(isActive ? WpTone.Success : WpTone.Danger)">@(isActive ? "Aktif" : "Pasif")</WpBadge>;

    private static string RoleLabel(string role) => role switch
    {
        "SystemAdmin" => "Sistem Admin",
        "TechnicalOfficeEngineer" => "Teknik Ofis",
        "HeadOfMaster" => "Ustabaşı",
        "SiteChief" => "Şantiye Şefi",
        "ProjectManager" => "Proje Müdürü",
        _ => role
    };

    private class NewUserModel
    {
        [Required, EmailAddress] public string Email { get; set; } = "";
        [Required] public string FullName { get; set; } = "";
        [Required, MinLength(6)] public string Password { get; set; } = "";
        public List<string> Roles { get; } = [];
    }
}
