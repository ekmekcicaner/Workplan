@page "/user-management"
@attribute [Authorize(Roles = "SystemAdmin")]
@inject UsersApiService UsersApi
@inject ConfirmService Confirm
@inject ToastService Toast

<h1 class="mb-4 text-2xl font-semibold">Kullanıcı Yönetimi</h1>

<div class="card mb-6">
    <h2 class="mb-1 font-semibold">Yeni kullanıcı oluştur</h2>
    <AccessNote Roles="SystemAdmin" />
    <EditForm Model="_newUser" OnValidSubmit="CreateAsync" class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <DataAnnotationsValidator />
        <div>
            <label class="field-label">E-posta</label>
            <input class="input" @bind="_newUser.Email" @bind:event="oninput" />
        </div>
        <div>
            <label class="field-label">Ad Soyad</label>
            <input class="input" @bind="_newUser.FullName" @bind:event="oninput" />
        </div>
        <div>
            <label class="field-label">Şifre</label>
            <input class="input" type="password" @bind="_newUser.Password" @bind:event="oninput" />
        </div>
        <div>
            <label class="field-label">Roller</label>
            <div class="flex flex-wrap gap-2 pt-1">
                @foreach (var role in AllRoles)
                {
                    <label class="flex items-center gap-1 text-xs">
                        <input type="checkbox" checked="@_newUser.Roles.Contains(role)" @onchange="e => ToggleRole(_newUser.Roles, role, e.Value)" />
                        @role
                    </label>
                }
            </div>
        </div>
        <div class="flex items-end lg:col-span-4">
            <button class="btn-primary" type="submit" disabled="@(!CanCreateUser)">Oluştur</button>
        </div>
    </EditForm>
</div>

<DataTable TItem="UserDto" Items="_users" Loading="_loading" LoadError="@_loadError" EmptyText="Henüz kullanıcı yok.">
    <HeaderRow>
        <th>E-posta</th>
        <th>Ad Soyad</th>
        <th>Roller</th>
        <th>Durum</th>
        <th></th>
    </HeaderRow>
    <RowTemplate Context="user">
        <td data-label="E-posta">@user.Email</td>
        <td data-label="Ad Soyad">@user.FullName</td>
        <td data-label="Roller">
            @if (_editingRolesId == user.Id)
            {
                <div class="flex flex-wrap gap-2">
                    @foreach (var role in AllRoles)
                    {
                        <label class="flex items-center gap-1 text-xs">
                            <input type="checkbox" checked="@_editRoles.Contains(role)" @onchange="e => ToggleRole(_editRoles, role, e.Value)" />
                            @role
                        </label>
                    }
                </div>
            }
            else
            {
                @string.Join(", ", user.Roles)
            }
        </td>
        <td data-label="Durum">
            <span class="badge @(user.IsActive ? "" : "!bg-red-100 !text-red-700 dark:!bg-red-900/40 dark:!text-red-300")">
                @(user.IsActive ? "Aktif" : "Pasif")
            </span>
        </td>
        <td data-label="">
            <div class="flex flex-wrap items-center gap-2">
                @if (_editingRolesId == user.Id)
                {
                    <button class="btn-primary" disabled="@(_editRoles.Count == 0)" @onclick="() => ConfirmUpdateRolesAsync(user.Id)">Kaydet</button>
                    <button class="btn-secondary" @onclick="() => _editingRolesId = null">Vazgeç</button>
                }
                else
                {
                    <button class="btn-secondary" @onclick="() => StartEditRoles(user)">Rolleri Düzenle</button>
                }

                @if (user.IsActive)
                {
                    <button class="btn-danger" @onclick="() => ConfirmSetActiveAsync(user, false)">Pasif Yap</button>
                }
                else
                {
                    <button class="btn-secondary" @onclick="() => ConfirmSetActiveAsync(user, true)">Aktif Yap</button>
                }

                @if (_resettingPasswordId == user.Id)
                {
                    <input class="input w-40" type="password" placeholder="Yeni şifre" @bind="_newPassword" @bind:event="oninput" />
                    <button class="btn-primary" disabled="@(!CanResetPassword)" @onclick="() => ConfirmResetPasswordAsync(user.Id)">Kaydet</button>
                    <button class="btn-secondary" @onclick="() => _resettingPasswordId = null">Vazgeç</button>
                }
                else
                {
                    <button class="btn-secondary" @onclick="() => StartResetPassword(user.Id)">Şifre Sıfırla</button>
                }
            </div>
        </td>
    </RowTemplate>
</DataTable>

@code {
    private static readonly string[] AllRoles =
    [
        "SystemAdmin", "TechnicalOfficeEngineer", "HeadOfMaster", "SiteChief", "ProjectManager"
    ];

    private List<UserDto> _users = [];
    private bool _loading = true;
    private string? _loadError;
    private bool _creating;
    private readonly NewUserModel _newUser = new();

    private Guid? _editingRolesId;
    private readonly List<string> _editRoles = [];

    private Guid? _resettingPasswordId;
    private string _newPassword = "";

    private static readonly EmailAddressAttribute EmailValidator = new();

    private bool CanCreateUser =>
        !_creating &&
        EmailValidator.IsValid(_newUser.Email) &&
        !string.IsNullOrWhiteSpace(_newUser.FullName) &&
        _newUser.Password.Length >= 6 &&
        _newUser.Roles.Count > 0;

    private bool CanResetPassword => _newPassword.Length >= 6;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        var result = await UsersApi.GetUsersAsync();
        if (result.Success)
        {
            _users = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }
        _loading = false;
    }

    private static void ToggleRole(List<string> roles, string role, object? isChecked)
    {
        var check = isChecked is bool b && b;
        if (check && !roles.Contains(role)) roles.Add(role);
        else if (!check) roles.Remove(role);
    }

    private async Task CreateAsync()
    {
        if (_newUser.Roles.Count == 0)
        {
            Toast.Error("Lütfen en az bir rol seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync(
            "Kullanıcı oluştur", $"\"{_newUser.Email}\" kullanıcısını oluşturmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        var result = await UsersApi.CreateAsync(new CreateUserRequest(_newUser.Email, _newUser.Password, _newUser.FullName, _newUser.Roles));
        if (result.Success)
        {
            Toast.Success("Kullanıcı oluşturuldu.");
            _newUser.Email = "";
            _newUser.FullName = "";
            _newUser.Password = "";
            _newUser.Roles.Clear();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Kullanıcı oluşturulamadı.");
        }

        _creating = false;
    }

    private void StartEditRoles(UserDto user)
    {
        _editingRolesId = user.Id;
        _editRoles.Clear();
        _editRoles.AddRange(user.Roles);
    }

    private async Task ConfirmUpdateRolesAsync(Guid userId)
    {
        if (_editRoles.Count == 0)
        {
            Toast.Error("Lütfen en az bir rol seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("Rolleri güncelle", "Bu kullanıcının rollerini güncellemek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await UsersApi.UpdateRolesAsync(userId, new UpdateUserRolesRequest(_editRoles.ToList()));
        if (result.Success)
        {
            Toast.Success("Roller güncellendi.");
            _editingRolesId = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Roller güncellenemedi.");
        }
    }

    private async Task ConfirmSetActiveAsync(UserDto user, bool isActive)
    {
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            $"Kullanıcıyı {action} yap", $"\"{user.FullName}\" kullanıcısını {action} yapmak istediğinize emin misiniz?", danger: !isActive);
        if (!confirmed) return;

        var result = await UsersApi.SetActiveAsync(user.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"Kullanıcı {action} yapıldı.");
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }

    private void StartResetPassword(Guid userId)
    {
        _resettingPasswordId = userId;
        _newPassword = "";
    }

    private async Task ConfirmResetPasswordAsync(Guid userId)
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 6)
        {
            Toast.Error("Şifre en az 6 karakter olmalı.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync(
            "Şifreyi sıfırla", "Bu kullanıcının şifresini sıfırlamak istediğinize emin misiniz?", danger: true);
        if (!confirmed) return;

        var result = await UsersApi.ResetPasswordAsync(userId, new ResetPasswordRequest(_newPassword));
        if (result.Success)
        {
            Toast.Success("Şifre sıfırlandı.");
            _resettingPasswordId = null;
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Şifre sıfırlanamadı.");
        }
    }

    private class NewUserModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string FullName { get; set; } = "";

        [Required, MinLength(6)]
        public string Password { get; set; } = "";

        public List<string> Roles { get; } = [];
    }
}
