@page "/"
@attribute [Authorize]
@inject DailyPlansApiService DailyPlansApi
@inject NotificationsApiService NotificationsApi
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Workplan</PageTitle>

<section class="space-y-4">
    <PageHeader Title="Ana Sayfa"
                Subtitle="Rolüne göre günlük operasyon özeti, bekleyen işler ve hızlı geçişler." />

    <div class="grid grid-cols-1 gap-3 xl:grid-cols-2">
        <NotificationList Items="_notifications" Loading="_notificationsLoading" LoadError="@_notificationsLoadError" />

        <AuthorizeView Roles="HeadOfMaster" Context="homContext">
            <Authorized>
                <TodayWorkSummary Items="_myWork" Loading="_myWorkLoading" LoadError="@_myWorkLoadError" />
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="SiteChief,ProjectManager" Context="approvalContext">
            <Authorized>
                <ApprovalQueuePreview Items="_approvalQueue" Loading="_approvalQueueLoading" LoadError="@_approvalQueueLoadError" />
            </Authorized>
        </AuthorizeView>
    </div>

    <QuickActions />
</section>

@code {
    private List<NotificationDto> _notifications = [];
    private bool _notificationsLoading = true;
    private string? _notificationsLoadError;

    private List<DailyPlanListItemDto> _myWork = [];
    private bool _myWorkLoading;
    private string? _myWorkLoadError;

    private List<DailyPlanListItemDto> _approvalQueue = [];
    private bool _approvalQueueLoading;
    private string? _approvalQueueLoadError;

    protected override async Task OnInitializedAsync()
    {
        var notificationsTask = LoadNotificationsAsync();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        Task myWorkTask = Task.CompletedTask;
        if (authState.User.IsInRole("HeadOfMaster"))
        {
            myWorkTask = LoadMyWorkAsync();
        }

        Task approvalTask = Task.CompletedTask;
        if (authState.User.IsInRole("SiteChief") || authState.User.IsInRole("ProjectManager"))
        {
            approvalTask = LoadApprovalQueueAsync();
        }

        await Task.WhenAll(notificationsTask, myWorkTask, approvalTask);
    }

    private async Task LoadNotificationsAsync()
    {
        _notificationsLoading = true;
        var result = await NotificationsApi.GetUnreadAsync();
        if (result.Success)
        {
            _notifications = result.Data ?? [];
        }
        else
        {
            _notificationsLoadError = result.ErrorMessage;
        }
        _notificationsLoading = false;
    }

    private async Task LoadMyWorkAsync()
    {
        _myWorkLoading = true;
        var result = await DailyPlansApi.GetMyWorkAsync();
        if (result.Success)
        {
            _myWork = result.Data ?? [];
        }
        else
        {
            _myWorkLoadError = result.ErrorMessage;
        }
        _myWorkLoading = false;
    }

    private async Task LoadApprovalQueueAsync()
    {
        _approvalQueueLoading = true;
        var result = await DailyPlansApi.GetApprovalQueueAsync();
        if (result.Success)
        {
            _approvalQueue = result.Data ?? [];
        }
        else
        {
            _approvalQueueLoadError = result.ErrorMessage;
        }
        _approvalQueueLoading = false;
    }
}
