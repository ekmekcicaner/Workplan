@page "/projects/{ProjectId:guid}/regions/{CrewRegionId:guid}/locations"
@attribute [Authorize]
@inject LocationsApiService LocationsApi
@inject UsersApiService UsersApi
@inject ConfirmService Confirm
@inject ToastService Toast

<p class="mb-2"><a class="text-sm text-slate-500 hover:underline dark:text-slate-400" href="@($"projects/{ProjectId}/regions")">&larr; Saha bölgeleri</a></p>
<h1 class="mb-4 text-2xl font-semibold">Lokasyonlar</h1>

<AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="formAuth">
    <Authorized>
        <div class="card mb-6">
            <h2 class="mb-1 font-semibold">Yeni lokasyon oluştur</h2>
            <AccessNote Roles="SystemAdmin,TechnicalOfficeEngineer" />
            <EditForm Model="_newLocation" OnValidSubmit="CreateAsync" class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                <DataAnnotationsValidator />
                <div>
                    <label class="field-label">İsim</label>
                    <input class="input" @bind="_newLocation.Name" @bind:event="oninput" />
                </div>
                <div>
                    <label class="field-label">Üst lokasyon (opsiyonel)</label>
                    <select class="input" @bind="_newLocation.ParentId">
                        <option value="">(yok)</option>
                        @foreach (var location in _locations)
                        {
                            <option value="@location.Id">@location.Name</option>
                        }
                    </select>
                </div>
                <div class="flex items-end">
                    <button class="btn-primary" type="submit" disabled="@(!CanCreateLocation)">Oluştur</button>
                </div>
            </EditForm>
        </div>
    </Authorized>
</AuthorizeView>

<div class="mb-3 flex items-center justify-between">
    <label class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
        <input type="checkbox" @bind="_includeInactive" @bind:after="LoadAsync" />
        Pasif lokasyonları da göster
    </label>
</div>

<DataTable TItem="LocationDto" Items="_locations" Loading="_loading" LoadError="@_loadError" EmptyText="Henüz lokasyon yok.">
    <HeaderRow>
        <th>İsim</th>
        <th>Ustabaşı</th>
        <th>Durum</th>
        <th></th>
    </HeaderRow>
    <RowTemplate Context="location">
        @if (_editingId == location.Id)
        {
            <td data-label="İsim" colspan="4">
                <div class="flex flex-wrap items-center gap-2">
                    <input class="input w-48" @bind="_editModel.Name" @bind:event="oninput" />
                    <button class="btn-primary" disabled="@(!CanUpdateLocation)" @onclick="() => ConfirmUpdateAsync(location.Id)">Kaydet</button>
                    <button class="btn-secondary" @onclick="() => _editingId = null">Vazgeç</button>
                </div>
            </td>
        }
        else
        {
            <td data-label="İsim">@location.Name</td>
            <td data-label="Ustabaşı">@(location.HeadOfMasterUserId is { } homId ? DisplayNameFor(homId) : "-")</td>
            <td data-label="Durum">
                <span class="badge @(location.IsActive ? "" : "!bg-red-100 !text-red-700 dark:!bg-red-900/40 dark:!text-red-300")">
                    @(location.IsActive ? "Aktif" : "Pasif")
                </span>
            </td>
            <td data-label="">
                <div class="flex flex-wrap items-center gap-2">
                    <a class="btn-secondary" href="@($"locations/{location.Id}/crews")">Ekipler</a>
                    <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer,SiteChief" Context="innerContext">
                        <Authorized>
                            @if (_assigningLocationId == location.Id)
                            {
                                <div class="flex flex-wrap items-center gap-2">
                                    <div class="w-full min-w-0 sm:w-56">
                                        <UserPicker Role="HeadOfMaster" @bind-Value="_assignHeadOfMasterUserId" Placeholder="Ustabaşı ara..." />
                                    </div>
                                    <button class="btn-primary" disabled="@(_assignHeadOfMasterUserId is null)" @onclick="() => ConfirmAssignAsync(location.Id)">Kaydet</button>
                                    <button class="btn-secondary" @onclick="() => _assigningLocationId = null">Vazgeç</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn-secondary" @onclick="() => StartAssign(location.Id)">Ustabaşı ata</button>
                            }
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="rowAuth">
                        <Authorized>
                            <button class="btn-secondary" @onclick="() => StartEdit(location)">Düzenle</button>
                            @if (location.IsActive)
                            {
                                <button class="btn-danger" @onclick="() => ConfirmSetActiveAsync(location, false)">Pasif Yap</button>
                            }
                            else
                            {
                                <button class="btn-secondary" @onclick="() => ConfirmSetActiveAsync(location, true)">Aktif Yap</button>
                            }
                        </Authorized>
                    </AuthorizeView>
                </div>
            </td>
        }
    </RowTemplate>
</DataTable>

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public Guid CrewRegionId { get; set; }

    private List<LocationDto> _locations = [];
    private Dictionary<Guid, string> _headOfMasterNames = new();
    private bool _loading = true;
    private string? _loadError;
    private bool _creating;
    private bool _includeInactive;
    private readonly NewLocationModel _newLocation = new();

    private Guid? _editingId;
    private readonly EditLocationModel _editModel = new();

    private Guid? _assigningLocationId;
    private Guid? _assignHeadOfMasterUserId;

    private bool CanCreateLocation =>
        !_creating && !string.IsNullOrWhiteSpace(_newLocation.Name);

    private bool CanUpdateLocation =>
        !string.IsNullOrWhiteSpace(_editModel.Name);

    protected override async Task OnInitializedAsync()
    {
        var usersResult = await UsersApi.GetUsersAsync("HeadOfMaster");
        _headOfMasterNames = (usersResult.Data ?? []).ToDictionary(u => u.Id, u => u.FullName);
        await LoadAsync();
    }

    private string DisplayNameFor(Guid userId) => _headOfMasterNames.TryGetValue(userId, out var name) ? name : userId.ToString();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        var result = await LocationsApi.GetByRegionAsync(CrewRegionId, _includeInactive);
        if (result.Success)
        {
            _locations = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }
        _loading = false;
    }

    private async Task CreateAsync()
    {
        var confirmed = await Confirm.ConfirmAsync(
            "Lokasyon oluştur", $"\"{_newLocation.Name}\" lokasyonunu oluşturmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        Guid? parentId = Guid.TryParse(_newLocation.ParentId, out var parsed) ? parsed : null;
        var result = await LocationsApi.CreateAsync(new CreateLocationRequest(ProjectId, CrewRegionId, _newLocation.Name, parentId));
        if (result.Success)
        {
            Toast.Success("Lokasyon oluşturuldu.");
            _newLocation.Name = "";
            _newLocation.ParentId = "";
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Lokasyon oluşturulamadı.");
        }

        _creating = false;
    }

    private void StartEdit(LocationDto location)
    {
        _editingId = location.Id;
        _editModel.Name = location.Name;
    }

    private async Task ConfirmUpdateAsync(Guid id)
    {
        var confirmed = await Confirm.ConfirmAsync("Lokasyonu güncelle", "Değişiklikleri kaydetmek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await LocationsApi.UpdateAsync(id, new UpdateLocationRequest(_editModel.Name));
        if (result.Success)
        {
            Toast.Success("Lokasyon güncellendi.");
            _editingId = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Lokasyon güncellenemedi.");
        }
    }

    private async Task ConfirmSetActiveAsync(LocationDto location, bool isActive)
    {
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            $"Lokasyonu {action} yap", $"\"{location.Name}\" lokasyonunu {action} yapmak istediğinize emin misiniz?", danger: !isActive);
        if (!confirmed) return;

        var result = await LocationsApi.SetActiveAsync(location.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"Lokasyon {action} yapıldı.");
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }

    private void StartAssign(Guid locationId)
    {
        _assigningLocationId = locationId;
        _assignHeadOfMasterUserId = null;
    }

    private async Task ConfirmAssignAsync(Guid locationId)
    {
        if (_assignHeadOfMasterUserId is not { } userId)
        {
            Toast.Error("Lütfen listeden bir ustabaşı seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("Ustabaşı ata", "Bu lokasyona ustabaşı atamak istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await LocationsApi.AssignHeadOfMasterAsync(locationId, new AssignHeadOfMasterRequest(userId));
        if (result.Success)
        {
            Toast.Success("Ustabaşı atandı.");
            _assigningLocationId = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Atama başarısız oldu.");
        }
    }

    private class NewLocationModel
    {
        [Required, MaxLength(100)]
        public string Name { get; set; } = "";

        public string ParentId { get; set; } = "";
    }

    private class EditLocationModel
    {
        [Required, MaxLength(100)]
        public string Name { get; set; } = "";
    }
}
