@page "/daily-plans/new"
@attribute [Authorize(Roles = "SystemAdmin,TechnicalOfficeEngineer")]
@inject DailyPlansApiService DailyPlansApi
@inject ProjectsApiService ProjectsApi
@inject CrewRegionsApiService CrewRegionsApi
@inject LocationsApiService LocationsApi
@inject ConfirmService Confirm
@inject ToastService Toast

<h1 class="mb-4 text-2xl font-semibold">Günlük Plan Oluştur</h1>

<div class="card mb-6">
    <h2 class="mb-1 font-semibold">Yeni günlük plan oluştur</h2>
    <AccessNote Roles="SystemAdmin,TechnicalOfficeEngineer" />
    <EditForm Model="_newPlan" OnValidSubmit="CreateAsync" class="grid grid-cols-1 gap-3 sm:grid-cols-4">
        <DataAnnotationsValidator />
        <div>
            <label class="field-label">Proje</label>
            <select class="input" @bind="_newPlan.ProjectId" @bind:after="OnProjectChangedAsync">
                <option value="">Seçiniz</option>
                @foreach (var project in _projects)
                {
                    <option value="@project.Id">@project.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="field-label">Saha bölgesi</label>
            <select class="input" @bind="_newPlan.CrewRegionId" @bind:after="OnRegionChangedAsync">
                <option value="">Seçiniz</option>
                @foreach (var region in _regions)
                {
                    <option value="@region.Id">@region.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="field-label">Lokasyon</label>
            <select class="input" @bind="_newPlan.LocationId">
                <option value="">Seçiniz</option>
                @foreach (var location in _locations)
                {
                    <option value="@location.Id">@location.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="field-label">Ustabaşı</label>
            <UserPicker Role="HeadOfMaster" @bind-Value="_newPlan.AssignedHoMId" Placeholder="Ustabaşı ara..." />
        </div>
        <WorkItemTypeSelector @bind-Value="_newPlan.WorkItemTypeId" SelectedLeafChanged="OnSelectedLeafChanged" />
        <div>
            <label class="field-label">İş tarihi</label>
            <input class="input" type="date" @bind="_newPlan.WorkDate" />
        </div>
        <div>
            <label class="field-label">Planlanan miktar</label>
            <input class="input" type="number" step="0.01" @bind="_newPlan.PlannedQuantity" />
        </div>
        <div>
            <label class="field-label">Birim</label>
            <input class="input" value="@(_selectedLeaf is null ? "—" : WorkUnitLabel(_selectedLeaf.Unit))" disabled />
        </div>
        <div>
            <label class="field-label">Planlanan adam-gün</label>
            <input class="input" type="number" step="0.01" @bind="_newPlan.PlannedManDay" />
        </div>
        <div class="flex items-end">
            <button class="btn-primary" type="submit" disabled="@(!CanCreateDailyPlan)">Oluştur</button>
        </div>
    </EditForm>
</div>

@code {
    private List<ProjectDto> _projects = [];
    private List<CrewRegionDto> _regions = [];
    private List<LocationDto> _locations = [];
    private WorkItemTypeDto? _selectedLeaf;
    private readonly NewPlanModel _newPlan = new();
    private bool _creating;

    private bool CanCreateDailyPlan =>
        !_creating &&
        Guid.TryParse(_newPlan.ProjectId, out _) &&
        Guid.TryParse(_newPlan.CrewRegionId, out _) &&
        Guid.TryParse(_newPlan.LocationId, out _) &&
        _newPlan.AssignedHoMId is not null &&
        _newPlan.WorkItemTypeId is not null &&
        _selectedLeaf is not null &&
        _newPlan.PlannedQuantity >= 0 &&
        _newPlan.PlannedManDay >= 0;

    protected override async Task OnInitializedAsync()
    {
        var projectsResult = await ProjectsApi.GetAllAsync();
        _projects = projectsResult.Data ?? [];
    }

    private async Task OnProjectChangedAsync()
    {
        _regions = [];
        _locations = [];
        _newPlan.CrewRegionId = "";
        _newPlan.LocationId = "";

        if (Guid.TryParse(_newPlan.ProjectId, out var projectId))
        {
            var result = await CrewRegionsApi.GetByProjectAsync(projectId);
            _regions = result.Data ?? [];
        }
    }

    private async Task OnRegionChangedAsync()
    {
        _locations = [];
        _newPlan.LocationId = "";

        if (Guid.TryParse(_newPlan.CrewRegionId, out var regionId))
        {
            var result = await LocationsApi.GetByRegionAsync(regionId);
            _locations = result.Data ?? [];
        }
    }

    private void OnSelectedLeafChanged(WorkItemTypeDto? leaf) => _selectedLeaf = leaf;

    private async Task CreateAsync()
    {
        if (!Guid.TryParse(_newPlan.ProjectId, out var projectId) ||
            !Guid.TryParse(_newPlan.CrewRegionId, out var crewRegionId) ||
            !Guid.TryParse(_newPlan.LocationId, out var locationId) ||
            _newPlan.WorkItemTypeId is not { } workItemTypeId ||
            _newPlan.AssignedHoMId is not { } assignedHoMId)
        {
            Toast.Error("Lütfen proje, saha bölgesi, lokasyon, ustabaşı ve iş kalemi tipini (Tip → Alt Tip → Alt-Alt Tip) seçin.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("Günlük plan oluştur", "Bu günlük plan taslağını oluşturmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        var request = new CreateDailyPlanRequest(
            projectId, crewRegionId, locationId, workItemTypeId,
            _newPlan.WorkDate, _newPlan.PlannedQuantity, _newPlan.PlannedManDay,
            assignedHoMId);

        var result = await DailyPlansApi.CreateAsync(request);
        if (result.Success)
        {
            Toast.Success("Günlük plan oluşturuldu.");
            _newPlan.ProjectId = "";
            _newPlan.CrewRegionId = "";
            _newPlan.LocationId = "";
            _newPlan.AssignedHoMId = null;
            _newPlan.WorkItemTypeId = null;
            _newPlan.PlannedQuantity = 0;
            _newPlan.PlannedManDay = 0;
            _selectedLeaf = null;
            _regions = [];
            _locations = [];
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Günlük plan oluşturulamadı.");
        }

        _creating = false;
    }

    private static string WorkUnitLabel(WorkUnit unit) => unit switch
    {
        WorkUnit.Ton => "ton",
        WorkUnit.M3 => "m³",
        WorkUnit.M2 => "m²",
        _ => "—"
    };

    private class NewPlanModel
    {
        [Required]
        public string ProjectId { get; set; } = "";

        [Required]
        public string CrewRegionId { get; set; } = "";

        [Required]
        public string LocationId { get; set; } = "";

        [Required]
        public Guid? AssignedHoMId { get; set; }

        [Required]
        public Guid? WorkItemTypeId { get; set; }

        public DateOnly WorkDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public decimal PlannedQuantity { get; set; }
        public decimal PlannedManDay { get; set; }
    }
}
