@page "/daily-plans/new"
@attribute [Authorize(Roles = Roles.Administration)]
@inject DailyPlansApiService DailyPlansApi
@inject ProjectsApiService ProjectsApi
@inject CrewRegionsApiService CrewRegionsApi
@inject LocationsApiService LocationsApi
@inject UsersApiService UsersApi
@inject ConfirmService Confirm
@inject ToastService Toast
@inject ConnectivityService Connectivity

<PageTitle>Günlük Plan Oluştur | Workplan</PageTitle>

<section class="space-y-4">
    <PageHeader Title="Günlük Plan Oluştur"
                Subtitle="@($"T-1 planlama: kapsam, SSToW, metrikler ve {Roles.DisplayName(Roles.HeadOfMaster)} ataması.")" />

    <PlanScopeSelector Projects="_projects"
                       Regions="_regions"
                       Locations="_locations"
                       @bind-ProjectId="_newPlan.ProjectId"
                       @bind-CrewRegionId="_newPlan.CrewRegionId"
                       @bind-LocationId="_newPlan.LocationId"
                       OnProjectChanged="OnProjectChangedAsync"
                       OnRegionChanged="OnRegionChangedAsync"
                       OnLocationChanged="OnLocationChanged" />

    <WorkItemCascadeSelector @bind-Value="_newPlan.WorkItemTypeId"
                             SelectedLeafChanged="OnSelectedLeafChanged" />

    <PlannedMetricsForm @bind-WorkDate="_newPlan.WorkDate"
                        @bind-PlannedQuantity="_newPlan.PlannedQuantity"
                        @bind-PlannedManDay="_newPlan.PlannedManDay"
                        Unit="@(_selectedLeaf?.Unit ?? WorkUnit.None)" />

    <div class="card">
        <h2 class="mb-3 text-base font-semibold">Saha Sorumlusu</h2>
        <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
            <div>
                <p class="field-label">Proje Yöneticisi</p>
                @if (SelectedProject is null)
                {
                    <p class="text-sm text-foreground-muted">-</p>
                }
                else if (SelectedProject.PmUserId is { } pmId)
                {
                    <p class="text-sm font-medium">@DisplayUser(pmId)</p>
                }
                else
                {
                    <p class="text-sm text-warning">Bu projeye proje yöneticisi atanmamış.</p>
                }
            </div>
            <div>
                <p class="field-label">@Roles.DisplayName(Roles.HeadOfMaster)</p>
                @if (SelectedLocation is null)
                {
                    <p class="text-sm text-foreground-muted">-</p>
                }
                else if (SelectedLocation.HeadOfMasterUserId is { } homId)
                {
                    <p class="text-sm font-medium">@DisplayUser(homId)</p>
                }
                else
                {
                    <p class="text-sm text-warning">Bu lokasyona @Roles.DisplayName(Roles.HeadOfMaster) atanmamış.</p>
                }
            </div>
            <div>
                <p class="field-label">@Roles.DisplayName(Roles.SiteChief)</p>
                @if (SelectedRegion is null)
                {
                    <p class="text-sm text-foreground-muted">-</p>
                }
                else if (SelectedRegion.SiteChiefUserId is { } siteChiefId)
                {
                    <p class="text-sm font-medium">@DisplayUser(siteChiefId)</p>
                }
                else
                {
                    <p class="text-sm text-warning">Bu saha bölgesine @Roles.DisplayName(Roles.SiteChief) atanmamış.</p>
                }
            </div>
        </div>
    </div>

    <StickyActionBar StatusText="@CreateStatusText">
        <button class="btn-primary w-full sm:w-auto" type="button" disabled="@(!CanCreateDailyPlan || !Connectivity.IsOnline)" @onclick="CreateAsync">
            @(_creating ? "Oluşturuluyor..." : "Oluştur")
        </button>
    </StickyActionBar>
</section>

@code {
    private List<ProjectDto> _projects = [];
    private List<CrewRegionDto> _regions = [];
    private List<LocationDto> _locations = [];
    private Dictionary<Guid, string> _userNames = new();
    private WorkItemTypeDto? _selectedLeaf;
    private readonly NewPlanModel _newPlan = new();
    private bool _creating;

    private bool CanCreateDailyPlan =>
        !_creating &&
        Guid.TryParse(_newPlan.ProjectId, out _) &&
        Guid.TryParse(_newPlan.CrewRegionId, out _) &&
        Guid.TryParse(_newPlan.LocationId, out _) &&
        _newPlan.AssignedHoMId is not null &&
        _newPlan.WorkItemTypeId is not null &&
        _selectedLeaf is not null &&
        _newPlan.PlannedQuantity is >= 0 &&
        _newPlan.PlannedManDay is >= 0;

    private LocationDto? SelectedLocation =>
        Guid.TryParse(_newPlan.LocationId, out var locationId)
            ? _locations.FirstOrDefault(location => location.Id == locationId)
            : null;

    private ProjectDto? SelectedProject =>
        Guid.TryParse(_newPlan.ProjectId, out var projectId)
            ? _projects.FirstOrDefault(project => project.Id == projectId)
            : null;

    private CrewRegionDto? SelectedRegion =>
        Guid.TryParse(_newPlan.CrewRegionId, out var regionId)
            ? _regions.FirstOrDefault(region => region.Id == regionId)
            : null;

    private string CreateStatusText =>
        !Connectivity.IsOnline ? "Bağlantı yokken plan oluşturulamaz." :
        !CanCreateDailyPlan ? "Zorunlu seçimleri ve planlanan metrikleri tamamlayın." :
        "Plan oluşturulmaya hazır.";

    protected override async Task OnInitializedAsync()
    {
        await Connectivity.InitializeAsync();
        var projectsResult = await ProjectsApi.GetAllAsync();
        _projects = projectsResult.Data ?? [];
        var usersResult = await UsersApi.GetUsersAsync();
        _userNames = (usersResult.Data ?? []).ToDictionary(user => user.Id, user => user.FullName);
    }

    private async Task OnProjectChangedAsync()
    {
        _regions = [];
        _locations = [];
        _newPlan.CrewRegionId = "";
        _newPlan.LocationId = "";
        _newPlan.AssignedHoMId = null;

        if (Guid.TryParse(_newPlan.ProjectId, out var projectId))
        {
            var result = await CrewRegionsApi.GetByProjectAsync(projectId);
            _regions = result.Data ?? [];
        }
    }

    private async Task OnRegionChangedAsync()
    {
        _locations = [];
        _newPlan.LocationId = "";
        _newPlan.AssignedHoMId = null;

        if (Guid.TryParse(_newPlan.CrewRegionId, out var regionId))
        {
            var result = await LocationsApi.GetByRegionAsync(regionId);
            _locations = result.Data ?? [];
        }
    }

    private void OnLocationChanged() =>
        _newPlan.AssignedHoMId = SelectedLocation?.HeadOfMasterUserId;

    private void OnSelectedLeafChanged(WorkItemTypeDto? leaf) => _selectedLeaf = leaf;

    private async Task CreateAsync()
    {
        if (!Connectivity.IsOnline)
        {
            Toast.Error("Bağlantı yokken plan oluşturulamaz.");
            return;
        }

        if (!Guid.TryParse(_newPlan.ProjectId, out var projectId) ||
            !Guid.TryParse(_newPlan.CrewRegionId, out var crewRegionId) ||
            !Guid.TryParse(_newPlan.LocationId, out var locationId) ||
            _newPlan.WorkItemTypeId is not { } workItemTypeId ||
            _newPlan.AssignedHoMId is not { } assignedHoMId ||
            _newPlan.PlannedQuantity is not { } plannedQuantity ||
            _newPlan.PlannedManDay is not { } plannedManDay)
        {
            Toast.Error($"Lütfen proje, bölge, lokasyon, SSToW, {Roles.DisplayName(Roles.HeadOfMaster)} ve planlanan metrikleri tamamlayın.");
            return;
        }

        var confirmed = await Confirm.ConfirmAsync("Günlük plan oluştur", $"Bu günlük planı {Roles.DisplayName(Roles.HeadOfMaster)}'na atamak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        var request = new CreateDailyPlanRequest(
            projectId,
            crewRegionId,
            locationId,
            workItemTypeId,
            _newPlan.WorkDate,
            plannedQuantity,
            plannedManDay,
            assignedHoMId);

        var result = await DailyPlansApi.CreateAsync(request);
        if (result.Success)
        {
            Toast.Success($"Günlük plan oluşturuldu ve {Roles.DisplayName(Roles.HeadOfMaster)}'na bildirildi.");
            ResetForm();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Günlük plan oluşturulamadı.");
        }

        _creating = false;
    }

    private void ResetForm()
    {
        _newPlan.ProjectId = "";
        _newPlan.CrewRegionId = "";
        _newPlan.LocationId = "";
        _newPlan.AssignedHoMId = null;
        _newPlan.WorkItemTypeId = null;
        _newPlan.PlannedQuantity = null;
        _newPlan.PlannedManDay = null;
        _selectedLeaf = null;
        _regions = [];
        _locations = [];
    }

    private string DisplayUser(Guid userId) =>
        _userNames.TryGetValue(userId, out var name) ? name : userId.ToString();

    private class NewPlanModel
    {
        public string ProjectId { get; set; } = "";
        public string CrewRegionId { get; set; } = "";
        public string LocationId { get; set; } = "";
        public Guid? AssignedHoMId { get; set; }
        public Guid? WorkItemTypeId { get; set; }
        public DateOnly WorkDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public decimal? PlannedQuantity { get; set; }
        public decimal? PlannedManDay { get; set; }
    }
}
