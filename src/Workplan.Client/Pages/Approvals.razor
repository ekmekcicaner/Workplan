@page "/approvals"
@attribute [Authorize(Roles = "SiteChief,ProjectManager")]
@inject DailyPlansApiService DailyPlansApi

<PageTitle>Bekleyen Onaylar | Workplan  </PageTitle>
<section class="space-y-4">
    <PageHeader Title="Beklenen Onaylar"
                Subtitle="Sadece kendi onay aşamandaki işler listelenir. Plan ve gerçekleşen değerleri inceleyip aksiyon ver.">
        <Metadata>
            <span class="badge">@_plans.Count kayıt</span>
        </Metadata>
    </PageHeader>

    <LoadingBlock Loading="_loading" ErrorText="@_loadError" />

    @if (!_loading && string.IsNullOrWhiteSpace(_loadError))
    {
        @if (_plans.Count == 0)
        {
            <EmptyState Icon="check-circle" Title="Onay bekleyen iş yok" Text="Yeni gönderimler geldiğinde burada görünür." />
        }
        else
        {
            <div class="grid grid-cols-1 gap-3 lg:grid-cols-2">
                @foreach (var plan in _plans)
                {
                    <ApprovalQueueCard @key="plan.Id" Plan="plan" />
                }
            </div>
        }
    }
</section>

@code {
    private List<DailyPlanListItemDto> _plans = [];
    private bool _loading = true;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        var result = await DailyPlansApi.GetApprovalQueueAsync();
        if (result.Success)
        {
            _plans = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }

        _loading = false;
    }
}
