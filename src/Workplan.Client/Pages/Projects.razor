@page "/projects"
@attribute [Authorize]
@inject ProjectsApiService ProjectsApi
@inject UsersApiService UsersApi
@inject ConfirmService Confirm
@inject ToastService Toast

<PageTitle>Projeler | Workplan</PageTitle>

<section class="space-y-4">
    <PageHeader Title="Projeler"
                Subtitle="Proje master verisini, proje yöneticisini ve saha bölgesi geçişlerini yönet.">
        <Actions>
            <button class="btn-secondary" @onclick="LoadAsync">
                <Icon Name="refresh" CssClass="h-4 w-4" />Yenile
            </button>
        </Actions>
    </PageHeader>

    <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="formAuth">
        <Authorized>
            <div class="surface-panel p-3">
                <EditForm Model="_newProject" OnValidSubmit="CreateAsync" class="grid grid-cols-1 gap-3 lg:grid-cols-[8rem_1fr_18rem_auto] lg:items-end">
                    <DataAnnotationsValidator />
                    <div>
                        <label class="field-label">Kod</label>
                        <InputText class="input" @bind-Value="_newProject.Code" />
                        <ValidationMessage For="() => _newProject.Code" />
                    </div>
                    <div>
                        <label class="field-label">İsim</label>
                        <InputText class="input" @bind-Value="_newProject.Name" />
                        <ValidationMessage For="() => _newProject.Name" />
                    </div>
                    <div>
                        <label class="field-label">Proje Yöneticisi</label>
                        <UserPicker Role="ProjectManager" @bind-Value="_newProject.PmUserId" Placeholder="PM ara..." />
                    </div>
                    <WpButton Type="submit" Icon="plus" Disabled="@(!CanCreateProject)" Loading="_creating">Oluştur</WpButton>
                </EditForm>
            </div>
        </Authorized>
    </AuthorizeView>

    <WpEntityToolbar Label="Pasif projeleri de göster" Count="_projects.Count" @bind-IncludeInactive="_includeInactive" OnChanged="LoadAsync" />

    <WpResponsiveDataView TItem="ProjectDto"
                          Items="_projects"
                          Loading="_loading"
                          ErrorText="@_loadError"
                          ItemKey="@(project => project.Id)"
                          EmptyTitle="Henüz proje yok"
                          EmptyText="Yeni proje oluşturarak saha bölgesi ve lokasyon yapılandırmasına başlayın.">
        <Columns>
            <PropertyColumn TGridItem="ProjectDto" TProp="string" Property="@(project => project.Code)" Title="Kod" Sortable="true" />
            <PropertyColumn TGridItem="ProjectDto" TProp="string" Property="@(project => project.Name)" Title="İsim" Sortable="true" />
            <TemplateColumn TGridItem="ProjectDto" Title="Proje Yöneticisi" Context="project">@PmName(project.PmUserId)</TemplateColumn>
            <TemplateColumn TGridItem="ProjectDto" Title="Durum" Context="project">@StatusPill(project.IsActive)</TemplateColumn>
            <TemplateColumn TGridItem="ProjectDto" Title="İşlem" Align="Align.End" Context="project">
                <button class="entity-row-action" @onclick="() => OpenDetail(project)">Yönet</button>
            </TemplateColumn>
        </Columns>
        <MobileTemplate Context="project">
            <article class="entity-card">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-xs font-semibold uppercase text-foreground-muted">@project.Code</p>
                        <h2 class="truncate font-semibold">@project.Name</h2>
                        <p class="mt-1 truncate text-sm text-foreground-muted">@PmName(project.PmUserId)</p>
                    </div>
                    @StatusPill(project.IsActive)
                </div>
                <button class="btn-secondary mt-3 w-full" @onclick="() => OpenDetail(project)">Yönet</button>
            </article>
        </MobileTemplate>
    </WpResponsiveDataView>
</section>

<DetailPanel Show="_selectedProject is not null"
             Title="@(_selectedProject?.Name ?? "")"
             Subtitle="@(_selectedProject?.Code ?? "Proje")"
             OnClose="CloseDetail">
    @if (_selectedProject is not null)
    {
        <div class="space-y-4">
            <a class="btn-secondary w-full" href="@($"projects/{_selectedProject.Id}/regions")">
                <Icon Name="map-pin" CssClass="h-4 w-4" />Saha bölgeleri
            </a>

            <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="editAuth">
                <Authorized>
                    <div class="space-y-3 rounded-lg border border-border bg-surface-muted p-3">
                        <h3 class="text-sm font-semibold">Proje bilgileri</h3>
                        <div>
                            <label class="field-label">Kod</label>
                            <input class="input" @bind="_editModel.Code" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="field-label">İsim</label>
                            <input class="input" @bind="_editModel.Name" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="field-label">Proje Yöneticisi</label>
                            <UserPicker Role="ProjectManager" @bind-Value="_editModel.PmUserId" Placeholder="PM ara..." />
                        </div>
                        <button class="btn-primary w-full" disabled="@(!CanUpdateProject)" @onclick="ConfirmUpdateAsync">
                            <Icon Name="check" CssClass="h-4 w-4" />Kaydet
                        </button>
                    </div>

                    <div class="rounded-lg border border-border bg-surface-muted p-3">
                        <p class="field-label">Durum</p>
                        <div class="flex items-center justify-between gap-3">
                            @StatusPill(_selectedProject.IsActive)
                            <button class="@(_selectedProject.IsActive ? "btn-danger" : "btn-secondary")"
                                    @onclick="() => ConfirmSetActiveAsync(_selectedProject, !_selectedProject.IsActive)">
                                @(_selectedProject.IsActive ? "Pasif Yap" : "Aktif Yap")
                            </button>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    }
</DetailPanel>

@code {
    private List<ProjectDto> _projects = [];
    private List<UserDto> _projectManagers = [];
    private bool _loading = true;
    private string? _loadError;
    private bool _creating;
    private bool _includeInactive;
    private readonly NewProjectModel _newProject = new();
    private ProjectDto? _selectedProject;
    private readonly EditProjectModel _editModel = new();

    private bool CanCreateProject =>
        !_creating &&
        !string.IsNullOrWhiteSpace(_newProject.Code) &&
        !string.IsNullOrWhiteSpace(_newProject.Name);

    private bool CanUpdateProject =>
        _selectedProject is not null &&
        !string.IsNullOrWhiteSpace(_editModel.Code) &&
        !string.IsNullOrWhiteSpace(_editModel.Name);

    protected override async Task OnInitializedAsync()
    {
        var pmResult = await UsersApi.GetUsersAsync("ProjectManager");
        _projectManagers = pmResult.Data ?? [];
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        var result = await ProjectsApi.GetAllAsync(_includeInactive);
        if (result.Success)
        {
            _projects = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }
        _loading = false;
    }

    private string PmName(Guid? pmUserId)
    {
        if (pmUserId is null) return "-";
        var user = _projectManagers.FirstOrDefault(u => u.Id == pmUserId);
        return user?.FullName ?? "-";
    }

    private async Task CreateAsync()
    {
        var confirmed = await Confirm.ConfirmAsync(
            "Proje oluştur", $"\"{_newProject.Name}\" projesini oluşturmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        var result = await ProjectsApi.CreateAsync(new CreateProjectRequest(_newProject.Code, _newProject.Name, _newProject.PmUserId));
        if (result.Success)
        {
            Toast.Success("Proje oluşturuldu.");
            _newProject.Code = "";
            _newProject.Name = "";
            _newProject.PmUserId = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Proje oluşturulamadı.");
        }

        _creating = false;
    }

    private void OpenDetail(ProjectDto project)
    {
        _selectedProject = project;
        _editModel.Code = project.Code;
        _editModel.Name = project.Name;
        _editModel.PmUserId = project.PmUserId;
    }

    private void CloseDetail() => _selectedProject = null;

    private async Task ConfirmUpdateAsync()
    {
        if (_selectedProject is null) return;

        var confirmed = await Confirm.ConfirmAsync("Projeyi güncelle", "Değişiklikleri kaydetmek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await ProjectsApi.UpdateAsync(_selectedProject.Id, new UpdateProjectRequest(_editModel.Code, _editModel.Name, _editModel.PmUserId));
        if (result.Success)
        {
            Toast.Success("Proje güncellendi.");
            CloseDetail();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Proje güncellenemedi.");
        }
    }

    private async Task ConfirmSetActiveAsync(ProjectDto project, bool isActive)
    {
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            $"Projeyi {action} yap", $"\"{project.Name}\" projesini {action} yapmak istediğinize emin misiniz?", danger: !isActive);
        if (!confirmed) return;

        var result = await ProjectsApi.SetActiveAsync(project.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"Proje {action} yapıldı.");
            CloseDetail();
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }

    private static RenderFragment StatusPill(bool isActive) =>
        @<WpBadge Tone="@(isActive ? WpTone.Success : WpTone.Danger)">@(isActive ? "Aktif" : "Pasif")</WpBadge>;

    private class NewProjectModel
    {
        [Required, MaxLength(50)]
        public string Code { get; set; } = "";

        [Required, MaxLength(200)]
        public string Name { get; set; } = "";

        public Guid? PmUserId { get; set; }
    }

    private class EditProjectModel
    {
        [Required, MaxLength(50)]
        public string Code { get; set; } = "";

        [Required, MaxLength(200)]
        public string Name { get; set; } = "";

        public Guid? PmUserId { get; set; }
    }
}
