@page "/projects"
@attribute [Authorize]
@inject ProjectsApiService ProjectsApi
@inject UsersApiService UsersApi
@inject ConfirmService Confirm
@inject ToastService Toast

<h1 class="mb-4 text-2xl font-semibold">Projeler</h1>

<AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="formAuth">
    <Authorized>
        <div class="card mb-6">
            <h2 class="mb-1 font-semibold">Yeni proje oluştur</h2>
            <AccessNote Roles="SystemAdmin,TechnicalOfficeEngineer" />
            <EditForm Model="_newProject" OnValidSubmit="CreateAsync" class="grid grid-cols-1 gap-3 sm:grid-cols-4">
                <DataAnnotationsValidator />
                <div>
                    <label class="field-label">Kod</label>
                    <input class="input" @bind="_newProject.Code" @bind:event="oninput" />
                </div>
                <div>
                    <label class="field-label">İsim</label>
                    <input class="input" @bind="_newProject.Name" @bind:event="oninput" />
                </div>
                <div>
                    <label class="field-label">Proje Yöneticisi</label>
                    <UserPicker Role="ProjectManager" @bind-Value="_newProject.PmUserId" Placeholder="PM ara..." />
                </div>
                <div class="flex items-end">
                    <button class="btn-primary" type="submit" disabled="@(!CanCreateProject)">Oluştur</button>
                </div>
            </EditForm>
        </div>
    </Authorized>
</AuthorizeView>

<div class="mb-3 flex items-center justify-between">
    <label class="flex items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400">
        <input type="checkbox" @bind="_includeInactive" @bind:after="LoadAsync" />
        Pasif projeleri de göster
    </label>
</div>

<DataTable TItem="ProjectDto" Items="_projects" Loading="_loading" LoadError="@_loadError" EmptyText="Henüz proje yok.">
    <HeaderRow>
        <th>Kod</th>
        <th>İsim</th>
        <th>Proje Yöneticisi</th>
        <th>Durum</th>
        <th></th>
    </HeaderRow>
    <RowTemplate Context="project">
        @if (_editingId == project.Id)
        {
            <td data-label="Kod" colspan="5">
                <div class="flex flex-wrap items-center gap-2">
                    <input class="input w-28" @bind="_editModel.Code" @bind:event="oninput" />
                    <input class="input w-48" @bind="_editModel.Name" @bind:event="oninput" />
                    <button class="btn-primary" disabled="@(!CanUpdateProject)" @onclick="() => ConfirmUpdateAsync(project.Id)">Kaydet</button>
                    <button class="btn-secondary" @onclick="() => _editingId = null">Vazgeç</button>
                </div>
            </td>
        }
        else
        {
            <td data-label="Kod">@project.Code</td>
            <td data-label="İsim">@project.Name</td>
            <td data-label="Proje Yöneticisi">@PmName(project.PmUserId)</td>
            <td data-label="Durum">
                <span class="badge @(project.IsActive ? "" : "!bg-red-100 !text-red-700 dark:!bg-red-900/40 dark:!text-red-300")">
                    @(project.IsActive ? "Aktif" : "Pasif")
                </span>
            </td>
            <td data-label="">
                <div class="flex flex-wrap items-center gap-2">
                    <a class="btn-secondary" href="@($"projects/{project.Id}/regions")">Saha bölgeleri</a>
                    <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="rowAuth">
                        <Authorized>
                            <button class="btn-secondary" @onclick="() => StartEdit(project)">Düzenle</button>
                            @if (project.IsActive)
                            {
                                <button class="btn-danger" @onclick="() => ConfirmSetActiveAsync(project, false)">Pasif Yap</button>
                            }
                            else
                            {
                                <button class="btn-secondary" @onclick="() => ConfirmSetActiveAsync(project, true)">Aktif Yap</button>
                            }
                        </Authorized>
                    </AuthorizeView>
                </div>
            </td>
        }
    </RowTemplate>
</DataTable>

@code {
    private List<ProjectDto> _projects = [];
    private List<UserDto> _projectManagers = [];
    private bool _loading = true;
    private string? _loadError;
    private bool _creating;
    private bool _includeInactive;
    private readonly NewProjectModel _newProject = new();

    private Guid? _editingId;
    private readonly EditProjectModel _editModel = new();

    private bool CanCreateProject =>
        !_creating &&
        !string.IsNullOrWhiteSpace(_newProject.Code) &&
        !string.IsNullOrWhiteSpace(_newProject.Name);

    private bool CanUpdateProject =>
        !string.IsNullOrWhiteSpace(_editModel.Code) &&
        !string.IsNullOrWhiteSpace(_editModel.Name);

    protected override async Task OnInitializedAsync()
    {
        var pmResult = await UsersApi.GetUsersAsync("ProjectManager");
        _projectManagers = pmResult.Data ?? [];
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        var result = await ProjectsApi.GetAllAsync(_includeInactive);
        if (result.Success)
        {
            _projects = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }
        _loading = false;
    }

    private string PmName(Guid? pmUserId)
    {
        if (pmUserId is null) return "-";
        var user = _projectManagers.FirstOrDefault(u => u.Id == pmUserId);
        return user?.FullName ?? "-";
    }

    private async Task CreateAsync()
    {
        var confirmed = await Confirm.ConfirmAsync(
            "Proje oluştur", $"\"{_newProject.Name}\" projesini oluşturmak istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;

        var result = await ProjectsApi.CreateAsync(new CreateProjectRequest(_newProject.Code, _newProject.Name, _newProject.PmUserId));
        if (result.Success)
        {
            Toast.Success("Proje oluşturuldu.");
            _newProject.Code = "";
            _newProject.Name = "";
            _newProject.PmUserId = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Proje oluşturulamadı.");
        }

        _creating = false;
    }

    private void StartEdit(ProjectDto project)
    {
        _editingId = project.Id;
        _editModel.Code = project.Code;
        _editModel.Name = project.Name;
    }

    private async Task ConfirmUpdateAsync(Guid id)
    {
        var confirmed = await Confirm.ConfirmAsync("Projeyi güncelle", "Değişiklikleri kaydetmek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await ProjectsApi.UpdateAsync(id, new UpdateProjectRequest(_editModel.Code, _editModel.Name));
        if (result.Success)
        {
            Toast.Success("Proje güncellendi.");
            _editingId = null;
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "Proje güncellenemedi.");
        }
    }

    private async Task ConfirmSetActiveAsync(ProjectDto project, bool isActive)
    {
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            $"Projeyi {action} yap", $"\"{project.Name}\" projesini {action} yapmak istediğinize emin misiniz?", danger: !isActive);
        if (!confirmed) return;

        var result = await ProjectsApi.SetActiveAsync(project.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"Proje {action} yapıldı.");
            await LoadAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }

    private class NewProjectModel
    {
        [Required, MaxLength(50)]
        public string Code { get; set; } = "";

        [Required, MaxLength(200)]
        public string Name { get; set; } = "";

        public Guid? PmUserId { get; set; }
    }

    private class EditProjectModel
    {
        [Required, MaxLength(50)]
        public string Code { get; set; } = "";

        [Required, MaxLength(200)]
        public string Name { get; set; } = "";
    }
}
