@page "/my-work"
@attribute [Authorize(Roles = Roles.HeadOfMaster)]
@inject DailyPlansApiService DailyPlansApi
<PageTitle>İşlerim | Workplan</PageTitle>

<section class="space-y-4">
    <PageHeader Title="Bana Atanan İşler"
                Subtitle="Ekip tipi seç, işi başlat ve gün sonu beyanını gönder." />

    <SegmentedFilter TValue="WorkStatus?" Items="FilterItems" Value="_selectedStatus" ValueChanged="OnStatusChanged" />

    <LoadingBlock Loading="_loading" ErrorText="@_loadError" />

    @if (!_loading && string.IsNullOrWhiteSpace(_loadError))
    {
        @if (FilteredPlans.Count == 0)
        {
            <EmptyState Title="Bu filtrede iş yok" Text="Atanan işler geldiğinde burada kart olarak listelenir." />
        }
        else
        {
            <div class="grid grid-cols-1 gap-3 lg:grid-cols-2">
                @foreach (var plan in FilteredPlans)
                {
                    <DailyPlanMobileCard @key="plan.Id" Plan="plan" />
                }
            </div>
        }
    }
</section>

@code {
    private List<DailyPlanListItemDto> _plans = [];
    private bool _loading = true;
    private string? _loadError;
    private WorkStatus? _selectedStatus;

    private IReadOnlyList<SegmentedFilterItem<WorkStatus?>> FilterItems =>
    [
        new(null, "Tümü", _plans.Count),
        new(WorkStatus.Assigned, "Atandı", _plans.Count(plan => plan.Status == WorkStatus.Assigned)),
        new(WorkStatus.InProgress, "Devam Ediyor", _plans.Count(plan => plan.Status == WorkStatus.InProgress)),
        new(WorkStatus.Submitted, "Onaya Gönderildi", _plans.Count(plan => plan.Status == WorkStatus.Submitted)),
        new(WorkStatus.ApprovedBySiteChief, "Şantiye Onayı", _plans.Count(plan => plan.Status == WorkStatus.ApprovedBySiteChief)),
        new(WorkStatus.ApprovedByPM, "Tamamlandı", _plans.Count(plan => plan.Status == WorkStatus.ApprovedByPM))
    ];

    private IReadOnlyList<DailyPlanListItemDto> FilteredPlans =>
        _selectedStatus is null
            ? _plans
            : _plans.Where(plan => plan.Status == _selectedStatus).ToList();

    protected override async Task OnInitializedAsync()
    {
        var result = await DailyPlansApi.GetMyWorkAsync();
        if (result.Success)
        {
            _plans = result.Data ?? [];
        }
        else
        {
            _loadError = result.ErrorMessage;
        }

        _loading = false;
    }

    private Task OnStatusChanged(WorkStatus? status)
    {
        _selectedStatus = status;
        return Task.CompletedTask;
    }
}
