<div class="card mb-6">
    <h2 class="mb-1 font-semibold">Gün sonu ilerleme gir</h2>
    <AccessNote Roles="HeadOfMaster" />
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-4">
        <div>
            <label class="field-label">Gerçek Miktar</label>
            <input class="input" type="number" step="0.01" @bind="Model.FactQuantity" />
        </div>
        <div>
            <label class="field-label">Gerçek Adam-Gün</label>
            <input class="input" type="number" step="0.01" @bind="Model.FactManDay" />
        </div>
        <div>
            <label class="field-label">Fazla Mesai</label>
            <input class="input" type="number" step="0.01" @bind="Model.Overtime" />
        </div>
        <div>
            <label class="field-label">Yorum</label>
            <input class="input" @bind="Model.Comment" />
        </div>
    </div>
    <div class="mt-3">
        <button class="btn-primary" @onclick="OnSubmit">Kaydet ve Onaya Sun</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ProgressModel Model { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback OnSubmit { get; set; }

    public class ProgressModel
    {
        public decimal? FactQuantity { get; set; }
        public decimal? FactManDay { get; set; }
        public decimal? Overtime { get; set; }
        public string? Comment { get; set; }
    }
}
