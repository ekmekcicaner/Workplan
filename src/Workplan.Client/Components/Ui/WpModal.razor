@if (Show)
{
    <div class="modal-backdrop" @onclick="CloseFromPointerAsync">
        <section class="modal-panel" role="dialog" aria-modal="true" aria-label="@Title" @onclick:stopPropagation="true">
            <header class="mb-4 flex items-start justify-between gap-3">
                <div class="min-w-0">
                    @if (!string.IsNullOrWhiteSpace(Title))
                    {
                        <h2 class="text-lg font-bold text-foreground">@Title</h2>
                    }
                    @if (!string.IsNullOrWhiteSpace(Description))
                    {
                        <p class="mt-1 text-sm text-foreground-muted">@Description</p>
                    }
                </div>
                <WpIconButton Icon="x" Label="Kapat" OnClick="CloseFromPointerAsync" />
            </header>
            @ChildContent
        </section>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private Task CloseFromPointerAsync(MouseEventArgs _) => OnClose.InvokeAsync();
}
