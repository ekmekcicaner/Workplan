@if (Loading)
{
    <div class="flex min-h-24 w-full items-center justify-center gap-3 px-4 py-6 text-sm font-semibold text-foreground-muted" role="status">
        <span class="h-5 w-5 animate-spin rounded-full border-2 border-border-strong border-r-brand-500" aria-hidden="true"></span>
        @Text
    </div>
}
else if (!string.IsNullOrWhiteSpace(ErrorText))
{
    <div class="flex min-h-24 w-full items-center justify-center gap-2 px-4 py-6 text-center text-sm font-semibold text-danger" role="alert">
        <Icon Name="alert-triangle" CssClass="h-5 w-5 shrink-0" />
        @ErrorText
    </div>
}

@code {
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string Text { get; set; } = "Yükleniyor...";
}
