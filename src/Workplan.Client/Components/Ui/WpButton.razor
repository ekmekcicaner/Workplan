@if (!string.IsNullOrWhiteSpace(Href))
{
    <a href="@(Disabled ? null : Href)" class="@ButtonClass" aria-disabled="@Disabled" @attributes="AdditionalAttributes">
        @ButtonContent
    </a>
}
else
{
    <button type="@Type" class="@ButtonClass" disabled="@(Disabled || Loading)" @onclick="OnClick" @attributes="AdditionalAttributes">
        @ButtonContent
    </button>
}

@code {
    [Parameter] public WpButtonVariant Variant { get; set; } = WpButtonVariant.Primary;
    [Parameter] public WpSize Size { get; set; } = WpSize.Medium;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ButtonClass => string.Join(' ', new[] { VariantClass, SizeClass, CssClass }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string VariantClass => Variant switch
    {
        WpButtonVariant.Secondary => "btn-secondary",
        WpButtonVariant.Ghost => "btn-ghost",
        WpButtonVariant.Danger => "btn-danger",
        _ => "btn-primary"
    };

    private string SizeClass => Size switch
    {
        WpSize.Small => "btn-sm",
        WpSize.Large => "btn-lg",
        _ => ""
    };

    private RenderFragment ButtonContent => @<text>
        @if (Loading)
        {
            <span class="h-4 w-4 animate-spin rounded-full border-2 border-current border-r-transparent" aria-hidden="true"></span>
        }
        else if (!string.IsNullOrWhiteSpace(Icon))
        {
            <Icon Name="@Icon" CssClass="h-4 w-4" />
        }
        @ChildContent
    </text>;
}
