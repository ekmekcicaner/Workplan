<article class="card flex h-full flex-col gap-3">
    <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
            <p class="truncate text-sm font-semibold">@Plan.LocationName</p>
            <p class="truncate text-sm text-neutral-500 dark:text-neutral-400">@Plan.WorkItemTypeName</p>
        </div>
        <StatusBadge Status="Plan.Status" />
    </div>

    <dl class="grid grid-cols-2 gap-3 text-sm">
        <div>
            <dt class="field-label">Tarih</dt>
            <dd>@Plan.WorkDate.ToString("dd.MM.yyyy")</dd>
        </div>
        <div>
            <dt class="field-label">Bölge</dt>
            <dd class="truncate">@Plan.CrewRegionName</dd>
        </div>
        <div>
            <dt class="field-label">Plan</dt>
            <dd>@NumberDisplay.Format(Plan.PlannedQuantity) @UnitLabel(Plan.Unit)</dd>
        </div>
        <div>
            <dt class="field-label">Adam-Gün</dt>
            <dd>@NumberDisplay.Format(Plan.PlannedManDay)</dd>
        </div>
    </dl>

    @if (!string.IsNullOrWhiteSpace(Plan.Comment))
    {
        <p class="line-clamp-2 rounded-md bg-neutral-50 px-3 py-2 text-sm text-neutral-600 dark:bg-neutral-900/40 dark:text-neutral-300">@Plan.Comment</p>
    }

    <RejectionNotice Plan="Plan" />

    <a class="btn-primary mt-auto w-full" href="@($"daily-plans/{Plan.Id}")">@DetailButtonText</a>
</article>

@code {
    [Parameter, EditorRequired] public DailyPlanListItemDto Plan { get; set; } = default!;

    private string DetailButtonText =>
        string.IsNullOrWhiteSpace(Plan.LatestRejectionReason) ? "Detay" : "Tekrar kontrol et";

    private static string UnitLabel(Unit unit) => unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => ""
    };
}
