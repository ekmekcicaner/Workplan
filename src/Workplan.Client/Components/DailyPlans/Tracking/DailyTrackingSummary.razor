<section class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
    <WpStatCard Label="Toplam iş" Value="@Items.Count.ToString()" Icon="clipboard" />
    <WpStatCard Label="Planlanan adam-gün" Value="@NumberDisplay.Format(Items.Sum(item => item.PlannedManDay))" Icon="calendar" />
    <WpStatCard Label="Gerçek adam-gün" Value="@NumberDisplay.Format(Items.Sum(item => item.FactManDay ?? 0))" Icon="users" />
    <WpStatCard Label="Fazla mesai" Value="@NumberDisplay.Format(Items.Sum(item => item.Overtime ?? 0))" Icon="clock" />
</section>

@if (Items.Count > 0)
{
    <section class="surface-panel p-3">
        <div class="flex flex-wrap gap-2">
            @foreach (var group in Items.GroupBy(item => item.Status).OrderBy(group => group.Key))
            {
                <span class="inline-flex items-center gap-2 rounded-md border border-border px-3 py-1.5 text-sm">
                    <StatusBadge Status="group.Key" />
                    <span class="font-semibold">@group.Count()</span>
                </span>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DailyTrackingPlanDto> Items { get; set; } = [];
}
