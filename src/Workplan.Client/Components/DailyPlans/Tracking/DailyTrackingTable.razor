<section class="space-y-3">
    <div class="mb-3 flex items-center justify-between gap-3">
        <h2 class="text-base font-semibold">Günlük İş Listesi</h2>
        <span class="badge">@Items.Count kayıt</span>
    </div>

    <WpResponsiveDataView TItem="DailyTrackingPlanDto"
                          Items="Items"
                          ItemKey="@(item => item.Id)"
                          PageSize="25"
                          EmptyTitle="Bu gün için iş yok"
                          EmptyText="Seçili gün ve filtrelerle listelenecek kayıt bulunamadı.">
        <Columns>
            <TemplateColumn TGridItem="DailyTrackingPlanDto" Title="Durum" Context="item"><StatusBadge Status="item.Status" /></TemplateColumn>
            <PropertyColumn TGridItem="DailyTrackingPlanDto" TProp="string" Property="@(item => item.ProjectName)" Title="Proje" Sortable="true" />
            <TemplateColumn TGridItem="DailyTrackingPlanDto" Title="Bölge / Lokasyon" Context="item">
                <span class="block">@item.CrewRegionName</span>
                <span class="block text-sm text-foreground-muted">@item.LocationName</span>
            </TemplateColumn>
            <TemplateColumn TGridItem="DailyTrackingPlanDto" Title="İş Kalemi" Context="item">
                <span class="block">@item.WorkItemTypeName</span>
                <span class="block text-sm text-foreground-muted">@CrewTypeLabel(item)</span>
            </TemplateColumn>
            <TemplateColumn TGridItem="DailyTrackingPlanDto" Title="Sorumlular" Context="item">
                <span class="block text-sm">@Roles.DisplayName(Roles.HeadOfMaster): @DisplayName(item.AssignedHoMName)</span>
                <span class="block text-sm text-foreground-muted">@Roles.DisplayName(Roles.SiteChief): @DisplayName(item.SiteChiefName)</span>
                <span class="block text-sm text-foreground-muted">PM: @DisplayName(item.ProjectManagerName)</span>
            </TemplateColumn>
            <TemplateColumn TGridItem="DailyTrackingPlanDto" Title="Plan" Context="item">
                <span class="block">@NumberDisplay.Format(item.PlannedQuantity) @UnitLabel(item.Unit)</span>
                <span class="block text-sm text-foreground-muted">@NumberDisplay.Format(item.PlannedManDay) AG</span>
            </TemplateColumn>
            <TemplateColumn TGridItem="DailyTrackingPlanDto" Title="Gerçek" Context="item">
                <span class="block">@NumberDisplay.Format(item.FactQuantity) @UnitLabel(item.Unit)</span>
                <span class="block text-sm text-foreground-muted">@NumberDisplay.Format(item.FactManDay) AG · @NumberDisplay.Format(item.Overtime) FM</span>
            </TemplateColumn>
            <TemplateColumn TGridItem="DailyTrackingPlanDto" Title="İşlem" Align="Align.End" Context="item"><a class="entity-row-action" href="@($"daily-plans/{item.Id}")">Detay</a></TemplateColumn>
        </Columns>
        <MobileTemplate Context="item">
            <article class="entity-card">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <h3 class="truncate font-semibold">@item.WorkItemTypeName</h3>
                        <p class="truncate text-sm text-foreground-muted">@item.ProjectName · @item.LocationName</p>
                    </div>
                    <StatusBadge Status="item.Status" />
                </div>
                <dl class="mt-3 grid grid-cols-2 gap-3 text-sm">
                    <div>
                        <dt class="field-label">@Roles.DisplayName(Roles.HeadOfMaster)</dt>
                        <dd class="truncate">@DisplayName(item.AssignedHoMName)</dd>
                    </div>
                    <div>
                        <dt class="field-label">@Roles.DisplayName(Roles.SiteChief)</dt>
                        <dd class="truncate">@DisplayName(item.SiteChiefName)</dd>
                    </div>
                    <div>
                        <dt class="field-label">Plan</dt>
                        <dd>@NumberDisplay.Format(item.PlannedQuantity) @UnitLabel(item.Unit)</dd>
                    </div>
                    <div>
                        <dt class="field-label">Gerçek</dt>
                        <dd>@NumberDisplay.Format(item.FactQuantity) @UnitLabel(item.Unit)</dd>
                    </div>
                    <div>
                        <dt class="field-label">Bölge</dt>
                        <dd class="truncate">@item.CrewRegionName</dd>
                    </div>
                    <div>
                        <dt class="field-label">PM</dt>
                        <dd class="truncate">@DisplayName(item.ProjectManagerName)</dd>
                    </div>
                </dl>
                @if (!string.IsNullOrWhiteSpace(item.Comment))
                {
                    <p class="mt-3 line-clamp-2 rounded-md bg-surface-muted px-3 py-2 text-sm text-foreground-muted">@item.Comment</p>
                }
                <a class="btn-secondary mt-3 w-full" href="@($"daily-plans/{item.Id}")">Detay</a>
            </article>
        </MobileTemplate>
    </WpResponsiveDataView>
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DailyTrackingPlanDto> Items { get; set; } = [];

    private static string DisplayName(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string CrewTypeLabel(DailyTrackingPlanDto item) =>
        string.IsNullOrWhiteSpace(item.CrewTypeName) ? "Ekip tipi seçilmedi" : item.CrewTypeName;

    private static string UnitLabel(Unit unit) => unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => ""
    };
}
