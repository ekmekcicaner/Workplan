<section class="surface-panel p-3">
    <div class="mb-3 flex items-center justify-between gap-3">
        <h2 class="text-base font-semibold">Günlük İş Listesi</h2>
        <span class="badge">@Items.Count kayıt</span>
    </div>

    <ResponsiveEntityList TItem="DailyTrackingPlanDto"
                          Items="Items"
                          EmptyTitle="Bu gün için iş yok"
                          EmptyText="Seçili gün ve filtrelerle listelenecek kayıt bulunamadı.">
        <HeaderRow>
            <th>Durum</th>
            <th>Proje</th>
            <th>Bölge / Lokasyon</th>
            <th>İş Kalemi</th>
            <th>Sorumlular</th>
            <th>Plan</th>
            <th>Gerçek</th>
            <th></th>
        </HeaderRow>
        <DesktopRowTemplate Context="item">
            <td><StatusBadge Status="item.Status" /></td>
            <td>@item.ProjectName</td>
            <td>
                <span class="block">@item.CrewRegionName</span>
                <span class="block text-sm text-neutral-500 dark:text-neutral-400">@item.LocationName</span>
            </td>
            <td>
                <span class="block">@item.WorkItemTypeName</span>
                <span class="block text-sm text-neutral-500 dark:text-neutral-400">@CrewTypeLabel(item)</span>
            </td>
            <td>
                <span class="block text-sm">Usta: @DisplayName(item.AssignedHoMName)</span>
                <span class="block text-sm text-neutral-500 dark:text-neutral-400">Şantiye şefi: @DisplayName(item.SiteChiefName)</span>
                <span class="block text-sm text-neutral-500 dark:text-neutral-400">PM: @DisplayName(item.ProjectManagerName)</span>
            </td>
            <td>
                <span class="block">@NumberDisplay.Format(item.PlannedQuantity) @UnitLabel(item.Unit)</span>
                <span class="block text-sm text-neutral-500 dark:text-neutral-400">@NumberDisplay.Format(item.PlannedManDay) AG</span>
            </td>
            <td>
                <span class="block">@NumberDisplay.Format(item.FactQuantity) @UnitLabel(item.Unit)</span>
                <span class="block text-sm text-neutral-500 dark:text-neutral-400">@NumberDisplay.Format(item.FactManDay) AG · @NumberDisplay.Format(item.Overtime) FM</span>
            </td>
            <td class="text-right"><a class="entity-row-action" href="@($"daily-plans/{item.Id}")">Detay</a></td>
        </DesktopRowTemplate>
        <MobileCardTemplate Context="item">
            <article class="entity-card">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <h3 class="truncate font-semibold">@item.WorkItemTypeName</h3>
                        <p class="truncate text-sm text-neutral-500 dark:text-neutral-400">@item.ProjectName · @item.LocationName</p>
                    </div>
                    <StatusBadge Status="item.Status" />
                </div>
                <dl class="mt-3 grid grid-cols-2 gap-3 text-sm">
                    <div>
                        <dt class="field-label">Ustabaşı</dt>
                        <dd class="truncate">@DisplayName(item.AssignedHoMName)</dd>
                    </div>
                    <div>
                        <dt class="field-label">Şantiye şefi</dt>
                        <dd class="truncate">@DisplayName(item.SiteChiefName)</dd>
                    </div>
                    <div>
                        <dt class="field-label">Plan</dt>
                        <dd>@NumberDisplay.Format(item.PlannedQuantity) @UnitLabel(item.Unit)</dd>
                    </div>
                    <div>
                        <dt class="field-label">Gerçek</dt>
                        <dd>@NumberDisplay.Format(item.FactQuantity) @UnitLabel(item.Unit)</dd>
                    </div>
                    <div>
                        <dt class="field-label">Bölge</dt>
                        <dd class="truncate">@item.CrewRegionName</dd>
                    </div>
                    <div>
                        <dt class="field-label">PM</dt>
                        <dd class="truncate">@DisplayName(item.ProjectManagerName)</dd>
                    </div>
                </dl>
                @if (!string.IsNullOrWhiteSpace(item.Comment))
                {
                    <p class="mt-3 line-clamp-2 rounded-md bg-neutral-50 px-3 py-2 text-sm text-neutral-600 dark:bg-neutral-900/40 dark:text-neutral-300">@item.Comment</p>
                }
                <a class="btn-secondary mt-3 w-full" href="@($"daily-plans/{item.Id}")">Detay</a>
            </article>
        </MobileCardTemplate>
    </ResponsiveEntityList>
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DailyTrackingPlanDto> Items { get; set; } = [];

    private static string DisplayName(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string CrewTypeLabel(DailyTrackingPlanDto item) =>
        string.IsNullOrWhiteSpace(item.CrewTypeName) ? "Ekip tipi seçilmedi" : item.CrewTypeName;

    private static string UnitLabel(Unit unit) => unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => ""
    };
}
