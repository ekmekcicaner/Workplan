<div class="rounded-md border border-neutral-200 bg-white p-3 dark:border-neutral-700 dark:bg-neutral-900">
    <div class="mb-2 flex items-center justify-between gap-2">
        <label class="field-label mb-0">Durum</label>
        @if (SelectedStatuses.Count > 0)
        {
            <button type="button" class="text-xs font-semibold text-brand-600 dark:text-brand-400" @onclick="ClearAsync">
                Temizle
            </button>
        }
    </div>
    <div class="max-h-44 space-y-1 overflow-y-auto pr-1">
        @foreach (var status in Statuses)
        {
            var selected = SelectedStatuses.Contains(status);
            <label @key="status" class="flex min-w-0 cursor-pointer items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-neutral-50 dark:hover:bg-neutral-800">
                <input type="checkbox"
                       class="size-4"
                       checked="@selected"
                       @onchange="args => ToggleAsync(status, args.Value)" />
                <span class="truncate">@StatusLabel(status)</span>
            </label>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<WorkStatus> Statuses { get; set; } = [];
    [Parameter, EditorRequired] public HashSet<WorkStatus> SelectedStatuses { get; set; } = [];
    [Parameter] public EventCallback<HashSet<WorkStatus>> SelectedStatusesChanged { get; set; }

    private Task ToggleAsync(WorkStatus status, object? value)
    {
        var next = new HashSet<WorkStatus>(SelectedStatuses);
        if (value is true)
        {
            next.Add(status);
        }
        else
        {
            next.Remove(status);
        }

        return SelectedStatusesChanged.InvokeAsync(next);
    }

    private Task ClearAsync() => SelectedStatusesChanged.InvokeAsync([]);

    private static string StatusLabel(WorkStatus status) => status switch
    {
        WorkStatus.Draft => "Taslak",
        WorkStatus.Assigned => "Atandı",
        WorkStatus.InProgress => "Devam Ediyor",
        WorkStatus.Submitted => "Şantiye Şefi Onayında",
        WorkStatus.ApprovedByHoM => "HoM Onayı",
        WorkStatus.ApprovedBySiteChief => "Şantiye Şefi Onayladı",
        WorkStatus.ApprovedByPM => "Tamamlandı",
        WorkStatus.Reported => "Raporlandı",
        _ => status.ToString()
    };
}
