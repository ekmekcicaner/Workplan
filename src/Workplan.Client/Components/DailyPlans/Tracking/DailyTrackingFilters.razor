<section class="card p-3">
    <div class="flex flex-wrap items-center gap-2">
        <div class="w-40 shrink-0">
            <label class="field-label">İş tarihi</label>
            <input class="input" type="date" value="@WorkDate.ToString("yyyy-MM-dd")" @onchange="OnDateChangedAsync" />
        </div>

        <div class="hidden flex-1 flex-wrap items-center gap-2 md:flex">
            <WpPopover Open="_openStatus" OpenChanged="v => SetOpen(ref _openStatus, v)">
                <Trigger>
                    <button type="button" class="filter-trigger">
                        Durum @CountBadge(SelectedStatuses.Count)
                        <Icon Name="chevron-down" CssClass="h-4 w-4" />
                    </button>
                </Trigger>
                <ChildContent>
                    <div class="w-56 p-1">
                        <div class="mb-1.5 flex items-center justify-between gap-2 px-2 pt-1">
                            <span class="text-xs font-bold uppercase tracking-wide text-foreground-subtle">Durum</span>
                            @if (SelectedStatuses.Count > 0)
                            {
                                <button type="button" class="text-xs font-semibold text-brand-600 dark:text-brand-400" @onclick="() => SelectedStatusesChanged.InvokeAsync([])">
                                    Temizle
                                </button>
                            }
                        </div>
                        <div class="max-h-52 space-y-0.5 overflow-y-auto pr-1">
                            @foreach (var status in Options?.Statuses ?? [])
                            {
                                var selected = SelectedStatuses.Contains(status);
                                <label @key="status" class="menu-item cursor-pointer">
                                    <input type="checkbox" class="size-4" checked="@selected" @onchange="args => ToggleStatusAsync(status, args.Value)" />
                                    <span class="truncate">@StatusLabel(status)</span>
                                </label>
                            }
                        </div>
                    </div>
                </ChildContent>
            </WpPopover>

            <WpPopover Open="_openProject" OpenChanged="v => SetOpen(ref _openProject, v)">
                <Trigger>
                    <button type="button" class="filter-trigger">
                        Proje @CountBadge(SelectedProjectIds.Count)
                        <Icon Name="chevron-down" CssClass="h-4 w-4" />
                    </button>
                </Trigger>
                <ChildContent>
                    <FilterOptionList Options="Options?.Projects ?? []" SelectedIds="SelectedProjectIds" SelectedIdsChanged="SelectedProjectIdsChanged" />
                </ChildContent>
            </WpPopover>

            <WpPopover Open="_openRegion" OpenChanged="v => SetOpen(ref _openRegion, v)">
                <Trigger>
                    <button type="button" class="filter-trigger">
                        Saha bölgesi @CountBadge(SelectedCrewRegionIds.Count)
                        <Icon Name="chevron-down" CssClass="h-4 w-4" />
                    </button>
                </Trigger>
                <ChildContent>
                    <FilterOptionList Options="Options?.CrewRegions ?? []" SelectedIds="SelectedCrewRegionIds" SelectedIdsChanged="SelectedCrewRegionIdsChanged" />
                </ChildContent>
            </WpPopover>

            <WpPopover Open="_openLocation" OpenChanged="v => SetOpen(ref _openLocation, v)">
                <Trigger>
                    <button type="button" class="filter-trigger">
                        Lokasyon @CountBadge(SelectedLocationIds.Count)
                        <Icon Name="chevron-down" CssClass="h-4 w-4" />
                    </button>
                </Trigger>
                <ChildContent>
                    <FilterOptionList Options="Options?.Locations ?? []" SelectedIds="SelectedLocationIds" SelectedIdsChanged="SelectedLocationIdsChanged" />
                </ChildContent>
            </WpPopover>

            <WpPopover Open="_openResponsible" OpenChanged="v => SetOpen(ref _openResponsible, v)">
                <Trigger>
                    <button type="button" class="filter-trigger">
                        Sorumlular @CountBadge(SelectedHeadOfMasterIds.Count + SelectedSiteChiefIds.Count + SelectedProjectManagerIds.Count)
                        <Icon Name="chevron-down" CssClass="h-4 w-4" />
                    </button>
                </Trigger>
                <ChildContent>
                    <div class="flex max-h-[24rem] flex-col divide-y divide-border overflow-y-auto">
                        <FilterOptionList Label="@Roles.DisplayName(Roles.HeadOfMaster)" Options="Options?.HeadOfMasters ?? []" SelectedIds="SelectedHeadOfMasterIds" SelectedIdsChanged="SelectedHeadOfMasterIdsChanged" />
                        <FilterOptionList Label="@Roles.DisplayName(Roles.SiteChief)" Options="Options?.SiteChiefs ?? []" SelectedIds="SelectedSiteChiefIds" SelectedIdsChanged="SelectedSiteChiefIdsChanged" />
                        <FilterOptionList Label="PM" Options="Options?.ProjectManagers ?? []" SelectedIds="SelectedProjectManagerIds" SelectedIdsChanged="SelectedProjectManagerIdsChanged" />
                    </div>
                </ChildContent>
            </WpPopover>
        </div>

        <button type="button" class="btn-secondary md:hidden" @onclick="() => _showMobileDrawer = true">
            <Icon Name="filter" CssClass="h-4 w-4" />
            Filtreler @CountBadge(TotalActiveGroups)
        </button>

        <div class="ml-auto flex gap-2">
            <button class="btn-secondary" type="button" @onclick="OnClear">Temizle</button>
            <button class="btn-primary" type="button" @onclick="OnApply">
                <Icon Name="search" CssClass="h-4 w-4" />Filtrele
            </button>
        </div>
    </div>

    @if (TotalActiveGroups > 0)
    {
        <div class="mt-3 flex flex-wrap gap-1.5">
            @foreach (var status in SelectedStatuses)
            {
                <span @key="status" class="filter-chip">
                    @StatusLabel(status)
                    <button type="button" class="filter-chip-remove" @onclick="() => RemoveStatusAsync(status)" aria-label="Kaldır">
                        <Icon Name="x" CssClass="h-3.5 w-3.5" />
                    </button>
                </span>
            }
            @foreach (var option in (Options?.Projects ?? []).Where(o => SelectedProjectIds.Contains(o.Id)))
            {
                <span @key="option.Id" class="filter-chip">
                    @option.Label
                    <button type="button" class="filter-chip-remove" @onclick="() => RemoveIdAsync(SelectedProjectIds, SelectedProjectIdsChanged, option.Id)" aria-label="Kaldır">
                        <Icon Name="x" CssClass="h-3.5 w-3.5" />
                    </button>
                </span>
            }
            @foreach (var option in (Options?.CrewRegions ?? []).Where(o => SelectedCrewRegionIds.Contains(o.Id)))
            {
                <span @key="option.Id" class="filter-chip">
                    @option.Label
                    <button type="button" class="filter-chip-remove" @onclick="() => RemoveIdAsync(SelectedCrewRegionIds, SelectedCrewRegionIdsChanged, option.Id)" aria-label="Kaldır">
                        <Icon Name="x" CssClass="h-3.5 w-3.5" />
                    </button>
                </span>
            }
            @foreach (var option in (Options?.Locations ?? []).Where(o => SelectedLocationIds.Contains(o.Id)))
            {
                <span @key="option.Id" class="filter-chip">
                    @option.Label
                    <button type="button" class="filter-chip-remove" @onclick="() => RemoveIdAsync(SelectedLocationIds, SelectedLocationIdsChanged, option.Id)" aria-label="Kaldır">
                        <Icon Name="x" CssClass="h-3.5 w-3.5" />
                    </button>
                </span>
            }
            @foreach (var option in (Options?.HeadOfMasters ?? []).Where(o => SelectedHeadOfMasterIds.Contains(o.Id)))
            {
                <span @key="option.Id" class="filter-chip">
                    @option.Label
                    <button type="button" class="filter-chip-remove" @onclick="() => RemoveIdAsync(SelectedHeadOfMasterIds, SelectedHeadOfMasterIdsChanged, option.Id)" aria-label="Kaldır">
                        <Icon Name="x" CssClass="h-3.5 w-3.5" />
                    </button>
                </span>
            }
            @foreach (var option in (Options?.SiteChiefs ?? []).Where(o => SelectedSiteChiefIds.Contains(o.Id)))
            {
                <span @key="option.Id" class="filter-chip">
                    @option.Label
                    <button type="button" class="filter-chip-remove" @onclick="() => RemoveIdAsync(SelectedSiteChiefIds, SelectedSiteChiefIdsChanged, option.Id)" aria-label="Kaldır">
                        <Icon Name="x" CssClass="h-3.5 w-3.5" />
                    </button>
                </span>
            }
            @foreach (var option in (Options?.ProjectManagers ?? []).Where(o => SelectedProjectManagerIds.Contains(o.Id)))
            {
                <span @key="option.Id" class="filter-chip">
                    @option.Label
                    <button type="button" class="filter-chip-remove" @onclick="() => RemoveIdAsync(SelectedProjectManagerIds, SelectedProjectManagerIdsChanged, option.Id)" aria-label="Kaldır">
                        <Icon Name="x" CssClass="h-3.5 w-3.5" />
                    </button>
                </span>
            }
        </div>
    }
</section>

<WpDrawer Show="_showMobileDrawer" Title="Filtreler" OnClose="() => _showMobileDrawer = false">
    <ChildContent>
    <div class="space-y-4">
        <details open class="rounded-md border border-border">
            <summary class="cursor-pointer px-3 py-2 text-sm font-semibold">Durum</summary>
            <div class="p-2">
                @foreach (var status in Options?.Statuses ?? [])
                {
                    var selected = SelectedStatuses.Contains(status);
                    <label @key="status" class="menu-item cursor-pointer">
                        <input type="checkbox" class="size-4" checked="@selected" @onchange="args => ToggleStatusAsync(status, args.Value)" />
                        <span class="truncate">@StatusLabel(status)</span>
                    </label>
                }
            </div>
        </details>
        <details class="rounded-md border border-border">
            <summary class="cursor-pointer px-3 py-2 text-sm font-semibold">Proje</summary>
            <FilterOptionList Options="Options?.Projects ?? []" SelectedIds="SelectedProjectIds" SelectedIdsChanged="SelectedProjectIdsChanged" />
        </details>
        <details class="rounded-md border border-border">
            <summary class="cursor-pointer px-3 py-2 text-sm font-semibold">Saha bölgesi</summary>
            <FilterOptionList Options="Options?.CrewRegions ?? []" SelectedIds="SelectedCrewRegionIds" SelectedIdsChanged="SelectedCrewRegionIdsChanged" />
        </details>
        <details class="rounded-md border border-border">
            <summary class="cursor-pointer px-3 py-2 text-sm font-semibold">Lokasyon</summary>
            <FilterOptionList Options="Options?.Locations ?? []" SelectedIds="SelectedLocationIds" SelectedIdsChanged="SelectedLocationIdsChanged" />
        </details>
        <details class="rounded-md border border-border">
            <summary class="cursor-pointer px-3 py-2 text-sm font-semibold">Sorumlu filtreleri</summary>
            <div class="space-y-2 p-2">
                <FilterOptionList Label="@Roles.DisplayName(Roles.HeadOfMaster)" Options="Options?.HeadOfMasters ?? []" SelectedIds="SelectedHeadOfMasterIds" SelectedIdsChanged="SelectedHeadOfMasterIdsChanged" />
                <FilterOptionList Label="@Roles.DisplayName(Roles.SiteChief)" Options="Options?.SiteChiefs ?? []" SelectedIds="SelectedSiteChiefIds" SelectedIdsChanged="SelectedSiteChiefIdsChanged" />
                <FilterOptionList Label="PM" Options="Options?.ProjectManagers ?? []" SelectedIds="SelectedProjectManagerIds" SelectedIdsChanged="SelectedProjectManagerIdsChanged" />
            </div>
        </details>
    </div>
    </ChildContent>
    <Footer>
        <button class="btn-secondary" type="button" @onclick="ClearFromDrawerAsync">Temizle</button>
        <button class="btn-primary" type="button" @onclick="ApplyFromDrawerAsync">
            <Icon Name="search" CssClass="h-4 w-4" />Uygula
        </button>
    </Footer>
</WpDrawer>

@code {
    [Parameter] public DailyTrackingOptionsDto? Options { get; set; }
    [Parameter] public DateOnly WorkDate { get; set; }
    [Parameter] public EventCallback<DateOnly> WorkDateChanged { get; set; }
    [Parameter, EditorRequired] public HashSet<Guid> SelectedProjectIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedProjectIdsChanged { get; set; }
    [Parameter, EditorRequired] public HashSet<Guid> SelectedCrewRegionIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedCrewRegionIdsChanged { get; set; }
    [Parameter, EditorRequired] public HashSet<Guid> SelectedLocationIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedLocationIdsChanged { get; set; }
    [Parameter, EditorRequired] public HashSet<Guid> SelectedHeadOfMasterIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedHeadOfMasterIdsChanged { get; set; }
    [Parameter, EditorRequired] public HashSet<Guid> SelectedSiteChiefIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedSiteChiefIdsChanged { get; set; }
    [Parameter, EditorRequired] public HashSet<Guid> SelectedProjectManagerIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedProjectManagerIdsChanged { get; set; }
    [Parameter, EditorRequired] public HashSet<WorkStatus> SelectedStatuses { get; set; } = [];
    [Parameter] public EventCallback<HashSet<WorkStatus>> SelectedStatusesChanged { get; set; }
    [Parameter] public EventCallback OnApply { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }

    private bool _openStatus;
    private bool _openProject;
    private bool _openRegion;
    private bool _openLocation;
    private bool _openResponsible;
    private bool _showMobileDrawer;

    private int TotalActiveGroups =>
        (SelectedStatuses.Count > 0 ? 1 : 0) +
        (SelectedProjectIds.Count > 0 ? 1 : 0) +
        (SelectedCrewRegionIds.Count > 0 ? 1 : 0) +
        (SelectedLocationIds.Count > 0 ? 1 : 0) +
        (SelectedHeadOfMasterIds.Count > 0 || SelectedSiteChiefIds.Count > 0 || SelectedProjectManagerIds.Count > 0 ? 1 : 0);

    private void SetOpen(ref bool field, bool value)
    {
        _openStatus = _openProject = _openRegion = _openLocation = _openResponsible = false;
        field = value;
    }

    private static RenderFragment CountBadge(int count) => builder =>
    {
        if (count > 0)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "ml-0.5 inline-flex min-w-5 justify-center rounded-full bg-brand-100 px-1.5 text-[11px] font-bold text-brand-800 dark:bg-brand-950/60 dark:text-brand-300");
            builder.AddContent(2, count);
            builder.CloseElement();
        }
    };

    private Task ToggleStatusAsync(WorkStatus status, object? value)
    {
        var next = new HashSet<WorkStatus>(SelectedStatuses);
        if (value is true) next.Add(status); else next.Remove(status);
        return SelectedStatusesChanged.InvokeAsync(next);
    }

    private Task RemoveStatusAsync(WorkStatus status)
    {
        var next = new HashSet<WorkStatus>(SelectedStatuses);
        next.Remove(status);
        return SelectedStatusesChanged.InvokeAsync(next);
    }

    private static Task RemoveIdAsync(HashSet<Guid> selectedIds, EventCallback<HashSet<Guid>> changed, Guid id)
    {
        var next = new HashSet<Guid>(selectedIds);
        next.Remove(id);
        return changed.InvokeAsync(next);
    }

    private async Task ClearFromDrawerAsync()
    {
        await OnClear.InvokeAsync();
        _showMobileDrawer = false;
    }

    private async Task ApplyFromDrawerAsync()
    {
        await OnApply.InvokeAsync();
        _showMobileDrawer = false;
    }

    private async Task OnDateChangedAsync(ChangeEventArgs args)
    {
        if (DateOnly.TryParse(args.Value?.ToString(), out var date))
        {
            await WorkDateChanged.InvokeAsync(date);
        }
    }

    private static string StatusLabel(WorkStatus status) => status switch
    {
        WorkStatus.Draft => "Taslak",
        WorkStatus.Assigned => "Atandı",
        WorkStatus.InProgress => "Devam Ediyor",
        WorkStatus.Submitted => $"{Roles.DisplayName(Roles.SiteChief)} Onayında",
        WorkStatus.ApprovedBySiteChief => $"{Roles.DisplayName(Roles.SiteChief)} Onayladı",
        WorkStatus.ApprovedByPM => "Tamamlandı",
        _ => status.ToString()
    };
}
