<div class="card">
    <div class="mb-3 flex items-center justify-between gap-3">
        <h2 class="text-base font-semibold">Bugünkü İşler</h2>
        <span class="badge">@TodayItems.Count</span>
    </div>

    <LoadingBlock Loading="Loading" ErrorText="@LoadError" />
    @if (!Loading && string.IsNullOrWhiteSpace(LoadError))
    {
        @if (TodayItems.Count == 0)
        {
            <p class="text-sm text-neutral-500 dark:text-neutral-400">Bugün için iş görünmüyor.</p>
        }
        else
        {
            <ul class="flex flex-col gap-2">
                @foreach (var plan in TodayItems)
                {
                    <li>
                        <a class="flex min-w-0 items-center justify-between gap-3 rounded-md border border-neutral-200 px-3 py-2 text-sm hover:bg-neutral-50 dark:border-neutral-700 dark:hover:bg-neutral-700/50"
                           href="@($"daily-plans/{plan.Id}")">
                            <span class="min-w-0">
                                <span class="block truncate font-medium">@plan.LocationName</span>
                                <span class="block truncate text-neutral-500 dark:text-neutral-400">@plan.WorkItemTypeName</span>
                            </span>
                            <StatusBadge Status="plan.Status" />
                        </a>
                    </li>
                }
            </ul>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DailyPlanListItemDto> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? LoadError { get; set; }

    private IReadOnlyList<DailyPlanListItemDto> TodayItems =>
        Items.Where(item => item.WorkDate == DateOnly.FromDateTime(DateTime.Today)).ToList();
}
