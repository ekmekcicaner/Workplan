<article class="card flex h-full flex-col gap-3">
    <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
            <h2 class="truncate font-semibold">@Plan.ProjectName</h2>
            <p class="truncate text-sm text-foreground-muted">@Plan.CrewRegionName · @Plan.LocationName</p>
        </div>
        <StatusBadge Status="Plan.Status" />
    </div>

    <dl class="grid grid-cols-2 gap-3 text-sm">
        <div>
            <dt class="field-label">Tarih</dt>
            <dd>@Plan.WorkDate.ToString("dd.MM.yyyy")</dd>
        </div>
        <div>
            <dt class="field-label">İş Kalemi</dt>
            <dd class="truncate">@Plan.WorkItemTypeName</dd>
        </div>
        <div>
            <dt class="field-label">Plan</dt>
            <dd>@NumberDisplay.Format(Plan.PlannedQuantity) @UnitLabel(Plan.Unit)</dd>
        </div>
        <div>
            <dt class="field-label">Gerçek</dt>
            <dd>@NumberDisplay.Format(Plan.FactQuantity) @UnitLabel(Plan.Unit)</dd>
        </div>
    </dl>

    @if (!string.IsNullOrWhiteSpace(Plan.Comment))
    {
        <p class="line-clamp-2 rounded-md bg-surface-muted px-3 py-2 text-sm text-foreground-muted">@Plan.Comment</p>
    }

    <RejectionNotice Plan="Plan" />

    <a class="btn-primary mt-auto w-full" href="@($"daily-plans/{Plan.Id}")">@ReviewButtonText</a>
</article>

@code {
    [Parameter, EditorRequired] public DailyPlanListItemDto Plan { get; set; } = default!;

    private string ReviewButtonText =>
        string.IsNullOrWhiteSpace(Plan.LatestRejectionReason) ? "İncele" : "Tekrar kontrol et";

    private static string UnitLabel(Unit unit) => unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => ""
    };
}
