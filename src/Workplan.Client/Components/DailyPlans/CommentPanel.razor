<div class="card">
    <h2 class="mb-3 text-base font-semibold">Açıklama / Red Gerekçesi</h2>
    @if (string.IsNullOrWhiteSpace(Comment))
    {
        <p class="text-sm text-foreground-muted">Açıklama girilmemiş.</p>
    }
    else
    {
        <p class="whitespace-pre-wrap text-sm text-foreground">@Comment</p>
    }
</div>

@code {
    [Parameter] public string? Comment { get; set; }
}
