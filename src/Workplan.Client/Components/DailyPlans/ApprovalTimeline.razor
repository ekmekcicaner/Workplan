<div class="card">
    <h2 class="mb-3 text-base font-semibold">Durum Geçmişi</h2>
    @if (History.Count == 0)
    {
        <p class="text-sm text-foreground-muted">Geçmiş kaydı yok.</p>
    }
    else
    {
        <ul class="flex flex-col gap-3 text-sm">
            @foreach (var entry in History.OrderBy(item => item.TransitionedAt))
            {
                <li class="border-b border-border pb-3 last:border-0 last:pb-0">
                    <div class="flex flex-wrap items-center gap-2">
                        <StatusBadge Status="entry.FromStatus" />
                        <span class="text-foreground-muted">→</span>
                        <StatusBadge Status="entry.ToStatus" />
                        <span class="text-foreground-muted">@entry.TransitionedAt.ToLocalTime().ToString("g")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(entry.Note))
                    {
                        <p class="mt-1 whitespace-pre-wrap text-foreground-muted">@entry.Note</p>
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyCollection<StatusTransitionDto> History { get; set; } = [];
}
