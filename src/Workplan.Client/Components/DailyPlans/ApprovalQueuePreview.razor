<div class="card">
    <div class="mb-3 flex items-center justify-between gap-3">
        <h2 class="text-base font-semibold">Onay Bekleyenler</h2>
        <span class="badge">@Items.Count</span>
    </div>

    <LoadingBlock Loading="Loading" ErrorText="@LoadError" />
    @if (!Loading && string.IsNullOrWhiteSpace(LoadError))
    {
        @if (Items.Count == 0)
        {
            <p class="text-sm text-foreground-muted">Onay bekleyen iş yok.</p>
        }
        else
        {
            <ul class="flex flex-col gap-2">
                @foreach (var plan in Items.Take(5))
                {
                    <li>
                        <a class="flex min-w-0 items-center justify-between gap-3 rounded-md border border-border px-3 py-2 text-sm hover:bg-surface-muted"
                           href="@($"daily-plans/{plan.Id}")">
                            <span class="min-w-0">
                                <span class="block truncate font-medium">@plan.ProjectName</span>
                                <span class="block truncate text-foreground-muted">@plan.LocationName · @plan.WorkDate.ToString("dd.MM.yyyy")</span>
                            </span>
                            <StatusBadge Status="plan.Status" />
                        </a>
                    </li>
                }
            </ul>
            <a class="btn-secondary mt-3 w-full" href="approvals">Tümünü görüntüle</a>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DailyPlanListItemDto> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? LoadError { get; set; }
}
