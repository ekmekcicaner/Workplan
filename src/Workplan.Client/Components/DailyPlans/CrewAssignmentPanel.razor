@inject CrewTypesApiService CrewTypesApi

<div class="card">
    <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-base font-semibold">Ekip Tipi</h2>
        @if (Plan.CrewTypeName is not null)
        {
            <span class="badge">@Plan.CrewTypeName</span>
        }
    </div>

    @if (Plan.CrewTypeId is not null)
    {
        <p class="text-sm text-neutral-500 dark:text-neutral-400">
            Bu iş <span class="font-medium text-neutral-700 dark:text-neutral-200">@Plan.CrewTypeName</span> ekip tipiyle başlatıldı.
        </p>
    }
    else if (Plan.Status == WorkStatus.Assigned)
    {
        <LoadingBlock Loading="_loadingCrewTypes" ErrorText="@_crewTypeLoadError" />

        @if (!_loadingCrewTypes && _crewTypeLoadError is null)
        {
            @if (_crewTypes.Count == 0)
            {
                <p class="text-sm text-neutral-500 dark:text-neutral-400">Aktif ekip tipi yok.</p>
            }
            else
            {
                <div class="flex flex-col gap-3">
                    <div>
                        <label class="field-label">Ekip tipi</label>
                        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
                            @foreach (var crewType in _crewTypes)
                            {
                                <label @key="crewType.Id" class="flex min-h-11 items-center gap-2 rounded-md border border-neutral-200 px-3 py-2 text-sm dark:border-neutral-700">
                                    <input type="radio"
                                           name="crew-type"
                                           checked="@(SelectedCrewTypeId == crewType.Id)"
                                           @onchange="() => SelectCrewTypeAsync(crewType.Id)" />
                                    <span>@crewType.Name</span>
                                </label>
                            }
                        </div>
                    </div>
                    <button class="btn-primary self-start" disabled="@(!CanStart)" @onclick="OnStart">İşi Başlat</button>
                </div>
            }
        }
    }
    else
    {
        <p class="text-sm text-neutral-500 dark:text-neutral-400">Bu aşamada ekip tipi seçimi değiştirilemez.</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public DailyPlanDetailDto Plan { get; set; } = default!;
    [Parameter] public Guid? SelectedCrewTypeId { get; set; }
    [Parameter] public EventCallback<Guid?> SelectedCrewTypeIdChanged { get; set; }
    [Parameter] public EventCallback OnStart { get; set; }
    [Parameter] public bool Busy { get; set; }
    [Parameter] public bool IsOnline { get; set; } = true;

    private List<CrewTypeDto> _crewTypes = [];
    private bool _loadingCrewTypes = true;
    private string? _crewTypeLoadError;

    private bool CanStart => !Busy && IsOnline && SelectedCrewTypeId is not null;

    protected override async Task OnInitializedAsync()
    {
        var result = await CrewTypesApi.GetAllAsync();
        if (result.Success)
        {
            _crewTypes = result.Data ?? [];
        }
        else
        {
            _crewTypeLoadError = result.ErrorMessage ?? "Ekip tipleri yüklenemedi.";
        }

        _loadingCrewTypes = false;
    }

    private async Task SelectCrewTypeAsync(Guid crewTypeId) =>
        await SelectedCrewTypeIdChanged.InvokeAsync(crewTypeId);
}
