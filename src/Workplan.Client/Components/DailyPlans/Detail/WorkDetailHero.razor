<section class="surface-panel overflow-hidden">
    <div class="border-b border-neutral-200 p-4 dark:border-neutral-800 sm:p-5">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div class="min-w-0">
                <div class="mb-3 flex flex-wrap items-center gap-2">
                    <StatusBadge Status="Plan.Status" />
                    <span class="badge">@Plan.WorkDate.ToString("dd.MM.yyyy")</span>
                </div>
                <h1 class="text-xl font-semibold tracking-normal text-neutral-950 dark:text-neutral-50 sm:text-2xl">
                    @Plan.WorkItemTypeName
                </h1>
                <p class="mt-2 text-sm font-medium text-neutral-700 dark:text-neutral-200">@Plan.ProjectName</p>
                <p class="mt-1 text-sm leading-6 text-neutral-500 dark:text-neutral-400">
                    @Plan.CrewRegionName · @Plan.LocationName
                </p>
            </div>

            <div class="grid grid-cols-2 gap-2 sm:min-w-72">
                <div class="rounded-lg border border-neutral-200 bg-neutral-50 p-3 dark:border-neutral-800 dark:bg-neutral-950/60">
                    <div class="mb-2 flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">
                        <Icon Name="calendar" CssClass="h-4 w-4" /> Tarih
                    </div>
                    <p class="text-sm font-semibold">@Plan.WorkDate.ToString("dd.MM.yyyy")</p>
                </div>
                <div class="rounded-lg border border-neutral-200 bg-neutral-50 p-3 dark:border-neutral-800 dark:bg-neutral-950/60">
                    <div class="mb-2 flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">
                        <Icon Name="hard-hat" CssClass="h-4 w-4" /> Ekip
                    </div>
                    <p class="truncate text-sm font-semibold">@CrewTypeLabel</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 divide-y divide-neutral-200 dark:divide-neutral-800 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
        <div class="p-4">
            <p class="field-label">Planlanan Miktar</p>
            <p class="text-lg font-semibold">@NumberDisplay.Format(Plan.PlannedQuantity) @UnitLabel</p>
        </div>
        <div class="p-4">
            <p class="field-label">Planlanan Adam-gün</p>
            <p class="text-lg font-semibold">@NumberDisplay.Format(Plan.PlannedManDay)</p>
        </div>
        <div class="p-4">
            <p class="field-label">Birim</p>
            <p class="text-lg font-semibold">@UnitLabel</p>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public DailyPlanDetailDto Plan { get; set; } = default!;

    private string CrewTypeLabel => string.IsNullOrWhiteSpace(Plan.CrewTypeName)
        ? "Henüz seçilmedi"
        : Plan.CrewTypeName;

    private string UnitLabel => Plan.Unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => "-"
    };
}
