<section class="card">
    <div class="mb-3 flex items-center gap-2">
        <div class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-warning-soft text-warning">
            <Icon Name="info" CssClass="h-5 w-5" />
        </div>
        <div>
            <h2 class="text-base font-semibold">Saha Açıklamaları</h2>
            <p class="text-sm text-foreground-muted">Gün sonu notları ve red gerekçeleri.</p>
        </div>
    </div>

    @if (Comments.Count == 0)
    {
        <p class="rounded-lg border border-dashed border-border bg-surface-muted p-3 text-sm text-foreground-muted">
            Açıklama girilmemiş.
        </p>
    }
    else
    {
        <ol class="space-y-3">
            @foreach (var comment in Comments.OrderByDescending(item => item.CreatedAt))
            {
                <li @key="comment" class="rounded-lg border border-border bg-surface-muted p-3">
                    <div class="mb-2 flex flex-wrap items-center gap-x-3 gap-y-1">
                        <span class="@KindBadgeClass(comment.Kind)">@KindLabel(comment.Kind)</span>
                        <span class="text-sm font-medium text-foreground">@ActorLabel(comment)</span>
                        <span class="text-sm text-foreground-muted">@comment.CreatedAt.ToLocalTime().ToString("g")</span>
                    </div>
                    <p class="whitespace-pre-wrap text-sm leading-6 text-foreground">@comment.Text</p>
                </li>
            }
        </ol>
    }
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyCollection<DailyPlanCommentDto> Comments { get; set; } = [];

    private static string ActorLabel(DailyPlanCommentDto comment) =>
        string.IsNullOrWhiteSpace(comment.ActionByName) ? "Sistem kaydı" : comment.ActionByName;

    private static string KindLabel(DailyPlanCommentKind kind) => kind switch
    {
        DailyPlanCommentKind.Rejection => "Red Gerekçesi",
        _ => "HoM Yorumu"
    };

    private static string KindBadgeClass(DailyPlanCommentKind kind) => kind switch
    {
        DailyPlanCommentKind.Rejection => "badge border border-danger/25 bg-danger-soft text-danger",
        _ => "badge border border-success/25 bg-success-soft text-success"
    };
}
