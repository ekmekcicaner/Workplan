<div class="card">
    <h2 class="mb-3 text-base font-semibold">Saha Sorumlusu</h2>
    <label class="field-label">@Roles.DisplayName(Roles.HeadOfMaster)</label>
    <UserPicker Role="@Roles.HeadOfMaster" Value="Value" ValueChanged="ValueChanged" Placeholder="@($"{Roles.DisplayName(Roles.HeadOfMaster)} ara...")" />
</div>

@code {
    [Parameter] public Guid? Value { get; set; }
    [Parameter] public EventCallback<Guid?> ValueChanged { get; set; }
}
