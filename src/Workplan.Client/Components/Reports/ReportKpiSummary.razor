<div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
    <WpStatCard Label="Onaylı kayıt" Value="@Report.Summary.ApprovedWorkCount.ToString()" Description="PM onayı tamamlandı" Icon="check-circle" />
    <WpStatCard Label="Gerçekleşen adam-gün" Value="@NumberDisplay.Format(Report.Summary.FactManDay)" Description="@($"Planlanan: {NumberDisplay.Format(Report.Summary.PlannedManDay)}")" Icon="users" />
    <WpStatCard Label="Fazla mesai" Value="@NumberDisplay.Format(Report.Summary.Overtime)" Description="Adam-günden ayrı takip edilir" Icon="clock" />
    <WpStatCard Label="Adam-gün gerçekleşme" Value="@RatioLabel" Description="Gerçekleşen / planlanan" Icon="bar-chart" />
</div>

@if (Report.QuantityByWorkItem.Count > 0)
{
    <div class="card mt-3">
        <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
            <div>
                <h2 class="text-base font-semibold">İş Kalemi Miktarları</h2>
                <p class="text-sm text-foreground-muted">Miktar KPI iş kalemi bazında okunur; birim toplamları aşağıda özetlenir.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3">
            @foreach (var item in Report.QuantityByWorkItem)
            {
                <div class="rounded-md border border-border p-3">
                    <p class="mb-2 min-h-10 font-semibold">@item.WorkItemTypeName</p>
                    <div class="grid grid-cols-2 gap-3 text-sm">
                        <div>
                            <p class="field-label">Plan</p>
                            <p>@NumberDisplay.Format(item.PlannedQuantity) @UnitLabel(item.Unit)</p>
                        </div>
                        <div>
                            <p class="field-label">Gerçek</p>
                            <p class="font-semibold">@NumberDisplay.Format(item.FactQuantity) @UnitLabel(item.Unit)</p>
                        </div>
                    </div>
                    <p class="mt-2 text-sm text-foreground-muted">@QuantityDeltaLabel(item)</p>
                </div>
            }
        </div>

        @if (Report.QuantityByUnit.Count > 0)
        {
            <div class="mt-4 border-t border-border pt-3">
                <p class="field-label">Birim bazlı toplam</p>
                <div class="flex flex-wrap gap-2">
                    @foreach (var item in Report.QuantityByUnit)
                    {
                        <span class="badge">@UnitLabel(item.Unit): @NumberDisplay.Format(item.FactQuantity) / @NumberDisplay.Format(item.PlannedQuantity)</span>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public DailyReportDto Report { get; set; } = default!;

    private string RatioLabel =>
        Report.Summary.ManDayRealizationRatio is { } ratio ? $"{NumberDisplay.Format(ratio * 100)}%" : "-";

    private static string UnitLabel(Unit unit) => unit switch
    {
        Unit.Ton => "ton",
        Unit.M3 => "m³",
        Unit.M2 => "m²",
        _ => "-"
    };

    private static string QuantityDeltaLabel(WorkItemQuantityKpiDto item)
    {
        var delta = item.FactQuantity - item.PlannedQuantity;
        if (delta == 0)
            return "Planla aynı";

        var direction = delta > 0 ? "Plan üstü" : "Plan altı";
        return $"{direction}: {NumberDisplay.Format(Math.Abs(delta))} {UnitLabel(item.Unit)}";
    }
}
