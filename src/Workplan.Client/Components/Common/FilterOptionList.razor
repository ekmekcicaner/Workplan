<div class="w-64 p-1">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <div class="mb-1.5 flex items-center justify-between gap-2 px-2 pt-1">
            <span class="text-xs font-bold uppercase tracking-wide text-foreground-subtle">@Label</span>
            @if (SelectedIds.Count > 0)
            {
                <button type="button" class="text-xs font-semibold text-brand-600 dark:text-brand-400" @onclick="ClearAsync">
                    Temizle
                </button>
            }
        </div>
    }

    @if (Options.Count > SearchThreshold)
    {
        <input class="input mb-1.5" placeholder="Ara..." value="@_query" @oninput="OnSearch" />
    }

    <div class="max-h-52 space-y-0.5 overflow-y-auto pr-1">
        @if (FilteredOptions.Count == 0)
        {
            <p class="px-2 py-2 text-sm text-foreground-muted">Seçenek yok.</p>
        }
        else
        {
            @foreach (var option in FilteredOptions)
            {
                var selected = SelectedIds.Contains(option.Id);
                <label @key="option.Id" class="menu-item cursor-pointer">
                    <input type="checkbox"
                           class="size-4"
                           checked="@selected"
                           @onchange="args => ToggleAsync(option.Id, args.Value)" />
                    <span class="truncate">@option.Label</span>
                </label>
            }
        }
    </div>
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<TrackingFilterOptionDto> Options { get; set; } = [];
    [Parameter, EditorRequired] public HashSet<Guid> SelectedIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedIdsChanged { get; set; }
    [Parameter] public int SearchThreshold { get; set; } = 8;

    private string _query = "";

    private IReadOnlyList<TrackingFilterOptionDto> FilteredOptions =>
        string.IsNullOrWhiteSpace(_query)
            ? Options
            : Options.Where(option => option.Label.Contains(_query, StringComparison.OrdinalIgnoreCase)).ToList();

    private Task OnSearch(ChangeEventArgs args)
    {
        _query = args.Value?.ToString() ?? "";
        return Task.CompletedTask;
    }

    private Task ToggleAsync(Guid id, object? value)
    {
        var next = new HashSet<Guid>(SelectedIds);
        if (value is true)
        {
            next.Add(id);
        }
        else
        {
            next.Remove(id);
        }

        return SelectedIdsChanged.InvokeAsync(next);
    }

    private Task ClearAsync() => SelectedIdsChanged.InvokeAsync([]);
}
