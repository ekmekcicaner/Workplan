<p class="access-note">
    <span aria-hidden="true"></span> Yalnızca: @string.Join(", ", RoleLabels)
</p>

@code {
    [Parameter, EditorRequired] public string Roles { get; set; } = "";

    private IEnumerable<string> RoleLabels =>
        Roles.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(Workplan.Client.Auth.Roles.DisplayName);
}
