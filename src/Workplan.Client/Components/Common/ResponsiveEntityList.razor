@typeparam TItem

<div class="responsive-list">
    <LoadingBlock Loading="Loading" ErrorText="@LoadError" />
    @if (!Loading && string.IsNullOrWhiteSpace(LoadError))
    {
        @if (Items.Count == 0)
        {
            <EmptyState Title="@EmptyTitle" Text="@EmptyText" />
        }
        else
        {
            <div class="hidden overflow-x-auto md:block">
                <table class="table-base">
                    <thead>
                        <tr>@HeaderRow</tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Items)
                        {
                            <tr @key="item">@DesktopRowTemplate(item)</tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="grid grid-cols-1 gap-3 md:hidden">
                @foreach (var item in Items)
                {
                    @MobileCardTemplate(item)
                }
            </div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<TItem> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? LoadError { get; set; }
    [Parameter] public string EmptyTitle { get; set; } = "Kayıt bulunamadı";
    [Parameter] public string? EmptyText { get; set; }
    [Parameter, EditorRequired] public RenderFragment HeaderRow { get; set; } = default!;
    [Parameter, EditorRequired] public RenderFragment<TItem> DesktopRowTemplate { get; set; } = default!;
    [Parameter, EditorRequired] public RenderFragment<TItem> MobileCardTemplate { get; set; } = default!;
}
