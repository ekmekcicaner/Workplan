@inject ThemeService Theme
@implements IDisposable

<div class="theme-switcher" role="radiogroup" aria-label="Tema">
    <button type="button"
            class="@ButtonClass(ThemeMode.Light)"
            title="Açık tema"
            aria-label="Açık tema"
            aria-checked="@(Theme.Mode == ThemeMode.Light)"
            role="radio"
            @onclick="() => SetModeAsync(ThemeMode.Light)">
        <Icon Name="sun" CssClass="h-4 w-4" />
    </button>
    <button type="button"
            class="@ButtonClass(ThemeMode.Dark)"
            title="Koyu tema"
            aria-label="Koyu tema"
            aria-checked="@(Theme.Mode == ThemeMode.Dark)"
            role="radio"
            @onclick="() => SetModeAsync(ThemeMode.Dark)">
        <Icon Name="moon" CssClass="h-4 w-4" />
    </button>
    <button type="button"
            class="@ButtonClass(ThemeMode.System)"
            title="Cihaz varsayılanı"
            aria-label="Cihaz varsayılanı"
            aria-checked="@(Theme.Mode == ThemeMode.System)"
            role="radio"
            @onclick="() => SetModeAsync(ThemeMode.System)">
        <Icon Name="monitor" CssClass="h-4 w-4" />
    </button>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Theme.Changed += OnThemeChanged;
            await Theme.InitializeAsync();
        }
    }

    private async Task SetModeAsync(ThemeMode mode) => await Theme.SetModeAsync(mode);

    private string ButtonClass(ThemeMode mode) =>
        Theme.Mode == mode ? "theme-option theme-option-active" : "theme-option";

    private async void OnThemeChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            await DispatchExceptionAsync(exception);
        }
    }

    public void Dispose()
    {
        Theme.Changed -= OnThemeChanged;
    }
}
