<header class="page-header">
    <div class="min-w-0">
        @if (!string.IsNullOrWhiteSpace(BackHref))
        {
            <a class="page-back-link" href="@BackHref">
                <Icon Name="chevron-left" CssClass="h-4 w-4" />@BackText
            </a>
        }
        <div class="flex flex-wrap items-center gap-2">
            <h1 class="page-title">@Title</h1>
            @Metadata
        </div>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <p class="page-subtitle">@Subtitle</p>
        }
    </div>
    @if (Actions is not null)
    {
        <div class="page-actions">
            @Actions
        </div>
    }
</header>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? BackHref { get; set; }
    [Parameter] public string BackText { get; set; } = "Geri";
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? Metadata { get; set; }
}
