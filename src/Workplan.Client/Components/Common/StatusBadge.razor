<WpBadge Tone="@Tone">@Label</WpBadge>

@code {
    [Parameter] public WorkStatus Status { get; set; }

    private string Label => Status switch
    {
        WorkStatus.Draft => "Taslak",
        WorkStatus.Assigned => "Atandı",
        WorkStatus.InProgress => "Devam Ediyor",
        WorkStatus.Submitted => $"{Roles.DisplayName(Roles.SiteChief)} Onayında",
        WorkStatus.ApprovedBySiteChief => $"{Roles.DisplayName(Roles.SiteChief)} Onayladı",
        WorkStatus.ApprovedByPM => "Tamamlandı",
        _ => Status.ToString()
    };

    private WpTone Tone => Status switch
    {
        WorkStatus.Assigned or WorkStatus.InProgress => WpTone.Warning,
        WorkStatus.Submitted => WpTone.Info,
        WorkStatus.ApprovedBySiteChief => WpTone.Brand,
        WorkStatus.ApprovedByPM => WpTone.Success,
        _ => WpTone.Neutral
    };
}
