@implements IDisposable
@inject ToastService Toasts

<div class="toast-host">
    @foreach (var toast in Toasts.Toasts)
    {
        <div class="toast @SeverityClass(toast.Severity)" role="alert" @onclick="() => Toasts.Remove(toast.Id)">
            @toast.Text
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        Toasts.Changed += StateHasChanged;
    }

    private static string SeverityClass(ToastSeverity severity) => severity switch
    {
        ToastSeverity.Success => "bg-green-600",
        ToastSeverity.Error => "bg-red-600",
        ToastSeverity.Warning => "bg-amber-500",
        _ => "bg-neutral-800"
    };

    public void Dispose()
    {
        Toasts.Changed -= StateHasChanged;
    }
}
