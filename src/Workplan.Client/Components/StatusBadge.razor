<span class="badge @ColorClass">@Label</span>

@code {
    [Parameter] public WorkStatus Status { get; set; }

    private string Label => Status switch
    {
        WorkStatus.Draft => "Taslak",
        WorkStatus.Assigned => "Atandı",
        WorkStatus.InProgress => "Devam Ediyor",
        WorkStatus.Submitted => "Site Chief Onayında",
        WorkStatus.ApprovedByHoM => "Usta Onayı (Eski)",
        WorkStatus.ApprovedBySiteChief => "Saha Şefi Onayladı",
        WorkStatus.ApprovedByPM => "Tamamlandı",
        WorkStatus.Reported => "Raporlandı",
        _ => Status.ToString()
    };

    private string ColorClass => Status switch
    {
        WorkStatus.Draft => "!bg-neutral-100 !text-neutral-700 dark:!bg-neutral-700 dark:!text-neutral-200",
        WorkStatus.Assigned or WorkStatus.InProgress =>
            "!bg-amber-100 !text-amber-800 dark:!bg-amber-900/40 dark:!text-amber-300",
        WorkStatus.Submitted => "!bg-blue-100 !text-blue-800 dark:!bg-blue-900/40 dark:!text-blue-300",
        WorkStatus.ApprovedByHoM or WorkStatus.ApprovedBySiteChief =>
            "!bg-indigo-100 !text-indigo-800 dark:!bg-indigo-900/40 dark:!text-indigo-300",
        WorkStatus.ApprovedByPM or WorkStatus.Reported =>
            "!bg-green-100 !text-green-800 dark:!bg-green-900/40 dark:!text-green-300",
        _ => ""
    };
}
