@typeparam TItem

<div class="card overflow-x-auto p-0">
    <LoadingBlock Loading="Loading" ErrorText="@LoadError" />
    @if (!Loading && string.IsNullOrWhiteSpace(LoadError))
    {
        @if (Items.Count == 0)
        {
            <p class="p-4 text-sm text-slate-500 dark:text-slate-400">@EmptyText</p>
        }
        else
        {
            <table class="table-base table-responsive">
                <thead>
                    <tr>@HeaderRow</tr>
                </thead>
                <tbody>
                    @foreach (var item in Items)
                    {
                        <tr>@RowTemplate(item)</tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<TItem> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? LoadError { get; set; }
    [Parameter] public string EmptyText { get; set; } = "Kayıt bulunamadı.";
    [Parameter, EditorRequired] public RenderFragment HeaderRow { get; set; } = default!;
    [Parameter, EditorRequired] public RenderFragment<TItem> RowTemplate { get; set; } = default!;
}
