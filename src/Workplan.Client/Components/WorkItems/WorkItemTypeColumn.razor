@inject WorkItemTypesApiService WorkItemTypesApi
@inject ConfirmService Confirm
@inject ToastService Toast

<div class="card flex h-full flex-col">
    <div class="mb-3 flex items-center justify-between">
        <h3 class="font-semibold">@Title</h3>
        <span class="badge">@Items.Count</span>
    </div>

    @if (Locked)
    {
        <p class="text-sm text-foreground-muted">@LockedMessage</p>
    }
    else
    {
        @if (Items.Count == 0)
        {
            <p class="mb-3 text-sm text-foreground-muted">Henüz kayıt yok.</p>
        }
        else
        {
            <ul class="mb-3 flex flex-col gap-1">
                @foreach (var item in Items)
                {
                    <li @key="item.Id">
                        <div class="flex items-center justify-between gap-2 rounded-md px-2 py-1.5 @(Selectable && item.Id == SelectedId ? "bg-brand-500/10 text-brand-700 ring-1 ring-brand-500/40 dark:bg-brand-500/15 dark:text-brand-400" : "hover:bg-surface-muted")">
                            <button type="button"
                                    class="flex min-w-0 flex-1 items-center gap-2 text-left text-sm disabled:cursor-default"
                                    disabled="@(!Selectable)"
                                    @onclick="() => Select(item.Id)">
                                <span class="truncate @(item.IsActive ? "" : "opacity-60")">@item.Name</span>
                                @if (RequireUnit)
                                {
                                    <span class="badge shrink-0">@UnitLabel(item.Unit)</span>
                                }
                                @if (!item.IsActive)
                                {
                                    <WpBadge Tone="WpTone.Danger" CssClass="shrink-0">Pasif</WpBadge>
                                }
                            </button>

                            <div class="flex shrink-0 items-center gap-1">
                                @if (Selectable && item.Id == SelectedId)
                                {
                                    <span class="text-xs">&rarr;</span>
                                }
                                <AuthorizeView Roles="@Roles.Administration" Context="rowAuth">
                                    <Authorized>
                                        <WpPopover Open="_openMenuId == item.Id" OpenChanged="v => SetMenuOpen(item.Id, v)">
                                            <Trigger>
                                                <button type="button" class="icon-button" aria-label="İşlemler">
                                                    <Icon Name="more-vertical" CssClass="h-4 w-4" />
                                                </button>
                                            </Trigger>
                                            <ChildContent>
                                                <div class="w-40 p-1">
                                                    <button type="button" class="menu-item" @onclick="() => EditAsync(item)">
                                                        <Icon Name="edit" CssClass="h-4 w-4" />Düzenle
                                                    </button>
                                                    @if (item.IsActive)
                                                    {
                                                        <button type="button" class="menu-item menu-item-danger" @onclick="() => ConfirmSetActiveAsync(item, false)">
                                                            <Icon Name="x" CssClass="h-4 w-4" />Pasif Yap
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="menu-item" @onclick="() => ConfirmSetActiveAsync(item, true)">
                                                            <Icon Name="check" CssClass="h-4 w-4" />Aktif Yap
                                                        </button>
                                                    }
                                                </div>
                                            </ChildContent>
                                        </WpPopover>
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        </div>
                    </li>
                }
            </ul>
        }

        <AuthorizeView Roles="@Roles.Administration" Context="createAuth">
            <Authorized>
                <button type="button" class="btn-ghost mt-auto w-full justify-center border-t border-border pt-3" @onclick="() => _formModal?.OpenCreate(ParentId)">
                    <Icon Name="plus" CssClass="h-4 w-4" />@Title ekle
                </button>
            </Authorized>
        </AuthorizeView>
    }
</div>

<WorkItemTypeFormModal @ref="_formModal" EntityLabel="@Title" RequireUnit="RequireUnit" OnSaved="OnChanged" />

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<WorkItemTypeDto> Items { get; set; } = [];
    [Parameter] public Guid? SelectedId { get; set; }
    [Parameter] public EventCallback<Guid> OnSelect { get; set; }
    [Parameter] public bool Selectable { get; set; } = true;
    [Parameter] public bool Locked { get; set; }
    [Parameter] public string? LockedMessage { get; set; }
    [Parameter] public Guid? ParentId { get; set; }
    [Parameter] public bool RequireUnit { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private WorkItemTypeFormModal? _formModal;
    private Guid? _openMenuId;

    private static string UnitLabel(WorkUnit unit) => unit switch
    {
        WorkUnit.Ton => "Ton",
        WorkUnit.M3 => "m³",
        WorkUnit.M2 => "m²",
        _ => "-",
    };

    private async Task Select(Guid id)
    {
        if (!Selectable) return;
        await OnSelect.InvokeAsync(id);
    }

    private void SetMenuOpen(Guid itemId, bool open)
    {
        _openMenuId = open ? itemId : null;
    }

    private void EditAsync(WorkItemTypeDto item)
    {
        _openMenuId = null;
        _formModal?.OpenEdit(item);
    }

    private async Task ConfirmSetActiveAsync(WorkItemTypeDto item, bool isActive)
    {
        _openMenuId = null;
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            $"{Title} Durumunu Güncelle", $"\"{item.Name}\" öğesini {action} yapmak istediğinize emin misiniz?", danger: !isActive);
        if (!confirmed) return;

        var result = await WorkItemTypesApi.SetActiveAsync(item.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"{Title} {action} yapıldı.");
            await OnChanged.InvokeAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }
}
