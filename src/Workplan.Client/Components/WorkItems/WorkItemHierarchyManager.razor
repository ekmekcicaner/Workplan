@inject WorkItemTypesApiService WorkItemTypesApi
@inject ConfirmService Confirm
@inject ToastService Toast

<div class="space-y-3">
    <div class="flex flex-wrap items-center justify-between gap-2">
        <div class="flex flex-wrap gap-2 text-xs font-semibold text-neutral-500 dark:text-neutral-400">
            <span class="rounded-full bg-neutral-100 px-2.5 py-1 dark:bg-neutral-800">Tip</span>
            <span class="rounded-full bg-neutral-100 px-2.5 py-1 dark:bg-neutral-800">Alt Tip</span>
            <span class="rounded-full bg-neutral-100 px-2.5 py-1 dark:bg-neutral-800">Alt-Alt Tip</span>
        </div>
        @if (SelectedTip is not null)
        {
            <button type="button" class="btn-ghost" @onclick="ClearSelection">
                <Icon Name="close" CssClass="h-4 w-4" />Seçimi temizle
            </button>
        }
    </div>

    <div class="hidden grid-cols-3 gap-3 md:grid">
        @RenderColumn("Tip", Tips, _selectedTipId, false, null, 0, null, false)
        @RenderColumn("Alt Tip", AltTips, _selectedAltTipId, SelectedTip is null, "Alt tipleri görmek için önce bir Tip seçin.", 1, _selectedTipId, false)
        @RenderColumn("Alt-Alt Tip", AltAltTips, _selectedLeafId, SelectedAltTip is null, "Alt-alt tipleri görmek için önce bir Alt Tip seçin.", 2, _selectedAltTipId, true)
    </div>

    <div class="space-y-3 md:hidden">
        <div class="flex items-center gap-2 overflow-x-auto pb-1">
            <button type="button" class="@MobileStepClass(0)" @onclick="() => GoToMobileLevel(0)">Tip</button>
            <button type="button" class="@MobileStepClass(1)" disabled="@(SelectedTip is null)" @onclick="() => GoToMobileLevel(1)">Alt Tip</button>
            <button type="button" class="@MobileStepClass(2)" disabled="@(SelectedAltTip is null)" @onclick="() => GoToMobileLevel(2)">Alt-Alt Tip</button>
        </div>

        @if (_mobileLevel == 0)
        {
            @RenderColumn("Tip", Tips, _selectedTipId, false, null, 0, null, false)
        }
        else if (_mobileLevel == 1)
        {
            @RenderColumn("Alt Tip", AltTips, _selectedAltTipId, SelectedTip is null, "Alt tipleri görmek için önce bir Tip seçin.", 1, _selectedTipId, false)
        }
        else
        {
            @RenderColumn("Alt-Alt Tip", AltAltTips, _selectedLeafId, SelectedAltTip is null, "Alt-alt tipleri görmek için önce bir Alt Tip seçin.", 2, _selectedAltTipId, true)
        }
    </div>
</div>

<DetailPanel Show="_detailItem is not null"
             Title="@(_detailItem?.Name ?? "")"
             Subtitle="@DetailSubtitle"
             OnClose="CloseDetail">
    @if (_detailItem is not null)
    {
        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3 text-sm">
                <div>
                    <p class="field-label">Seviye</p>
                    <p class="font-medium">@LevelLabel(_detailItem.Level)</p>
                </div>
                <div>
                    <p class="field-label">Durum</p>
                    <span class="badge @(_detailItem.IsActive ? "" : "!bg-red-100 !text-red-700 dark:!bg-red-900/40 dark:!text-red-300")">
                        @(_detailItem.IsActive ? "Aktif" : "Pasif")
                    </span>
                </div>
                @if (_detailItem.Level == 2)
                {
                    <div>
                        <p class="field-label">Birim</p>
                        <p class="font-medium">@UnitLabel(_detailItem.Unit)</p>
                    </div>
                }
                <div>
                    <p class="field-label">Alt kayıt</p>
                    <p class="font-medium">@_detailItem.Children.Count</p>
                </div>
            </div>

            <div class="rounded-lg border border-neutral-200 bg-neutral-50 p-3 dark:border-neutral-800 dark:bg-neutral-950">
                <h3 class="mb-3 text-sm font-semibold">Düzenle</h3>
                <div class="space-y-3">
                    <div>
                        <label class="field-label">Ad</label>
                        <input class="input" @bind="_editName" @bind:event="oninput" />
                    </div>
                    @if (_detailItem.Level == 2)
                    {
                        <div>
                            <label class="field-label">Birim</label>
                            <select class="input" @bind="_editUnit">
                                <option value="@WorkUnit.None" disabled>Birim seçin</option>
                                <option value="@WorkUnit.Ton">Ton</option>
                                <option value="@WorkUnit.M3">m³</option>
                                <option value="@WorkUnit.M2">m²</option>
                            </select>
                        </div>
                    }
                    <button type="button" class="btn-primary w-full" disabled="@(!CanUpdateDetail)" @onclick="ConfirmRenameAsync">
                        <Icon Name="check" CssClass="h-4 w-4" />Kaydet
                    </button>
                </div>
            </div>

            <div class="rounded-lg border border-red-200 bg-red-50 p-3 dark:border-red-900/50 dark:bg-red-950/20">
                <h3 class="mb-1 text-sm font-semibold text-red-800 dark:text-red-300">Durum işlemi</h3>
                <p class="mb-3 text-sm text-red-700 dark:text-red-300">Kayıt geçmişi silinmez; yalnızca kullanılabilirlik durumu değişir.</p>
                <button type="button"
                        class="@(_detailItem.IsActive ? "btn-danger" : "btn-secondary") w-full"
                        @onclick="() => ConfirmSetActiveAsync(_detailItem, !_detailItem.IsActive)">
                    @(_detailItem.IsActive ? "Pasif Yap" : "Aktif Yap")
                </button>
            </div>
        </div>
    }
</DetailPanel>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<WorkItemTypeDto> Tree { get; set; } = [];
    [Parameter] public EventCallback OnChanged { get; set; }

    private Guid? _selectedTipId;
    private Guid? _selectedAltTipId;
    private Guid? _selectedLeafId;
    private int _mobileLevel;
    private WorkItemTypeDto? _detailItem;
    private string _editName = "";
    private WorkUnit _editUnit = WorkUnit.None;

    private string _newTipName = "";
    private string _newAltTipName = "";
    private string _newLeafName = "";
    private WorkUnit _newLeafUnit = WorkUnit.None;
    private bool _creating;

    private List<WorkItemTypeDto> Tips => Sort(Tree);
    private WorkItemTypeDto? SelectedTip => Tree.FirstOrDefault(t => t.Id == _selectedTipId);
    private List<WorkItemTypeDto> AltTips => Sort(SelectedTip?.Children ?? []);
    private WorkItemTypeDto? SelectedAltTip => AltTips.FirstOrDefault(t => t.Id == _selectedAltTipId);
    private List<WorkItemTypeDto> AltAltTips => Sort(SelectedAltTip?.Children ?? []);

    private string DetailSubtitle => _detailItem is null
        ? ""
        : $"{LevelLabel(_detailItem.Level)} · {(_detailItem.IsActive ? "Aktif" : "Pasif")}";

    private bool CanUpdateDetail =>
        _detailItem is not null &&
        !string.IsNullOrWhiteSpace(_editName) &&
        (_detailItem.Level != 2 || _editUnit != WorkUnit.None);

    private RenderFragment RenderColumn(
        string title,
        IReadOnlyList<WorkItemTypeDto> items,
        Guid? selectedId,
        bool locked,
        string? lockedMessage,
        int level,
        Guid? parentId,
        bool requireUnit) => @<section class="surface-panel flex min-h-[22rem] flex-col overflow-hidden">
        <header class="flex items-center justify-between gap-3 border-b border-neutral-200 px-3 py-3 dark:border-neutral-800">
            <h2 class="text-sm font-semibold">@title</h2>
            <span class="badge">@items.Count</span>
        </header>
        @if (locked)
        {
            <div class="p-3">
                <EmptyState Icon="layers" Title="Seçim bekleniyor" Text="@lockedMessage" />
            </div>
        }
        else
        {
            <div class="min-h-0 flex-1 overflow-y-auto p-2">
                @if (items.Count == 0)
                {
                    <EmptyState Icon="layers" Title="Henüz kayıt yok" Text="Bu seviyede aktif kayıt bulunmuyor." />
                }
                else
                {
                    <ul class="space-y-1">
                        @foreach (var item in items)
                        {
                            var selected = item.Id == selectedId;
                            <li @key="item.Id">
                                <button type="button"
                                        class="list-row @(selected ? "list-row-selected" : "")"
                                        @onclick="() => SelectItem(level, item)">
                                    <span class="min-w-0 flex-1">
                                        <span class="block truncate font-semibold @(item.IsActive ? "" : "text-neutral-400 line-through")">@item.Name</span>
                                        <span class="mt-0.5 flex flex-wrap items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400">
                                            @if (requireUnit)
                                            {
                                                <span>@UnitLabel(item.Unit)</span>
                                            }
                                            @if (!item.IsActive)
                                            {
                                                <span class="text-red-600 dark:text-red-300">Pasif</span>
                                            }
                                            @if (item.Children.Count > 0)
                                            {
                                                <span>@item.Children.Count alt kayıt</span>
                                            }
                                        </span>
                                    </span>
                                    <Icon Name="chevron-right" CssClass="h-4 w-4 shrink-0 text-neutral-400" />
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>

            <AuthorizeView Roles="SystemAdmin,TechnicalOfficeEngineer" Context="createAuth">
                <Authorized>
                    <div class="border-t border-neutral-200 p-3 dark:border-neutral-800">
                        <div class="space-y-2">
                            <input class="input"
                                   placeholder="@($"{title} adı")"
                                   value="@NewName(level)"
                                   @oninput="@((ChangeEventArgs args) => SetNewName(level, args.Value?.ToString() ?? ""))"
                                   @onkeyup="@((KeyboardEventArgs args) => OnNewNameKeyUp(args, level, parentId, requireUnit))" />
                            @if (requireUnit)
                            {
                                <select class="input" @bind="_newLeafUnit">
                                    <option value="@WorkUnit.None" disabled>Birim seçin</option>
                                    <option value="@WorkUnit.Ton">Ton</option>
                                    <option value="@WorkUnit.M3">m³</option>
                                    <option value="@WorkUnit.M2">m²</option>
                                </select>
                            }
                            <button type="button" class="btn-primary w-full" disabled="@(!CanCreate(level, requireUnit))" @onclick="() => CreateAsync(level, parentId, requireUnit)">
                                <Icon Name="plus" CssClass="h-4 w-4" />Ekle
                            </button>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        }
    </section>;

    private void SelectItem(int level, WorkItemTypeDto item)
    {
        if (level == 0)
        {
            _selectedTipId = _selectedTipId == item.Id ? null : item.Id;
            _selectedAltTipId = null;
            _selectedLeafId = null;
            _mobileLevel = _selectedTipId is null ? 0 : 1;
        }
        else if (level == 1)
        {
            _selectedAltTipId = _selectedAltTipId == item.Id ? null : item.Id;
            _selectedLeafId = null;
            _mobileLevel = _selectedAltTipId is null ? 1 : 2;
        }
        else
        {
            _selectedLeafId = _selectedLeafId == item.Id ? null : item.Id;
        }

        OpenDetail(item);
    }

    private void OpenDetail(WorkItemTypeDto item)
    {
        _detailItem = item;
        _editName = item.Name;
        _editUnit = item.Unit;
    }

    private void CloseDetail() => _detailItem = null;

    private void ClearSelection()
    {
        _selectedTipId = null;
        _selectedAltTipId = null;
        _selectedLeafId = null;
        _mobileLevel = 0;
        _detailItem = null;
    }

    private void GoToMobileLevel(int level)
    {
        _mobileLevel = level;
        if (level == 0)
        {
            _selectedAltTipId = null;
            _selectedLeafId = null;
        }
        else if (level == 1)
        {
            _selectedLeafId = null;
        }
    }

    private string MobileStepClass(int level) =>
        $"segment-item {(_mobileLevel == level ? "segment-item-active" : "")}";

    private string NewName(int level) => level switch
    {
        0 => _newTipName,
        1 => _newAltTipName,
        _ => _newLeafName
    };

    private void SetNewName(int level, string value)
    {
        if (level == 0) _newTipName = value;
        else if (level == 1) _newAltTipName = value;
        else _newLeafName = value;
    }

    private bool CanCreate(int level, bool requireUnit) =>
        !_creating &&
        !string.IsNullOrWhiteSpace(NewName(level)) &&
        (!requireUnit || _newLeafUnit != WorkUnit.None);

    private async Task OnNewNameKeyUp(KeyboardEventArgs args, int level, Guid? parentId, bool requireUnit)
    {
        if (args.Key == "Enter" && CanCreate(level, requireUnit))
        {
            await CreateAsync(level, parentId, requireUnit);
        }
    }

    private async Task CreateAsync(int level, Guid? parentId, bool requireUnit)
    {
        var name = NewName(level).Trim();
        if (string.IsNullOrWhiteSpace(name)) return;

        var title = LevelLabel(level);
        var confirmed = await Confirm.ConfirmAsync($"{title} ekle", $"\"{name}\" kaydını eklemek istediğinize emin misiniz?");
        if (!confirmed) return;

        _creating = true;
        var result = await WorkItemTypesApi.CreateAsync(new CreateWorkItemTypeRequest(name, parentId, requireUnit ? _newLeafUnit : WorkUnit.None));
        if (result.Success)
        {
            Toast.Success($"{title} eklendi.");
            SetNewName(level, "");
            if (level == 2) _newLeafUnit = WorkUnit.None;
            await OnChanged.InvokeAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? $"{title} eklenemedi.");
        }
        _creating = false;
    }

    private async Task ConfirmRenameAsync()
    {
        if (_detailItem is null) return;
        var name = _editName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;

        var confirmed = await Confirm.ConfirmAsync(
            $"{LevelLabel(_detailItem.Level)} güncelle",
            $"\"{_detailItem.Name}\" adını \"{name}\" olarak değiştirmek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await WorkItemTypesApi.UpdateAsync(_detailItem.Id, new UpdateWorkItemTypeRequest(name, _detailItem.Level == 2 ? _editUnit : WorkUnit.None));
        if (result.Success)
        {
            Toast.Success("İş kalemi güncellendi.");
            _detailItem = null;
            await OnChanged.InvokeAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İş kalemi güncellenemedi.");
        }
    }

    private async Task ConfirmSetActiveAsync(WorkItemTypeDto item, bool isActive)
    {
        var action = isActive ? "aktif" : "pasif";
        var confirmed = await Confirm.ConfirmAsync(
            "Durumu güncelle",
            $"\"{item.Name}\" kaydını {action} yapmak istediğinize emin misiniz?",
            danger: !isActive);
        if (!confirmed) return;

        var result = await WorkItemTypesApi.SetActiveAsync(item.Id, isActive);
        if (result.Success)
        {
            Toast.Success($"Kayıt {action} yapıldı.");
            _detailItem = null;
            await OnChanged.InvokeAsync();
        }
        else
        {
            Toast.Error(result.ErrorMessage ?? "İşlem başarısız oldu.");
        }
    }

    private static List<WorkItemTypeDto> Sort(IReadOnlyCollection<WorkItemTypeDto> items) =>
        items.OrderBy(i => !i.IsActive).ThenBy(i => i.Name, StringComparer.CurrentCultureIgnoreCase).ToList();

    private static string LevelLabel(int level) => level switch
    {
        0 => "Tip",
        1 => "Alt Tip",
        _ => "Alt-Alt Tip"
    };

    private static string UnitLabel(WorkUnit unit) => unit switch
    {
        WorkUnit.Ton => "Ton",
        WorkUnit.M3 => "m³",
        WorkUnit.M2 => "m²",
        _ => "-"
    };
}
