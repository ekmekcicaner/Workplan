<article class="rounded-panel border border-border bg-surface p-4 shadow-panel @CssClass">
    <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
            <p class="text-xs font-bold uppercase tracking-wide text-foreground-muted">@Label</p>
            <p class="mt-2 text-2xl font-bold tracking-tight text-foreground">@Value</p>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="mt-1 text-xs text-foreground-muted">@Description</p>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Icon))
        {
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-control bg-brand-50 text-brand-700 dark:bg-brand-950/60 dark:text-brand-300">
                <Icon Name="@Icon" />
            </span>
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? CssClass { get; set; }
}
