<div class="wp-data-pager">
    <span>@TotalItems kayıt · Sayfa @(State.CurrentPageIndex + 1) / @PageCount</span>
    <div class="flex items-center gap-1.5">
        <button type="button" class="btn-ghost btn-sm" disabled="@(State.CurrentPageIndex == 0)" @onclick="PreviousAsync">
            <Icon Name="chevron-left" CssClass="h-4 w-4" />Önceki
        </button>
        <button type="button" class="btn-ghost btn-sm" disabled="@(State.CurrentPageIndex >= PageCount - 1)" @onclick="NextAsync">
            Sonraki<Icon Name="chevron-right" CssClass="h-4 w-4" />
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PaginationState State { get; set; } = default!;
    [Parameter] public int TotalItems { get; set; }

    private int PageCount => Math.Max(1, (int)Math.Ceiling(TotalItems / (double)State.ItemsPerPage));
    private Task PreviousAsync() => State.SetCurrentPageIndexAsync(Math.Max(0, State.CurrentPageIndex - 1));
    private Task NextAsync() => State.SetCurrentPageIndexAsync(Math.Min(PageCount - 1, State.CurrentPageIndex + 1));
}
