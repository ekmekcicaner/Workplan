<nav class="flex flex-col gap-4 text-sm">
    <div class="flex flex-col gap-1">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="Navigated">
            <Icon Name="home" />Ana Sayfa
        </NavLink>
    </div>

    <div>
        <p class="nav-section-label">Operasyon</p>
        <div class="flex flex-col gap-1">
            <AuthorizeView Roles="@Roles.Administration">
                <Authorized>
                    <NavLink class="nav-link" href="daily-plans/new" @onclick="Navigated">
                        <Icon Name="clipboard" />Günlük Plan Oluştur
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="@Roles.Tracking">
                <Authorized>
                    <NavLink class="nav-link" href="daily-tracking" @onclick="Navigated">
                        <Icon Name="calendar" />Günlük İş Takibi
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="@Roles.HeadOfMaster">
                <Authorized>
                    <NavLink class="nav-link" href="my-work" @onclick="Navigated">
                        <Icon Name="clipboard" />Bana Atanan İşler
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="@Roles.Approval">
                <Authorized>
                    <NavLink class="nav-link" href="approvals" @onclick="Navigated">
                        <Icon Name="check-circle" />Beklenen Onaylar
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="@Roles.Reporting">
                <Authorized>
                    <NavLink class="nav-link" href="reports" @onclick="Navigated">
                        <Icon Name="bar-chart" />Raporlar
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <div>
        <p class="nav-section-label">Saha Yapısı</p>
        <div class="flex flex-col gap-1">
            <NavLink class="nav-link" href="projects" @onclick="Navigated">
                <Icon Name="folder" />Projeler
            </NavLink>
            <AuthorizeView Roles="@Roles.Administration">
                <Authorized>
                    <NavLink class="nav-link" href="crews" @onclick="Navigated">
                        <Icon Name="hard-hat" />Ekip Tipleri
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <NavLink class="nav-link" href="work-item-types" @onclick="Navigated">
                <Icon Name="layers" />İş Kalemi Tipleri
            </NavLink>
        </div>
    </div>

    <AuthorizeView Roles="@Roles.SystemAdmin">
        <Authorized>
            <div>
                <p class="nav-section-label">Yönetim</p>
                <div class="flex flex-col gap-1">
                    <NavLink class="nav-link" href="user-management" @onclick="Navigated">
                        <Icon Name="users" />Kullanıcı Yönetimi
                    </NavLink>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>
</nav>

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }

    private Task Navigated() => OnNavigate.InvokeAsync();
}
