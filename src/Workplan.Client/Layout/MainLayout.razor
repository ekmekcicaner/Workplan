@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject Workplan.Client.Auth.LocalStorageService LocalStorage
@inject Workplan.Client.Auth.JwtAuthenticationStateProvider AuthStateProvider
@inject AuthApiService AuthApi
@inject ThemeService Theme

<div class="min-h-screen bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100">
    <header class="sticky top-0 z-20 bg-neutral-950 text-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-2 px-4 py-2.5">
            <a href="/" class="flex items-center gap-2">
                <span class="flex h-8 w-8 items-center justify-center rounded-md bg-brand-500 text-sm font-bold text-neutral-950">W</span>
                <span class="text-lg font-semibold">Workplan</span>
            </a>
            <div class="flex items-center gap-2">
                <button class="flex h-10 w-10 items-center justify-center rounded-lg text-neutral-300 hover:bg-white/10 hover:text-white" @onclick="ToggleThemeAsync" title="Tema değiştir" aria-label="Tema değiştir">
                    <Icon Name="@(Theme.IsDark ? "sun" : "moon")" />
                </button>
                <AuthorizeView>
                    <Authorized>
                        <button class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white hover:bg-white/20" @onclick="() => _showAccountMenu = true" aria-label="Hesap menüsü">
                            @Initials(context.User.FindFirst(ClaimTypes.Email)?.Value)
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <a class="btn-primary" href="/login">Giriş yap</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <div class="mx-auto flex max-w-6xl gap-6 px-4 py-6">
        <AuthorizeView>
            <Authorized>
                <aside class="hidden md:block md:w-56 md:shrink-0">
                    <NavMenu />
                </aside>
            </Authorized>
        </AuthorizeView>
        <main class="min-w-0 flex-1 pb-20 md:pb-6">
            @Body
        </main>
    </div>

    <AuthorizeView>
        <Authorized>
            <BottomNav />
        </Authorized>
    </AuthorizeView>
</div>

<AuthorizeView>
    <Authorized>
        <Modal Show="_showAccountMenu" Title="Hesap" OnClose="() => _showAccountMenu = false">
            <p class="mb-4 text-sm text-neutral-600 dark:text-neutral-300">@context.User.FindFirst(ClaimTypes.Email)?.Value</p>
            <button class="btn-secondary w-full" @onclick="LogoutAsync">
                <Icon Name="log-out" CssClass="h-5 w-5" />Çıkış yap
            </button>
        </Modal>
    </Authorized>
</AuthorizeView>

<ToastHost />
<ConfirmModal />

@code {
    private bool _showAccountMenu;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Theme.Changed += StateHasChanged;
            await Theme.InitializeAsync();
            StateHasChanged();
        }
    }

    private async Task ToggleThemeAsync() => await Theme.ToggleAsync();

    private static string Initials(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return "?";
        var name = email.Split('@')[0];
        return name.Length >= 2 ? name[..2].ToUpperInvariant() : name.ToUpperInvariant();
    }

    private async Task LogoutAsync()
    {
        _showAccountMenu = false;

        var refreshToken = await LocalStorage.GetAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.RefreshTokenKey);
        if (!string.IsNullOrEmpty(refreshToken))
        {
            await AuthApi.RevokeAsync(new RevokeRequest(refreshToken));
        }

        await LocalStorage.RemoveAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.AccessTokenKey);
        await LocalStorage.RemoveAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.RefreshTokenKey);
        AuthStateProvider.NotifyUserLogout();
        Navigation.NavigateTo("/login");
    }
}
