@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject Workplan.Client.Auth.LocalStorageService LocalStorage
@inject Workplan.Client.Auth.JwtAuthenticationStateProvider AuthStateProvider
@inject AuthApiService AuthApi
@inject ConnectivityService Connectivity
@implements IDisposable

<div class="min-h-screen bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100">
    <header class="sticky top-0 z-20 border-b border-neutral-200 bg-white/95 backdrop-blur dark:border-neutral-800 dark:bg-neutral-950/95">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-2 px-4 py-2.5">
            <a href="/" class="flex items-center gap-2">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-500 text-sm font-bold text-neutral-950">W</span>
                <span class="text-lg font-semibold text-neutral-950 dark:text-white">Workplan</span>
            </a>
            <div class="flex items-center gap-2">
                <span class="hidden items-center gap-1 rounded-full border px-2.5 py-1 text-xs font-semibold sm:inline-flex @(Connectivity.IsOnline ? "border-green-200 bg-green-50 text-green-700 dark:border-green-900/60 dark:bg-green-950/30 dark:text-green-300" : "border-amber-200 bg-amber-50 text-amber-800 dark:border-amber-900/60 dark:bg-amber-950/30 dark:text-amber-300")">
                    <span class="h-1.5 w-1.5 rounded-full @(Connectivity.IsOnline ? "bg-green-500" : "bg-amber-500")"></span>
                    @(Connectivity.IsOnline ? "Online" : "Offline")
                </span>
                <ThemeModeSelector />
                <AuthorizeView>
                    <Authorized>
                        <button class="flex min-w-0 items-center gap-2 rounded-full bg-neutral-100 py-1.5 pr-2.5 pl-1.5 text-left hover:bg-neutral-200 dark:bg-neutral-800 dark:hover:bg-neutral-700" @onclick="() => _showAccountMenu = true" aria-label="Hesap menüsü">
                            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white text-xs font-semibold text-neutral-700 dark:bg-neutral-900 dark:text-neutral-100">
                                @Initials(context.User)
                            </span>
                            <span class="hidden min-w-0 flex-col sm:flex">
                                <span class="max-w-36 truncate text-sm font-semibold leading-4 text-neutral-800 dark:text-neutral-100">@UserDisplayName(context.User)</span>
                                <span class="max-w-36 truncate text-xs leading-4 text-neutral-500 dark:text-neutral-400">@UserTitle(context.User)</span>
                            </span>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <a class="btn-primary" href="/login">Giriş yap</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <div class="mx-auto flex max-w-7xl gap-6 px-4 py-5 md:py-6">
        <AuthorizeView>
            <Authorized>
                <aside class="hidden md:block md:w-56 md:shrink-0">
                    <NavMenu />
                </aside>
            </Authorized>
        </AuthorizeView>
        <main class="min-w-0 flex-1 pb-20 md:pb-6">
            @if (!Connectivity.IsOnline)
            {
                <div class="mb-4">
                    <InlineNotice Tone="warning"
                                  Title="Bağlantı yok"
                                  Text="Uygulama kabuğu açık kalır, ancak kayıt gönderme ve onay işlemleri çevrimiçi olana kadar kapalıdır." />
                </div>
            }
            @Body
        </main>
    </div>

    <AuthorizeView>
        <Authorized>
            <BottomNav />
        </Authorized>
    </AuthorizeView>
</div>

<AuthorizeView>
    <Authorized>
        <Modal Show="_showAccountMenu" Title="Hesap" OnClose="() => _showAccountMenu = false">
            <div class="mb-4">
                <p class="text-sm font-semibold text-neutral-900 dark:text-neutral-100">@UserDisplayName(context.User)</p>
                <p class="text-sm text-neutral-600 dark:text-neutral-300">@UserTitle(context.User)</p>
                <p class="mt-1 text-xs text-neutral-500 dark:text-neutral-400">@context.User.FindFirst(ClaimTypes.Email)?.Value</p>
            </div>
            <button class="btn-secondary w-full" @onclick="LogoutAsync">
                <Icon Name="log-out" CssClass="h-5 w-5" />Çıkış yap
            </button>
        </Modal>
    </Authorized>
</AuthorizeView>

<ToastHost />
<ConfirmModal />

@code {
    private bool _showAccountMenu;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Connectivity.Changed += OnConnectivityChanged;
            await Connectivity.InitializeAsync();
            StateHasChanged();
        }
    }

    private void OnConnectivityChanged() => _ = InvokeAsync(StateHasChanged);

    private static string UserDisplayName(ClaimsPrincipal user)
    {
        return user.FindFirst("full_name")?.Value
            ?? user.FindFirst(ClaimTypes.Email)?.Value
            ?? "Kullanıcı";
    }

    private static string UserTitle(ClaimsPrincipal user)
    {
        var titles = user.FindAll(ClaimTypes.Role)
            .Select(claim => RoleLabel(claim.Value))
            .Distinct()
            .ToList();

        return titles.Count > 0 ? string.Join(", ", titles) : "Kullanıcı";
    }

    private static string Initials(ClaimsPrincipal user)
    {
        var displayName = UserDisplayName(user);
        if (string.IsNullOrWhiteSpace(displayName)) return "?";

        var words = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length >= 2)
        {
            return $"{words[0][0]}{words[^1][0]}".ToUpperInvariant();
        }

        var name = displayName.Split('@')[0];
        return name.Length >= 2 ? name[..2].ToUpperInvariant() : name.ToUpperInvariant();
    }

    private static string RoleLabel(string role) => role switch
    {
        "SystemAdmin" => "Sistem Admin",
        "TechnicalOfficeEngineer" => "Teknik Ofis",
        "HeadOfMaster" => "Ustabaşı",
        "SiteChief" => "Şantiye Şefi",
        "ProjectManager" => "Proje Yöneticisi",
        _ => role
    };

    private async Task LogoutAsync()
    {
        _showAccountMenu = false;

        var refreshToken = await LocalStorage.GetAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.RefreshTokenKey);
        if (!string.IsNullOrEmpty(refreshToken))
        {
            await AuthApi.RevokeAsync(new RevokeRequest(refreshToken));
        }

        await LocalStorage.RemoveAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.AccessTokenKey);
        await LocalStorage.RemoveAsync(Workplan.Client.Auth.JwtAuthenticationStateProvider.RefreshTokenKey);
        AuthStateProvider.NotifyUserLogout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        Connectivity.Changed -= OnConnectivityChanged;
    }
}
