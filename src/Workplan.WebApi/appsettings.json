{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5276",
      "http://localhost:5277"
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5434;Database=workplan;Username=postgres;Password=postgres"
  },
  "Outbox": {
    "PollIntervalSeconds": 2,
    "BatchSize": 20,
    "MaxRetryCount": 8,
    "BaseRetryDelaySeconds": 5,
    "MaxRetryDelaySeconds": 300
  },
  "IntegrationWebhook": {
    "Enabled": false,
    "Endpoint": "",
    "SigningSecret": "",
    "TimeoutSeconds": 15
  },
  "Jwt": {
    "Issuer": "Workplan",
    "Audience": "WorkplanClients",
    "SigningKey": "CHANGE_ME_LOCAL_DEV_ONLY_32_CHARS_MIN",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "InitialAdmin": {
    "Email": "admin@workplan.local",
    "Password": "ChangeMe123!",
    "FullName": "System Admin"
  },
  "SeedDemoData": false
}
