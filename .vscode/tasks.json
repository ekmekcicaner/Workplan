{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: db up",
      "type": "shell",
      "command": "docker start workplan-dev-db 2>/dev/null || docker run -d --name workplan-dev-db -p 5434:5432 -e POSTGRES_DB=workplan -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -v workplan-dev-db-data:/var/lib/postgresql/data postgres:16-alpine",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "build: webapi",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/Workplan.WebApi/Workplan.WebApi.csproj"
      ],
      "dependsOn": "docker: db up",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: client",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/Workplan.Client/Workplan.Client.csproj"
      ],
      "dependsOn": "docker: db up",
      "problemMatcher": "$msCompile"
    }
  ]
}
